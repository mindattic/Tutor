    // Expandable resource details
    private HashSet<string> expandedResources = new();
    private Dictionary<string, ResourceKbDetails> resourceKbDetailsCache = new();

    // Delete confirmation modal
    private bool showDeleteConfirmModal;
    private string deleteConfirmTitle = "";
    private string deleteConfirmMessage = "";
    private Func<Task>? pendingDeleteAction;

    // Advanced settings per resource
    private HashSet<string> expandedAdvancedSettings = new();
    private int globalMaxIterations = SettingsService.DefaultOrphanLinkingMaxIterations;
    private float globalMinConfidence = SettingsService.DefaultOrphanLinkingMinConfidence;

    // Merge duplicates state
    private bool isMergingDuplicates;
    private string? mergeResultMessage;
    private bool mergeResultSuccess;
    private bool showSimilarConceptsModal;
    private List<Tutor.Core.Services.SimilarConceptPair> pendingSimilarPairs = [];
    private List<Tutor.Core.Services.ApprovedMerge> approvedMerges = [];
    
    // Merge progress tracking
    private string? mergeProgressMessage;
    private int mergeProgressPercent;

    // Cancel task confirmation
    private bool showCancelConfirmModal;
    private string? cancelTaskId;
    private string? cancelTaskTitle;

    private string statusMessage = "";
    
    // Timer for updating processing time display
    private System.Threading.Timer? processingTimer;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to processing events
        ProcessingService.OnStatusChanged += OnProcessingStatusChanged;
        ProcessingService.OnProcessingComplete += OnProcessingComplete;
        ProcessingService.OnProcessingError += OnProcessingError;
        
        // Subscribe to CM build progress
        ConceptMapService.OnProgressChanged += OnConceptMapProgressChanged;

        await LoadData();
        RefreshProcessingTasks();
        
        // Start timer to update processing time display every second
        processingTimer = new System.Threading.Timer(
            _ => InvokeAsync(StateHasChanged),
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    public void Dispose()
    {
        processingTimer?.Dispose();
        ProcessingService.OnStatusChanged -= OnProcessingStatusChanged;
        ProcessingService.OnProcessingComplete -= OnProcessingComplete;
        ProcessingService.OnProcessingError -= OnProcessingError;
        ConceptMapService.OnProgressChanged -= OnConceptMapProgressChanged;
    }

    private void OnProcessingStatusChanged(ResourceProcessingStatus status)
    {
        processingTasks[status.TaskId] = status;
        InvokeAsync(StateHasChanged);
    }

    private async void OnProcessingComplete(string taskId)
    {
        // Refresh data when processing completes
        await LoadData();
        
        // Remove from active tasks after a delay
        await Task.Delay(2000);
        processingTasks.Remove(taskId);
        await InvokeAsync(StateHasChanged);
    }

    private void OnProcessingError(string taskId, string error)
    {
        statusMessage = $"Error processing resource: {error}";
        InvokeAsync(StateHasChanged);
    }


    private void RefreshProcessingTasks()
    {
        processingTasks = ProcessingService.GetAllStatuses()
            .ToDictionary(s => s.TaskId, s => s);
    }

    private async Task LoadData()
    {
        resources = await CourseService.GetAllResourcesAsync();
        courses = await CourseService.GetAllCoursesAsync();
        selectedCourseId = await CourseService.GetActiveCourseIdAsync();
        
        // Load global linking settings
        globalMaxIterations = await Settings.GetOrphanLinkingMaxIterationsAsync();
        globalMinConfidence = await Settings.GetOrphanLinkingMinConfidenceAsync();
        
        // Pre-load KB details for all processed resources so concept count shows immediately
        await PreloadResourceKbCounts();
        
        // Load concept count for active course
        await LoadKnowledgeBaseInfo();
    }

    /// <summary>
    /// Pre-loads the concept count for all resources so it displays immediately in the library list.
    /// </summary>
    private async Task PreloadResourceKbCounts()
    {
        foreach (var resource in resources.Where(r => r.IsProcessed && !string.IsNullOrEmpty(r.ConceptMapId)))
        {
            // Skip if already cached
            if (resourceKbDetailsCache.ContainsKey(resource.Id))
                continue;
                
            try
            {
                var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId!);
                if (conceptMap != null)
                {
                    resourceKbDetailsCache[resource.Id] = new ResourceKbDetails
                    {
                        ContentLength = resource.Content?.Length ?? 0,
                        FormattedContentLength = resource.FormattedContent?.Length ?? 0,
                        HasFormattedContent = !string.IsNullOrEmpty(resource.FormattedContent),
                        ConceptMapId = conceptMap.Id,
                        ConceptCount = conceptMap.Concepts.Count,
                        RelationCount = conceptMap.Relations.Count,
                        ConceptMapName = conceptMap.Name,
                        ConceptMapStatus = conceptMap.Status,
                        KnowledgeBaseCreatedAt = conceptMap.CreatedAt,
                        KnowledgeBaseUpdatedAt = conceptMap.UpdatedAt
                    };
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[CourseManagement] Error preloading KB details for {resource.Title}: {ex.Message}");
            }
        }
    }

    private async Task LoadKnowledgeBaseInfo()
    {
        knowledgeBaseConceptCount = 0;
        resourcesWithKb = 0;
        totalResourcesInCourse = 0;
        
        if (!string.IsNullOrEmpty(selectedCourseId))
        {
            var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
            if (course != null)
            {
                totalResourcesInCourse = course.ResourceIds.Count;
                bool needsSave = false;
                
                // Count concepts across all resource ConceptMaps
                foreach (var resourceId in course.ResourceIds)
                {
                    var resource = resources.FirstOrDefault(r => r.Id == resourceId);
                    if (resource == null) continue;
                    
                    // Check if resource has a ConceptMap ID set
                    if (!string.IsNullOrEmpty(resource.ConceptMapId))
                    {
                        var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId);
                        if (conceptMap != null && conceptMap.Status == ConceptMapStatus.Ready)
                        {
                            knowledgeBaseConceptCount += conceptMap.Concepts.Count;
                            resourcesWithKb++;
                            
                            // Fix up stale resource status if needed (migration for older data)
                            if (resource.ConceptMapStatus != ConceptMapStatus.Ready)
                            {
                                resource.ConceptMapStatus = ConceptMapStatus.Ready;
                                needsSave = true;
                            }
                        }
                    }
                }
                
                // Save fixed resources if any were updated
                if (needsSave)
                {
                    await CourseService.SaveAllResourcesAsync(resources);
                }
            }
        }
    }

    private async Task OnCourseChanged()
    {
        await CourseService.SetActiveCourseAsync(selectedCourseId);
        await LoadKnowledgeBaseInfo();
    }

    private async Task ToggleResourceInCourse(string resourceId)
    {
        if (string.IsNullOrEmpty(selectedCourseId))
            return;

        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        if (course == null)
            return;

        bool wasAdded = false;
        if (course.ResourceIds.Contains(resourceId))
        {
            await CourseService.RemoveResourceFromCourseAsync(selectedCourseId, resourceId);
        }
        else
        {
            await CourseService.AddResourceToCourseAsync(selectedCourseId, resourceId);
            wasAdded = true;
        }

        // Invalidate the course's merged map since resources changed
        await CourseConceptMapService.InvalidateMergedMapAsync(selectedCourseId);

        await LoadData();

        // If a resource was added, rebuild the merged map with auto-deduplication
        if (wasAdded)
        {
            var resource = resources.FirstOrDefault(r => r.Id == resourceId);
            if (resource?.HasConceptMap == true)
            {
                // Rebuild merged map (this auto-merges exact duplicates)
                await RebuildMergedMapAndCheckSimilarAsync();
            }
        }
    }

    /// <summary>
    /// Rebuilds the course's merged map and checks for similar concepts.
    /// This works on COPIES - original resource ConceptMaps are never modified.
    /// </summary>
    private async Task RebuildMergedMapAndCheckSimilarAsync()
    {
        try
        {
            // Rebuild the merged map (this auto-merges exact duplicates)
            var mergedMap = await CourseConceptMapService.RebuildMergedMapAsync(selectedCourseId!);
            if (mergedMap == null)
            {
                statusMessage = "Resource added to course.";
                return;
            }

            // Check for similar concepts that need user review
            var duplicates = ConceptMergeService.FindDuplicatesInMergedMap(mergedMap);

            var exactMerged = mergedMap.MergedConceptMapping.Count;

            if (duplicates.SimilarConcepts.Count > 0)
            {
                pendingSimilarPairs = duplicates.SimilarConcepts
                    .OrderByDescending(p => p.SimilarityScore)
                    .ToList();
                showSimilarConceptsModal = true;

                if (exactMerged > 0)
                {
                    mergeResultMessage = $"✓ Auto-merged {exactMerged} duplicate(s). Review {pendingSimilarPairs.Count} similar concept(s) below.";
                    mergeResultSuccess = true;
                }
                else
                {
                    mergeResultMessage = $"Found {pendingSimilarPairs.Count} similar concept(s) to review.";
                    mergeResultSuccess = false;
                }
            }
            else if (exactMerged > 0)
            {
                mergeResultMessage = $"✓ Resource added. Auto-merged {exactMerged} duplicate concept(s).";
                mergeResultSuccess = true;
                
                // Refresh KB stats
                await LoadKnowledgeBaseInfo();
            }
            else
            {
                statusMessage = "Resource added to course.";
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[CourseManagement] Auto-merge error: {ex.Message}");
            statusMessage = "Resource added. Error during auto-merge: " + ex.Message;
        }
    }

