    private void QueueResource()
    {
        if (string.IsNullOrWhiteSpace(resourceTitle))
        {
            statusMessage = "Title is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(resourceContent))
        {
            statusMessage = "Content is required.";
            return;
        }

        var isNew = editingResource == null;
        var resource = editingResource ?? new CourseResource();
        resource.Title = resourceTitle.Trim();
        resource.Author = resourceAuthor.Trim();
        resource.Year = resourceYear.Trim();
        resource.Description = resourceDescription.Trim();
        resource.Content = resourceContent;
        resource.Type = contentSource == "file" ? uploadedFileType : ResourceType.Text;
        resource.FileName = uploadedFileName;

        if (isNew)
        {
            resource.Id = Guid.NewGuid().ToString();
        }

        // Queue for async processing - always formats and builds KB for new resources
        var taskId = ProcessingService.QueueResourceForProcessing(
            resource,
            selectedCourseId,
            autoFormat: isNew,  // Always format new resources
            buildGraph: isNew); // Always build KB for new resources

        statusMessage = "Resource queued for processing. AI formatting and Knowledge Base generation will begin shortly.";
        editingResource = null;
        ClearForm();
        
        // Stay on Add tab to allow adding more resources
        RefreshProcessingTasks();
        StateHasChanged();
    }

    private async Task DeleteResource(string id)
    {
        await CourseService.DeleteResourceAsync(id);
        await LoadData();
    }

    private bool IsRegeneratingConceptMap(string resourceId)
    {
        return regeneratingConceptMaps.Contains(resourceId);
    }

    private async Task RegenerateConceptMap(CourseResource resource)
    {
        if (regeneratingConceptMaps.Contains(resource.Id))
            return;

        // Check if the resource has formatted content
        var content = resource.GetEffectiveContent();
        if (string.IsNullOrWhiteSpace(content))
        {
            Log.Warn($"Cannot regenerate ConceptMap for '{resource.Title}': No content available");
            return;
        }

        try
        {
            regeneratingConceptMaps.Add(resource.Id);
            StateHasChanged();

            Log.Info($"Regenerating ConceptMap for resource: {resource.Title}");

            // Clear existing ConceptMap data
            if (!string.IsNullOrEmpty(resource.ConceptMapId))
            {
                await ConceptMapStorageService.DeleteAsync(resource.ConceptMapId);
            }

            // Reset resource state
            resource.ConceptMapId = null;
            resource.ConceptMapStatus = ConceptMapStatus.NotStarted;
            await CourseService.SaveResourceAsync(resource);

            // Invalidate the cached details
            resourceKbDetailsCache.Remove(resource.Id);


            // Queue the resource for processing (only rebuild ConceptMap, don't re-format)
            ProcessingService.QueueResourceForProcessing(
                resource,
                selectedCourseId,
                autoFormat: false,  // Don't re-format, use existing formatted content
                buildGraph: true);  // Build the ConceptMap
            
            RefreshProcessingTasks();
            
            Log.Info($"ConceptMap regeneration queued for: {resource.Title}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to queue ConceptMap regeneration: {ex.Message}", ex);
        }
        finally
        {
            regeneratingConceptMaps.Remove(resource.Id);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Opens the ConceptMap JSON file for the given resource in the OS file explorer.
    /// </summary>
    private async Task OpenConceptMapFile(CourseResource resource)
    {
        if (string.IsNullOrEmpty(resource.ConceptMapId))
        {
            Log.Warn($"Cannot open ConceptMap for '{resource.Title}': No ConceptMap exists");
            return;
        }

        try
        {
            // Ensure the ConceptMap is saved so the JSON file exists
            var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId);
            if (conceptMap == null)
            {
                Log.Warn($"Cannot open ConceptMap for '{resource.Title}': ConceptMap not found");
                return;
            }

            await ConceptMapStorageService.SaveAsync(conceptMap);

            // Build the expected JSON path based on storage settings
            var kbDir = DataStorageSettings.GetKnowledgeBasesDirectory();
            var jsonPath = Path.Combine(kbDir, conceptMap.Id + ".json");

            if (!File.Exists(jsonPath))
            {
                Log.Warn($"ConceptMap JSON file not found at: {jsonPath}");
                statusMessage = "ConceptMap JSON file not found on disk.";
                return;
            }

            // Open the file in the default associated editor/viewer
            try
            {
#if WINDOWS
                System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
                {
                    FileName = jsonPath,
                    UseShellExecute = true
                });
#else
                System.Diagnostics.Process.Start(jsonPath);
#endif

                statusMessage = "Opened ConceptMap JSON in your default editor.";
            }
            catch (Exception ex)
            {
                Log.Error($"Failed to open ConceptMap JSON: {ex.Message}", ex);
                statusMessage = "Failed to open ConceptMap JSON file.";
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to open ConceptMap: {ex.Message}", ex);
            statusMessage = "Error opening ConceptMap JSON file.";
        }
    }

    private static string SanitizeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var sanitized = new string(name.Select(c => invalid.Contains(c) ? '_' : c).ToArray());
        return sanitized.ToLowerInvariant().Replace(' ', '-');
    }

    private async Task PickFile()
    {
        try
        {
            var picked = await FilePickerService.PickFileAsync(new[] { ".txt", ".docx", ".pdf" });

            if (picked != null)
            {
                uploadedFileName = picked.FileName;
                var extension = Path.GetExtension(picked.FileName).ToLowerInvariant();

                using var stream = picked.Stream;

                switch (extension)
                {
                    case ".txt":
                        uploadedFileType = ResourceType.Txt;
                        using (var reader = new StreamReader(stream))
                        {
                            fullFileContent = await reader.ReadToEndAsync();
                        }
                        break;

                    case ".docx":
                        uploadedFileType = ResourceType.Docx;
                        fullFileContent = await ReadDocxAsync(stream);
                        break;

                    case ".pdf":
                        uploadedFileType = ResourceType.Pdf;
                        fullFileContent = await ReadPdfAsync(stream);
                        break;

                    default:
                        statusMessage = "Unsupported file type.";
                        return;
                }

                // Also set resourceContent for saving
                resourceContent = fullFileContent;

                if (string.IsNullOrEmpty(resourceTitle))
                {
                    resourceTitle = Path.GetFileNameWithoutExtension(picked.FileName);
                }

                statusMessage = $"File loaded: {fullFileContent.Length} characters";
            }
        }
        catch (Exception ex)
        {
            statusMessage = "Error reading file: " + ex.Message;
        }
    }

    private string GetContentPreview()
    {
        if (string.IsNullOrEmpty(fullFileContent))
            return "";
        
        return fullFileContent.Length <= 500 
            ? fullFileContent 
            : fullFileContent[..500];
    }

    private async Task<string> ReadDocxAsync(Stream stream)
    {
        try
        {
            using var archive = new System.IO.Compression.ZipArchive(stream, System.IO.Compression.ZipArchiveMode.Read);
            var entry = archive.GetEntry("word/document.xml");

            if (entry == null)
                return "[Could not read DOCX file]";

            using var entryStream = entry.Open();
            using var reader = new StreamReader(entryStream);
            var xml = await reader.ReadToEndAsync();

            var text = System.Text.RegularExpressions.Regex.Replace(xml, "<[^>]+>", " ");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ");
            return text.Trim();
        }
        catch
        {
            return "[Error reading DOCX file]";
        }
    }

    private Task<string> ReadPdfAsync(Stream stream)
    {
        return Task.FromResult("[PDF content extraction requires additional libraries. Please copy-paste the text content instead, or convert to .txt/.docx format.]");
    }

    // Course management
