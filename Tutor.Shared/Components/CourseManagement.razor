    /// <summary>
    /// Updates the merge progress UI.
    /// </summary>
    private void UpdateMergeProgress(string message, int percent)
    {
        mergeProgressMessage = message;
        mergeProgressPercent = Math.Clamp(percent, 0, 100);
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Handles progress updates from the async deduplication service.
    /// </summary>
    private void OnDuplicateDetectionProgress(DuplicateDetectionProgress progress)
    {
        mergeProgressMessage = progress.Phase;
        mergeProgressPercent = progress.ProgressPercent;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Finds and merges duplicate concepts in the course's merged map.
    /// This ONLY modifies the course-specific merged map, NOT the original resource ConceptMaps.
    /// Uses async parallel processing with progress reporting to avoid UI freezing.
    /// </summary>
    private async Task MergeDuplicatesAsync()
    {
        if (string.IsNullOrEmpty(selectedCourseId) || isMergingDuplicates)
            return;

        isMergingDuplicates = true;
        mergeResultMessage = null;
        mergeResultSuccess = false;
        mergeProgressMessage = "Initializing...";
        mergeProgressPercent = 0;
        StateHasChanged();

        try
        {
            // Step 1: Load ConceptMap IDs
            UpdateMergeProgress("Loading course resources...", 5);
            await Task.Delay(50); // Allow UI to update
            
            var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(selectedCourseId);
            if (conceptMapIds.Count == 0)
            {
                mergeResultMessage = "No Concept Maps found to merge.";
                return;
            }

            // Step 2: Load all source ConceptMaps
            UpdateMergeProgress($"Loading {conceptMapIds.Count} Concept Map(s)...", 10);
            await Task.Delay(50);
            
            var sourceMaps = new List<ConceptMap>();
            var loadIndex = 0;
            foreach (var cmId in conceptMapIds)
            {
                loadIndex++;
                var progressPercent = 10 + (int)(10.0 * loadIndex / conceptMapIds.Count);
                UpdateMergeProgress($"Loading Concept Map {loadIndex}/{conceptMapIds.Count}...", progressPercent);
                
                var cm = await ConceptMapStorageService.LoadAsync(cmId);
                if (cm != null && cm.Status == ConceptMapStatus.Ready)
                {
                    sourceMaps.Add(cm);
                }
            }

            if (sourceMaps.Count == 0)
            {
                mergeResultMessage = "No ready Concept Maps found.";
                return;
            }

            // Step 3: Create merged map with deep copies
            UpdateMergeProgress($"Creating merged map from {sourceMaps.Count} source(s)...", 22);
            await Task.Delay(50);
            
            var mergedMap = new MergedCourseConceptMap
            {
                Id = $"merged-{selectedCourseId}",
                CourseId = selectedCourseId,
                Status = MergedMapStatus.Building
            };
            mergedMap.InitializeFromConceptMaps(sourceMaps);

            // Step 4: Use async parallel duplicate detection with progress reporting
            UpdateMergeProgress($"Scanning {mergedMap.TotalConcepts} concepts for duplicates...", 25);
            await Task.Delay(50);
            
            // The async method handles parallelism and chunking internally
            var duplicateResult = await ConceptMergeService.FindDuplicatesInMergedMapAsync(
                mergedMap,
                progress =>
                {
                    // Scale progress from 25-75% for the detection phase
                    var scaledPercent = 25 + (int)(progress.ProgressPercent * 0.50);
                    UpdateMergeProgress(progress.Phase, scaledPercent);
                });
            
            var exactDupeCount = duplicateResult.ExactDuplicates.Sum(g => g.Concepts.Count - 1);

            // Step 5: Auto-merge exact duplicates
            if (exactDupeCount > 0)
            {
                UpdateMergeProgress($"Auto-merging {exactDupeCount} exact duplicate(s)...", 78);
                await Task.Yield(); // Allow UI to update
                
                var mergeResult = ConceptMergeService.AutoMergeExactDuplicatesInMergedMap(mergedMap);
            }

            // Step 6: Re-scan for similar concepts after exact merges (use async version)
            UpdateMergeProgress("Analyzing similar concepts...", 82);
            await Task.Yield();
            
            duplicateResult = await ConceptMergeService.FindDuplicatesInMergedMapAsync(
                mergedMap,
                progress =>
                {
                    var scaledPercent = 82 + (int)(progress.ProgressPercent * 0.10);
                    UpdateMergeProgress(progress.Phase, scaledPercent);
                });

            // Step 7: Save merged map
            UpdateMergeProgress("Saving merged map...", 95);
            await Task.Yield();
            
            mergedMap.Status = MergedMapStatus.Ready;
            await CourseConceptMapService.SaveMergedMapAsync(mergedMap);

            var totalMerged = mergedMap.MergedConceptMapping.Count;

            // Step 8: Complete
            UpdateMergeProgress("Complete!", 100);

            if (duplicateResult.SimilarConcepts.Count > 0)
            {
                pendingSimilarPairs = duplicateResult.SimilarConcepts
                    .OrderByDescending(p => p.SimilarityScore)
                    .ToList();
                showSimilarConceptsModal = true;
                
                mergeResultMessage = totalMerged > 0
                    ? $"✓ Auto-merged {totalMerged} exact duplicate(s). Found {pendingSimilarPairs.Count} similar concept pair(s) for review."
                    : $"Found {pendingSimilarPairs.Count} similar concept pair(s) for review.";
                mergeResultSuccess = totalMerged > 0;
            }
            else if (totalMerged > 0)
            {
                mergeResultMessage = $"✓ Successfully merged {totalMerged} duplicate concept(s). Original resource maps unchanged.";
                mergeResultSuccess = true;
                
                // Refresh stats
                await LoadKnowledgeBaseInfo();
            }
            else
            {
                mergeResultMessage = "No duplicate concepts found.";
                mergeResultSuccess = true;
            }
        }
        catch (Exception ex)
        {
            mergeResultMessage = $"Error during merge: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[CourseManagement] Merge error: {ex.Message}");
        }
        finally
        {
            isMergingDuplicates = false;
            mergeProgressMessage = null;
            mergeProgressPercent = 0;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Approves a similar concept pair for merging.
    /// </summary>
    private void ApproveSimilarMerge(Tutor.Core.Services.SimilarConceptPair pair)
    {
        // Select the one with the longer/more complete title as canonical
        var keepA = pair.ConceptA.Title.Length >= pair.ConceptB.Title.Length;
        
        approvedMerges.Add(new ApprovedMerge
        {
            ConceptAId = pair.ConceptA.Id,
            ConceptBId = pair.ConceptB.Id,
            KeepConceptAId = keepA ? pair.ConceptA.Id : pair.ConceptB.Id,
            CanonicalTitle = keepA ? pair.ConceptA.Title : pair.ConceptB.Title
        });

        pendingSimilarPairs.Remove(pair);
        StateHasChanged();
    }

    /// <summary>
    /// Skips a similar concept pair (keeps them separate).
    /// </summary>
    private void SkipSimilarMerge(Tutor.Core.Services.SimilarConceptPair pair)
    {
        pendingSimilarPairs.Remove(pair);
        StateHasChanged();
    }

    /// <summary>
    /// Approves a similar concept pair at the given index.
    /// </summary>
    private void ApproveSimilarMergeAt(int index)
    {
        if (index >= 0 && index < pendingSimilarPairs.Count)
        {
            ApproveSimilarMerge(pendingSimilarPairs[index]);
        }
    }

    /// <summary>
    /// Skips a similar concept pair at the given index.
    /// </summary>
    private void SkipSimilarMergeAt(int index)
    {
        if (index >= 0 && index < pendingSimilarPairs.Count)
        {
            SkipSimilarMerge(pendingSimilarPairs[index]);
        }
    }

    /// <summary>
    /// Dismisses the merge result message.
    /// </summary>
    private void DismissMergeMessage()
    {
        mergeResultMessage = null;
    }

    /// <summary>
    /// Applies all approved merges for similar concepts to the course's merged map.
    /// This ONLY modifies the course-specific merged map, NOT the original resource ConceptMaps.
    /// </summary>
    private async Task ApplyApprovedMerges()
    {
        if (approvedMerges.Count == 0)
        {
            CloseSimilarConceptsModal();
            return;
        }

        isMergingDuplicates = true;
        StateHasChanged();

        try
        {
            // Apply merges to the course's merged map (NOT the original ConceptMaps)
            var result = await CourseConceptMapService.MergeApprovedPairsAsync(selectedCourseId!, approvedMerges);

            mergeResultMessage = $"✓ Merged {result.MergedCount} similar concept(s). Original resource maps unchanged.";
            mergeResultSuccess = true;

            approvedMerges.Clear();
            CloseSimilarConceptsModal();
            
            // Refresh stats
            await LoadKnowledgeBaseInfo();
        }
        catch (Exception ex)
        {
            mergeResultMessage = $"Error applying merges: {ex.Message}";
        }
        finally
        {
            isMergingDuplicates = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Closes the similar concepts confirmation modal.
    /// </summary>
    private void CloseSimilarConceptsModal()
    {
        showSimilarConceptsModal = false;
        pendingSimilarPairs.Clear();
        approvedMerges.Clear();
    }
