    // Expandable resource details
    private async Task ToggleResourceExpanded(string resourceId)
    {
        if (expandedResources.Contains(resourceId))
        {
            expandedResources.Remove(resourceId);
        }
        else
        {
            expandedResources.Add(resourceId);
            // Load KB details if not cached
            if (!resourceKbDetailsCache.ContainsKey(resourceId))
            {
                await LoadResourceKbDetails(resourceId);
            }
        }
    }

    private async Task LoadResourceKbDetails(string resourceId)
    {
        var resource = resources.FirstOrDefault(r => r.Id == resourceId);
        if (resource == null) return;

        var details = new ResourceKbDetails
        {
            ContentLength = resource.Content?.Length ?? 0,
            FormattedContentLength = resource.FormattedContent?.Length ?? 0,
            HasFormattedContent = !string.IsNullOrEmpty(resource.FormattedContent),
            ConceptMapStatus = resource.ConceptMapStatus
        };

        // Load ConceptMap if exists
        if (!string.IsNullOrEmpty(resource.ConceptMapId))
        {
            var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId);
            if (conceptMap != null)
            {
                details.ConceptMapId = conceptMap.Id;
                details.ConceptCount = conceptMap.Concepts.Count;
                details.RelationCount = conceptMap.Relations.Count;
                details.ConceptMapName = conceptMap.Name;
                details.ConceptMapStatus = conceptMap.Status;
                details.KnowledgeBaseCreatedAt = conceptMap.CreatedAt;
                details.KnowledgeBaseUpdatedAt = conceptMap.UpdatedAt;
            }
        }

        resourceKbDetailsCache[resourceId] = details;
    }

    private bool IsResourceExpanded(string resourceId) => expandedResources.Contains(resourceId);

    private ResourceKbDetails? GetResourceKbDetails(string resourceId)
    {
        resourceKbDetailsCache.TryGetValue(resourceId, out var details);
        return details;
    }

    // Helper class for caching ConceptMap details
    private class ResourceKbDetails
    {
        public int ContentLength { get; set; }
        public int FormattedContentLength { get; set; }
        public bool HasFormattedContent { get; set; }
        public string? ConceptMapId { get; set; }
        public string? ConceptMapName { get; set; }
        public int ConceptCount { get; set; }
        public int RelationCount { get; set; }
        public ConceptMapStatus ConceptMapStatus { get; set; }
        public DateTime? KnowledgeBaseCreatedAt { get; set; }
        public DateTime? KnowledgeBaseUpdatedAt { get; set; }
    }

