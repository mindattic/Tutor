    private void ConfirmDeleteResource(CourseResource resource)
    {
        deleteConfirmTitle = "Delete Resource";
        deleteConfirmMessage = $"Are you sure you want to delete \"{resource.Title}\"? This will remove it from all courses.";
        pendingDeleteAction = async () =>
        {
            await CourseService.DeleteResourceAsync(resource.Id);
            await LoadData();
        };
        showDeleteConfirmModal = true;
    }

    private async Task ExecuteDelete()
    {
        if (pendingDeleteAction != null)
        {
            await pendingDeleteAction();
        }
        CloseModals();
    }

    private void ConfirmCancelTask(string taskId, string taskTitle)
    {
        cancelTaskId = taskId;
        cancelTaskTitle = taskTitle;
        showCancelConfirmModal = true;
    }

    private void ExecuteCancelTask()
    {
        if (!string.IsNullOrEmpty(cancelTaskId))
        {
            // Cancel via the BackgroundQueueService
            var cancelled = Tutor.Core.Services.Queue.BackgroundQueueService.CancelTask(cancelTaskId);
            
            if (cancelled)
            {
                // Remove from local tracking
                processingTasks.Remove(cancelTaskId);
                statusMessage = $"Cancelled upload: {cancelTaskTitle}";
                Log.Info($"User cancelled resource upload: {cancelTaskTitle}");
            }
            else
            {
                statusMessage = $"Could not cancel upload (may have already completed)";
            }
        }
        
        CloseModals();
    }

    private void ResumeFailedTask(string taskId)
    {
        var resumed = Tutor.Core.Services.Queue.BackgroundQueueService.RetryTask(taskId);
        
        if (resumed)
        {
            // Update local status to show it's processing again
            if (processingTasks.TryGetValue(taskId, out var task))
            {
                task.Stage = ProcessingStage.Queued;
                task.CurrentOperation = "Resuming from checkpoint...";
            }
            statusMessage = "Task resumed - will continue from last checkpoint";
            Log.Info($"User resumed failed task: {taskId}");
        }
        else
        {
            statusMessage = "Could not resume task";
        }
        
        RefreshProcessingTasks();
        StateHasChanged();
    }

    private void ResumeAllFailedTasks()
    {
        var failedTaskIds = processingTasks.Values
            .Where(t => t.Stage == ProcessingStage.Failed)
            .Select(t => t.TaskId)
            .ToList();
        
        var resumedCount = 0;
        foreach (var taskId in failedTaskIds)
        {
            if (Tutor.Core.Services.Queue.BackgroundQueueService.RetryTask(taskId))
            {
                resumedCount++;
            }
        }
        
        statusMessage = $"Resumed {resumedCount} task(s) - will continue from checkpoints";
        Log.Info($"User resumed {resumedCount} failed tasks");
        
        RefreshProcessingTasks();
        StateHasChanged();
    }

    private async Task CreateCourse()
    {
        if (string.IsNullOrWhiteSpace(newCourseName))
            return;

        var course = await CourseService.CreateCourseAsync(
            newCourseName.Trim(), 
            newCourseDescription.Trim());

        selectedCourseId = course.Id;
        await CourseService.SetActiveCourseAsync(course.Id);
        await LoadData();
        CloseModals();
    }

    private async Task RenameCourse()
    {
        if (string.IsNullOrWhiteSpace(renameCourseName) || string.IsNullOrEmpty(selectedCourseId))
            return;

        await CourseService.RenameCourseAsync(selectedCourseId, renameCourseName.Trim());
        await LoadData();
        CloseModals();
    }

