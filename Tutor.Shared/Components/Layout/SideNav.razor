@using Tutor.Core.Services
@inject AppUiState UiState
@implements IDisposable

<nav class="side-nav" aria-label="Sidebar navigation">
    @if (Nodes.Count == 0)
    {
        <div class="side-nav-empty" role="status">
            <span class="bi bi-folder2-open" aria-hidden="true"></span>
            <span>No items to display</span>
        </div>
    }
    else
    {
        <ul class="side-nav-tree" role="tree" aria-label="Navigation tree">
            @foreach (var node in Nodes)
            {
                <SideNavNode Node="@node" Level="0" OnNodeClick="HandleNodeClick" OnToggle="HandleToggle" />
            }
        </ul>
    }
</nav>

@code {
    [Parameter]
    public List<NavNode> Nodes { get; set; } = [];

    [Parameter]
    public EventCallback<NavNode> OnNodeSelected { get; set; }

    protected override void OnInitialized()
    {
        UiState.OnSideNavChanged += HandleSideNavChanged;
    }

    private void HandleSideNavChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleNodeClick(NavNode node)
    {
        UiState.SelectNode(node.Id);
        await OnNodeSelected.InvokeAsync(node);
    }

    private void HandleToggle(NavNode node)
    {
        UiState.ToggleNode(node.Id);
    }

    public void Dispose()
    {
        UiState.OnSideNavChanged -= HandleSideNavChanged;
    }
}
