@using Tutor.Core.Services
@inject NavigationManager Nav
@inject AppUiState UiState
@inject SettingsService Settings
@inject AuthenticationService AuthService
@implements IDisposable

<div class="top-menu">
    <div class="top-menu-brand">
        <a href="" class="brand-link">
            <span class="bi bi-mortarboard-fill"></span>
            <span class="brand-text">Tutor</span>
        </a>
    </div>
    
    <nav class="top-menu-nav">
        <NavLink class="top-nav-link" href="" Match="NavLinkMatch.All" @onclick="() => OnTabSelected(TopTab.Home)">
            <span class="bi bi-house-fill"></span>
            <span>Home</span>
        </NavLink>
        @if (AuthService.IsAuthenticated)
        {
            <NavLink class="top-nav-link" href="courses" Match="NavLinkMatch.Prefix" @onclick="() => OnTabSelected(TopTab.Courses)">
                <span class="bi bi-book-fill"></span>
                <span>Courses</span>
            </NavLink>
            <NavLink class="top-nav-link" href="learn" Match="NavLinkMatch.Prefix" @onclick="() => OnTabSelected(TopTab.Learn)">
                <span class="bi bi-mortarboard-fill"></span>
                <span>Learn</span>
            </NavLink>
            @if (AuthService.IsAdmin)
            {
                <NavLink class="top-nav-link" href="settings" Match="NavLinkMatch.Prefix" @onclick="() => OnTabSelected(TopTab.Settings)">
                    <span class="bi bi-gear-fill"></span>
                    <span>Settings</span>
                </NavLink>
            }
        }
    </nav>

    <div class="profile-menu">
        @if (AuthService.IsAuthenticated)
        {
            <span class="profile-username">@userDisplayName</span>
            <button class="profile-avatar" @onclick="ToggleProfileMenu" @onclick:stopPropagation="true">
                @if (!string.IsNullOrEmpty(userCustomAvatar))
                {
                    <img src="@userCustomAvatar" alt="@userDisplayName" />
                }
                else
                {
                    <span class="bi @userAvatarIcon"></span>
                }
            </button>
            @if (showProfileMenu)
            {
                <div class="profile-dropdown">
                    <a href="profile" class="dropdown-item">
                        <span class="bi bi-person"></span>
                        <span>My Profile</span>
                    </a>
                    <a href="account" class="dropdown-item">
                        <span class="bi bi-gear"></span>
                        <span>Account Settings</span>
                    </a>
                    <a href="progress" class="dropdown-item">
                        <span class="bi bi-bar-chart"></span>
                        <span>My Progress</span>
                    </a>
                    <div class="dropdown-divider"></div>
                    <a href="help" class="dropdown-item">
                        <span class="bi bi-question-circle"></span>
                        <span>Help</span>
                    </a>
                    <button class="dropdown-item" @onclick="HandleLogout">
                        <span class="bi bi-box-arrow-right"></span>
                        <span>Log Out</span>
                    </button>
                </div>
            }
        }
    </div>
</div>

@code {
    private bool showProfileMenu = false;
    private string userDisplayName = "User";
    private string userAvatarIcon = "bi-person-fill";
    private string? userCustomAvatar;

    protected override void OnInitialized()
    {
        // Subscribe to auth state changes to refresh menu
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        
        // Determine initial tab from current URL
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var path = uri.AbsolutePath.TrimStart('/').ToLowerInvariant();
        
        var tab = path switch
        {
            "" or "home" => TopTab.Learn,
            var p when p.StartsWith("learn") => TopTab.Learn,
            var p when p.StartsWith("courses") => TopTab.Courses,
            var p when p.StartsWith("knowledge-bases") => TopTab.KnowledgeGraph,
            var p when p.StartsWith("knowledge-graph") => TopTab.KnowledgeGraph,
            var p when p.StartsWith("settings") => TopTab.Settings,
            _ => TopTab.Learn
        };
        
        UiState.SetActiveTab(tab);
    }

    private void HandleAuthStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnTabSelected(TopTab tab)
    {
        UiState.SetActiveTab(tab);
    }

    private void ToggleProfileMenu()
    {
        showProfileMenu = !showProfileMenu;
    }

    private async Task HandleLogout()
    {
        showProfileMenu = false;
        await AuthService.LogoutAsync();
        Nav.NavigateTo("/");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Use the actual logged-in username, fallback to settings display name
            if (AuthService.IsAuthenticated && !string.IsNullOrEmpty(AuthService.CurrentUsername))
            {
                userDisplayName = AuthService.CurrentUsername;
            }
            else
            {
                userDisplayName = await Settings.GetUserDisplayNameAsync();
            }
            userAvatarIcon = await Settings.GetUserAvatarIconAsync();
            userCustomAvatar = await Settings.GetUserCustomAvatarAsync();
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
