@inherits LayoutComponentBase
@using Microsoft.JSInterop
@using Tutor.Core.Services
@inject ThemeService ThemeService
@inject SettingsService SettingsService
@inject IJSRuntime JS

<a class="skip-link" href="#main-content">Skip to main content</a>
<div class="app-layout">
    <TopMenu />

    <main id="main-content" class="main-panel" tabindex="-1" role="main" aria-label="Main content">
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await ThemeService.GetThemeAsync();
            await JS.InvokeVoidAsync("setTheme", theme);

            var borderRadius = await SettingsService.GetBorderRadiusAsync();
            await JS.InvokeVoidAsync("setBorderRadius", borderRadius);
        }
    }
}
