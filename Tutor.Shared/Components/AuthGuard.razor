@using Tutor.Core.Services
@inject AuthenticationService AuthService
@inject NavigationManager Nav
@implements IDisposable

@* 
    AuthGuard component that wraps protected content.
    If user is not authenticated, redirects to home page.
    Can also check for specific roles.
*@

@if (_initialized && AuthService.IsAuthenticated)
{
    @if (RequiredRole.HasValue && !AuthService.HasRole(RequiredRole.Value))
    {
        <div class="auth-guard-denied" role="alert" aria-labelledby="access-denied-heading">
            <span class="bi bi-shield-lock" aria-hidden="true"></span>
            <h2 id="access-denied-heading">Access Denied</h2>
            <p>You don't have permission to access this page.</p>
            <button class="back-btn" type="button" @onclick="GoHome">Go to Home</button>
        </div>
    }
    else
    {
        @ChildContent
    }
}
else if (_initialized)
{
    <div class="auth-guard-redirect" role="status" aria-live="polite">
        <span class="spinner" aria-hidden="true"></span>
        <p>Redirecting to login...</p>
    </div>
}
else
{
    <div class="auth-guard-loading" role="status" aria-live="polite">
        <span class="spinner" aria-hidden="true"></span>
        <p>Loading...</p>
    </div>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Optional role required to access the content.
    /// </summary>
    [Parameter]
    public UserRole? RequiredRole { get; set; }

    /// <summary>
    /// If true, silently shows nothing instead of redirecting.
    /// </summary>
    [Parameter]
    public bool Silent { get; set; }

    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        AuthService.OnAuthStateChanged += HandleAuthStateChanged;
        
        // Initialize the auth service
        await AuthService.InitializeAsync();
        _initialized = true;

        // Redirect if not authenticated
        if (!AuthService.IsAuthenticated && !Silent)
        {
            Nav.NavigateTo("/");
        }
    }

    private async void HandleAuthStateChanged()
    {
        try
        {
            await InvokeAsync(() =>
            {
                if (!AuthService.IsAuthenticated && !Silent)
                {
                    Nav.NavigateTo("/");
                }
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException)
        {
            // Component was disposed before the callback could run
        }
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        AuthService.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
