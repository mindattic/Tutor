@using Tutor.Core.Models
@using Tutor.Core.Services
@inject QuizService QuizService
@inject CourseService CourseService
@inject ConceptMapStorageService ConceptMapStorageService
@implements IDisposable

<section class="quiz-tab" aria-labelledby="quiz-region-label">
    <h2 id="quiz-region-label" class="sr-only">Quiz</h2>
    @if (string.IsNullOrEmpty(CourseId))
    {
        <div class="quiz-empty" role="status">
            <span class="bi bi-book" aria-hidden="true"></span>
            <h3>No Course Selected</h3>
            <p>Please select a course to start a quiz.</p>
        </div>
    }
    else if (_loading)
    {
        <div class="quiz-loading" role="status" aria-live="polite">
            <span class="spinner" aria-hidden="true"></span>
            <p>Loading quiz...</p>
        </div>
    }
    else if (QuizService.HasActiveSession)
    {
        @* Active Quiz Session *@
        <div class="quiz-active" aria-labelledby="quiz-active-heading">
            <h3 id="quiz-active-heading" class="sr-only">Active quiz</h3>
            <div class="quiz-progress-bar"
                 role="progressbar"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-valuenow="@((int)GetProgressPercentage())"
                 aria-label="Quiz progress">
                <div class="quiz-progress" style="width: @GetProgressPercentage()%"></div>
            </div>
            <div class="quiz-header" aria-live="polite" aria-atomic="true">
                <span class="question-counter">Question @(QuizService.CurrentSession!.CurrentQuestionIndex + 1) of @QuizService.CurrentSession.Questions.Count</span>
            </div>

            @if (_currentQuestion != null)
            {
                <div class="question-bubble" role="group" aria-labelledby="quiz-question-text">
                    <span class="bi bi-question-circle" aria-hidden="true"></span>
                    <div id="quiz-question-text" class="question-text">@_currentQuestion.QuestionText</div>
                </div>

                @if (!string.IsNullOrEmpty(_feedback))
                {
                    <div class="feedback-bubble @(_lastAnswerCorrect ? "correct" : "incorrect")"
                         role="status"
                         aria-live="assertive"
                         aria-atomic="true">
                        <span class="bi @(_lastAnswerCorrect ? "bi-check-circle" : "bi-x-circle")" aria-hidden="true"></span>
                        <div class="feedback-text">@(_lastAnswerCorrect ? "Correct. " : "Incorrect. ")@_feedback</div>
                    </div>

                    @if (!string.IsNullOrEmpty(_currentQuestion.Explanation))
                    {
                        <div class="explanation-bubble">
                            <span class="bi bi-lightbulb" aria-hidden="true"></span>
                            <div class="explanation-text">@_currentQuestion.Explanation</div>
                        </div>
                    }

                    <button class="quiz-btn primary" type="button" @onclick="NextQuestion">
                        @if (_quizComplete)
                        {
                            <span>View Results</span>
                        }
                        else
                        {
                            <span>Next Question</span>
                        }
                        <span class="bi bi-arrow-right" aria-hidden="true"></span>
                    </button>
                }
                else
                {
                    <div class="answer-section">
                        <label for="quiz-answer" class="sr-only">Your answer</label>
                        <textarea id="quiz-answer"
                                  @bind="_userAnswer"
                                  @bind:event="oninput"
                                  placeholder="Type your answer here..."
                                  rows="3"
                                  aria-describedby="quiz-question-text"
                                  disabled="@_submitting"></textarea>

                        <button class="quiz-btn primary"
                                type="button"
                                @onclick="SubmitAnswer"
                                disabled="@(string.IsNullOrWhiteSpace(_userAnswer) || _submitting)"
                                aria-busy="@_submitting.ToString().ToLowerInvariant()">
                            @if (_submitting)
                            {
                                <span class="spinner-small" aria-hidden="true"></span>
                            }
                            else
                            {
                                <span class="bi bi-send" aria-hidden="true"></span>
                            }
                            <span>Submit Answer</span>
                        </button>
                    </div>
                }
            }
        </div>
    }
    else if (_quizResult != null)
    {
        @* Quiz Results *@
        <section class="quiz-results" role="region" aria-labelledby="quiz-results-heading">
            <header class="results-header @(_quizResult.Passed ? "passed" : "failed")">
                <span class="bi @(_quizResult.Passed ? "bi-trophy" : "bi-emoji-frown")" aria-hidden="true"></span>
                <h2 id="quiz-results-heading">@(_quizResult.Passed ? "Congratulations!" : "Keep Learning!")</h2>
            </header>

            <div class="results-score" role="group" aria-label="Score summary">
                <div class="score-circle @(_quizResult.Passed ? "passed" : "failed")" aria-hidden="true">
                    <span class="score-value">@(_quizResult.ScorePercentage.ToString("0"))%</span>
                </div>
                <div class="score-details">
                    <p>Score: @(_quizResult.ScorePercentage.ToString("0"))%. @_quizResult.CorrectAnswers of @_quizResult.TotalQuestions correct.</p>
                    <p class="points">@_quizResult.EarnedPoints of @_quizResult.TotalPoints points earned.</p>
                </div>
            </div>

            <div class="results-actions">
                <button class="quiz-btn secondary" type="button" @onclick="RetryQuiz">
                    <span class="bi bi-arrow-repeat" aria-hidden="true"></span>
                    <span>Try Again</span>
                </button>
                <button class="quiz-btn primary" type="button" @onclick="BackToLesson">
                    <span class="bi bi-book" aria-hidden="true"></span>
                    <span>Continue Learning</span>
                </button>
            </div>
        </section>
    }
    else
    {
        @* Quiz Start Screen *@
        <section class="quiz-start" aria-labelledby="quiz-start-heading">
            <header class="quiz-start-header">
                <span class="bi bi-question-circle" aria-hidden="true"></span>
                @if (_isSectionQuiz)
                {
                    <h2 id="quiz-start-heading">Section Quiz</h2>
                    <p>Complete this quiz to master: <strong>@SectionTitle</strong></p>
                }
                else
                {
                    <h2 id="quiz-start-heading">Ready for a Quiz?</h2>
                    <p>Test your knowledge based on what you've learned so far.</p>
                }
            </header>

            @if (_conceptIds.Count == 0 && LearnedConcepts.Count == 0)
            {
                <div class="quiz-warning" role="status">
                    <span class="bi bi-info-circle" aria-hidden="true"></span>
                    <p>You haven't learned any concepts yet. Start a lesson first to unlock quizzes!</p>
                </div>

                <button class="quiz-btn secondary" type="button" @onclick="BackToLesson">
                    <span class="bi bi-book" aria-hidden="true"></span>
                    <span>Go to Lessons</span>
                </button>
            }
            else
            {
                <ul class="quiz-info" aria-label="Quiz overview" style="list-style:none;padding:0;">
                    <li class="info-item">
                        <span class="bi bi-journal-check" aria-hidden="true"></span>
                        <span>@(_isSectionQuiz ? $"{_conceptIds.Count} concepts in section" : $"{LearnedConcepts.Count} concepts learned")</span>
                    </li>
                    <li class="info-item">
                        <span class="bi bi-list-ol" aria-hidden="true"></span>
                        <span>@GetQuestionCount() questions</span>
                    </li>
                    <li class="info-item">
                        <span class="bi bi-clock" aria-hidden="true"></span>
                        <span>~@GetEstimatedMinutes() minutes</span>
                    </li>
                </ul>

                <button class="quiz-btn primary large"
                        type="button"
                        @onclick="StartQuiz"
                        disabled="@_starting"
                        aria-busy="@_starting.ToString().ToLowerInvariant()">
                    @if (_starting)
                    {
                        <span class="spinner-small" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span class="bi bi-play-fill" aria-hidden="true"></span>
                    }
                    <span>Start Quiz</span>
                </button>
            }

            @if (_quizHistory.Count > 0 && !_isSectionQuiz)
            {
                <section class="quiz-history" aria-labelledby="quiz-history-heading">
                    <h3 id="quiz-history-heading">Recent Quizzes</h3>
                    <ul style="list-style:none;padding:0;">
                        @foreach (var result in _quizHistory.Take(3))
                        {
                            <li class="history-item @(result.Passed ? "passed" : "failed")">
                                <span class="history-score">@(result.ScorePercentage.ToString("0"))%</span>
                                <span class="history-date">@result.CompletedAt.ToString("MMM d, h:mm tt")</span>
                                <span class="bi @(result.Passed ? "bi-check-circle" : "bi-x-circle")"
                                      aria-label="@(result.Passed ? "Passed" : "Failed")"></span>
                            </li>
                        }
                    </ul>
                </section>
            }
        </section>
    }
</section>

@code {
[Parameter]
public string? CourseId { get; set; }

[Parameter]
public HashSet<string> LearnedConcepts { get; set; } = [];

[Parameter]
public EventCallback OnBackToLesson { get; set; }

/// <summary>
/// Optional: Section ID to scope the quiz to a specific section
/// </summary>
[Parameter]
public string? SectionId { get; set; }

/// <summary>
/// Optional: Section title for display purposes
/// </summary>
[Parameter]
public string? SectionTitle { get; set; }

/// <summary>
/// Optional: Concept IDs to quiz on (overrides LearnedConcepts if provided)
/// </summary>
[Parameter]
public List<string>? SectionConceptIds { get; set; }

/// <summary>
/// Event fired when section quiz is completed
/// </summary>
[Parameter]
public EventCallback<QuizResult> OnSectionQuizCompleted { get; set; }

private bool _loading;
private bool _starting;
private bool _submitting;
private bool _quizComplete;
private bool _lastAnswerCorrect;
private string _userAnswer = "";
private string? _feedback;
private QuizQuestion? _currentQuestion;
private QuizResult? _quizResult;
private List<QuizResult> _quizHistory = [];
private List<string> _conceptIds = [];
private bool _isSectionQuiz => !string.IsNullOrEmpty(SectionId);

protected override async Task OnInitializedAsync()
{
    QuizService.OnQuizStateChanged += HandleQuizStateChanged;
    await LoadDataAsync();
}

protected override async Task OnParametersSetAsync()
{
    await LoadDataAsync();
}

private async Task LoadDataAsync()
{
    if (string.IsNullOrEmpty(CourseId))
        return;

    _loading = true;
    StateHasChanged();

    try
    {
        // If section concept IDs are provided, use those
        if (SectionConceptIds != null && SectionConceptIds.Count > 0)
        {
            _conceptIds = SectionConceptIds.ToList();
        }
        else if (LearnedConcepts.Count > 0)
        {
            // Load concept IDs matching encountered/learned concept names
            var allConcepts = await LoadAllCourseConceptsAsync();
            if (allConcepts.Count > 0)
            {
                // Try exact match first, then fuzzy (contains) match
                _conceptIds = allConcepts
                    .Where(c => LearnedConcepts.Any(lc =>
                        c.Title.Equals(lc, StringComparison.OrdinalIgnoreCase) ||
                        c.Title.Contains(lc, StringComparison.OrdinalIgnoreCase) ||
                        lc.Contains(c.Title, StringComparison.OrdinalIgnoreCase)))
                    .Select(c => c.Id)
                    .Distinct()
                    .ToList();
            }
        }

            // Load quiz history
            _quizHistory = await QuizService.GetQuizHistoryAsync(CourseId);

            // Update current question if quiz is active
            _currentQuestion = QuizService.GetCurrentQuestion();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Load all concepts from the course - tries collection first, falls back to individual resource maps.
    /// </summary>
    private async Task<List<Concept>> LoadAllCourseConceptsAsync()
    {
        var course = await CourseService.GetCourseAsync(CourseId!);
        if (course == null) return [];

        // Try the aggregated collection first
        if (!string.IsNullOrEmpty(course.ConceptMapCollectionId))
        {
            var conceptMap = await ConceptMapStorageService.LoadAsync(course.ConceptMapCollectionId);
            if (conceptMap != null && conceptMap.Concepts.Count > 0)
                return conceptMap.Concepts;
        }

        // Fall back to individual resource concept maps
        var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(CourseId!);
        var allConcepts = new List<Concept>();
        foreach (var cmId in conceptMapIds)
        {
            var cm = await ConceptMapStorageService.LoadAsync(cmId);
            if (cm != null && cm.Status == ConceptMapStatus.Ready)
                allConcepts.AddRange(cm.Concepts);
        }
        return allConcepts;
    }

    private async Task StartQuiz()
    {
        if (string.IsNullOrEmpty(CourseId) || _conceptIds.Count == 0)
            return;

        _starting = true;
        _quizResult = null;
        _feedback = null;
        StateHasChanged();

        try
        {
            var sectionIds = _isSectionQuiz ? [SectionId!] : new List<string>();
            var questionCount = GetQuestionCount();
            
            await QuizService.StartQuizAsync(CourseId, sectionIds, _conceptIds, questionCount);
            _currentQuestion = QuizService.GetCurrentQuestion();
        }
        finally
        {
            _starting = false;
            StateHasChanged();
        }
    }

    private async Task SubmitAnswer()
    {
        if (string.IsNullOrWhiteSpace(_userAnswer))
            return;

        _submitting = true;
        StateHasChanged();

        try
        {
            var (isCorrect, feedback, complete) = await QuizService.SubmitAnswerAsync(_userAnswer);
            _lastAnswerCorrect = isCorrect;
            _feedback = feedback;
            _quizComplete = complete;
        }
        finally
        {
            _submitting = false;
            StateHasChanged();
        }
    }

    private async Task NextQuestion()
    {
        if (_quizComplete)
        {
            _quizResult = QuizService.GetCurrentResult();
            QuizService.CancelQuiz();
            
            // Notify if section quiz completed
            if (_isSectionQuiz && _quizResult != null)
            {
                await OnSectionQuizCompleted.InvokeAsync(_quizResult);
            }
        }
        else
        {
            _currentQuestion = QuizService.GetCurrentQuestion();
        }
        
        _userAnswer = "";
        _feedback = null;
        StateHasChanged();
    }

    private async Task RetryQuiz()
    {
        _quizResult = null;
        await StartQuiz();
    }

    private async Task BackToLesson()
    {
        _quizResult = null;
        await OnBackToLesson.InvokeAsync();
    }

    private double GetProgressPercentage()
    {
        if (QuizService.CurrentSession == null)
            return 0;
        
        var total = QuizService.CurrentSession.Questions.Count;
        var current = QuizService.CurrentSession.CurrentQuestionIndex;
        return (double)current / total * 100;
    }

    private int GetQuestionCount()
    {
        // For section quizzes, use a smaller number based on concept count
        if (_isSectionQuiz)
        {
            return Math.Max(3, Math.Min(5, _conceptIds.Count));
        }
        return 5;
    }

    private int GetEstimatedMinutes()
    {
        return GetQuestionCount();
    }

    private void HandleQuizStateChanged()
    {
        InvokeAsync(() =>
        {
            _currentQuestion = QuizService.GetCurrentQuestion();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        QuizService.OnQuizStateChanged -= HandleQuizStateChanged;
    }
}
