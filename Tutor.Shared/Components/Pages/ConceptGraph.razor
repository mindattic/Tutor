@page "/knowledge-bases"
@page "/knowledge-graph"
@using Tutor.Core.Models
@using Tutor.Core.Services
@inject KnowledgeGraphService GraphService
@inject CourseService CourseService

<AuthGuard>
<h1 class="page-title">Knowledge Bases</h1>

<div class="knowledge-graph-page">
    @if (isLoading)
    {
        <div class="loading-state" role="status" aria-live="polite">
            <div class="spinner" aria-hidden="true"></div>
            <p>Loading...</p>
        </div>
    }
    else if (string.IsNullOrEmpty(activeCourseId))
    {
        <section class="no-course-state" aria-labelledby="no-course-heading">
            <div class="empty-icon" aria-hidden="true">
                <span class="bi bi-book"></span>
            </div>
            <h2 id="no-course-heading">No Active Course</h2>
            <p>Select an active course to view or build its knowledge graph.</p>
            <a href="courses" class="settings-btn primary">
                <span class="bi bi-book-fill" aria-hidden="true"></span> Go to Courses
            </a>
        </section>
    }
    else if (isBuilding)
    {
        <section class="graph-building-progress"
                 role="status"
                 aria-live="polite"
                 aria-atomic="true"
                 aria-labelledby="building-graph-title">
            <div class="building-header">
                <span class="building-icon bi bi-diagram-3" aria-hidden="true"></span>
                <span id="building-graph-title" class="building-title">Building Knowledge Graph</span>
            </div>
            <div class="progress-bar-container"
                 role="progressbar"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 aria-valuenow="@buildProgress.PercentComplete"
                 aria-label="Knowledge graph build progress">
                <div class="progress-bar" style="width: @(buildProgress.PercentComplete)%"></div>
            </div>
            <div class="building-status">
                <span class="status-message">@buildProgress.Message</span>
                @if (!string.IsNullOrEmpty(buildProgress.Detail))
                {
                    <span class="status-detail">@buildProgress.Detail</span>
                }
            </div>
            <div class="building-step">
                Step @buildProgress.CurrentStep of @buildProgress.TotalSteps
            </div>
        </section>
    }
    else if (graph == null)
    {
        <section class="empty-graph-state" aria-labelledby="no-kg-heading">
            <div class="empty-icon" aria-hidden="true">
                <span class="bi bi-diagram-3"></span>
            </div>
            <h2 id="no-kg-heading">No Knowledge Graph</h2>
            <p>Build a knowledge graph from <strong>@activeCourse?.Name</strong> to see concepts organized hierarchically.</p>
            @if (resources.Count > 0)
            {
                <p class="resource-count">@resources.Count resource(s) available for analysis</p>
                <button class="settings-btn primary" type="button" @onclick="BuildGraph">
                    <span class="bi bi-lightning-charge" aria-hidden="true"></span> Build Knowledge Graph
                </button>
            }
            else
            {
                <p class="hint">Add resources to your course first, then build the knowledge graph.</p>
                <a href="courses" class="settings-btn">
                    <span class="bi bi-plus-lg" aria-hidden="true"></span> Add Resources
                </a>
            }
        </section>
    }
    else
    {
        <header class="graph-header">
            <h2 class="graph-title">
                <span class="bi bi-diagram-3" aria-hidden="true"></span>
                <span>@activeCourse?.Name</span>
            </h2>
            <dl class="graph-stats" aria-label="Graph statistics">
                <div class="stat">
                    <dt class="stat-label">concepts</dt>
                    <dd class="stat-value">@stats.TotalConcepts</dd>
                </div>
                <div class="stat">
                    <dt class="stat-label">relationships</dt>
                    <dd class="stat-value">@stats.TotalRelationships</dd>
                </div>
                <div class="stat">
                    <dt class="stat-label">depth</dt>
                    <dd class="stat-value">@stats.MaxDepth</dd>
                </div>
            </dl>
            <div class="graph-actions" role="toolbar" aria-label="Graph actions">
                <button class="icon-btn" type="button" title="Refresh" aria-label="Refresh graph" @onclick="RefreshGraph">
                    <span class="bi bi-arrow-clockwise" aria-hidden="true"></span>
                </button>
                <button class="icon-btn" type="button" title="Rebuild Graph" aria-label="Rebuild graph" @onclick="BuildGraph">
                    <span class="bi bi-lightning-charge" aria-hidden="true"></span>
                </button>
            </div>
        </header>

        <div class="graph-toolbar">
            <div class="view-toggle" role="tablist" aria-label="Graph view mode">
                <button class="toggle-btn @(viewMode == "hierarchy" ? "active" : "")"
                        type="button"
                        role="tab"
                        id="tab-hierarchy"
                        aria-selected="@(viewMode == "hierarchy" ? "true" : "false")"
                        aria-controls="graph-content"
                        tabindex="@(viewMode == "hierarchy" ? "0" : "-1")"
                        @onclick="@(() => viewMode = "hierarchy")">
                    <span class="bi bi-list-nested" aria-hidden="true"></span> Hierarchy
                </button>
                <button class="toggle-btn @(viewMode == "path" ? "active" : "")"
                        type="button"
                        role="tab"
                        id="tab-path"
                        aria-selected="@(viewMode == "path" ? "true" : "false")"
                        aria-controls="graph-content"
                        tabindex="@(viewMode == "path" ? "0" : "-1")"
                        @onclick="@(() => viewMode = "path")">
                    <span class="bi bi-signpost-split" aria-hidden="true"></span> Learning Path
                </button>
                <button class="toggle-btn @(viewMode == "search" ? "active" : "")"
                        type="button"
                        role="tab"
                        id="tab-search"
                        aria-selected="@(viewMode == "search" ? "true" : "false")"
                        aria-controls="graph-content"
                        tabindex="@(viewMode == "search" ? "0" : "-1")"
                        @onclick="@(() => viewMode = "search")">
                    <span class="bi bi-search" aria-hidden="true"></span> Search
                </button>
            </div>

            @if (viewMode == "path" || viewMode == "search")
            {
                <div class="search-box" role="search">
                    <label for="graph-search-input" class="sr-only">@(viewMode == "path" ? "Enter concept to explore" : "Search concepts")</label>
                    <input id="graph-search-input"
                           type="search"
                           class="settings-input"
                           placeholder="@(viewMode == "path" ? "Enter concept to explore..." : "Search concepts...")"
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @onkeyup="OnSearchKeyUp" />
                    @if (!string.IsNullOrEmpty(searchQuery))
                    {
                        <button class="clear-btn" type="button" aria-label="Clear search" @onclick="ClearSearch">
                            <span class="bi bi-x" aria-hidden="true"></span>
                        </button>
                    }
                </div>
            }
        </div>

        <div id="graph-content"
             class="graph-content"
             role="tabpanel"
             aria-labelledby="@($"tab-{viewMode}")">
            @if (viewMode == "hierarchy")
            {
                <div class="toc-view">
                    <div class="path-placeholder">
                        <span class="bi bi-diagram-3" aria-hidden="true"></span>
                        <p>Hierarchy view is being updated</p>
                        <p class="hint">Use the Courses page to build a KnowledgeBase and CourseStructure for a structured view.</p>
                    </div>
                </div>
            }
            else if (viewMode == "path")
            {
                <div class="path-placeholder">
                    <span class="bi bi-signpost-split" aria-hidden="true"></span>
                    <p>Learning path view is being updated</p>
                    <p class="hint">Use the Learn page to access the new structured learning experience.</p>
                </div>
            }
            else if (viewMode == "search")
            {
                @if (searchResults.Count > 0)
                {
                    <div class="search-results" role="region" aria-live="polite" aria-label="Search results">
                        <p class="results-count">Found @searchResults.Count concepts</p>
                        <ul class="concept-card-list" style="list-style:none;padding:0;">
                            @foreach (var concept in searchResults)
                            {
                                <li>
                                    <button class="concept-card @(selectedConceptId == concept.Id ? "selected" : "")"
                                            type="button"
                                            aria-pressed="@((selectedConceptId == concept.Id).ToString().ToLowerInvariant())"
                                            @onclick="@(() => SelectConcept(concept.Id))">
                                        <div class="concept-term">@concept.Term</div>
                                        <div class="concept-description">@Truncate(concept.Description, 150)</div>
                                        <div class="concept-meta">
                                            <span class="meta-item">Depth @concept.HierarchyDepth</span>
                                            @if (concept.PrerequisiteIds.Count > 0)
                                            {
                                                <span class="meta-item">@concept.PrerequisiteIds.Count prereqs</span>
                                            }
                                        </div>
                                    </button>
                                </li>
                            }
                        </ul>
                    </div>
                }
                else if (!string.IsNullOrEmpty(searchQuery))
                {
                    <div class="no-results" role="status" aria-live="polite">
                        <p>No concepts found matching "@searchQuery"</p>
                    </div>
                }
            }
        </div>

        @* Concept Detail Panel *@
        @if (selectedConcept != null)
        {
            <aside class="concept-detail-panel"
                   role="complementary"
                   aria-labelledby="concept-detail-heading">
                <header class="detail-header">
                    <h3 id="concept-detail-heading">@selectedConcept.Term</h3>
                    <button class="close-btn" type="button" aria-label="Close concept details" @onclick="DeselectConcept">
                        <span class="bi bi-x-lg" aria-hidden="true"></span>
                    </button>
                </header>
                <div class="detail-body">
                    <div class="detail-section">
                        <p class="detail-description">@selectedConcept.Description</p>
                    </div>

                    @if (selectedConcept.Aliases.Count > 0)
                    {
                        <div class="detail-section">
                            <h4>Also known as</h4>
                            <p>@string.Join(", ", selectedConcept.Aliases)</p>
                        </div>
                    }

                    <div class="detail-section">
                        <h4>Hierarchy</h4>
                        <div class="hierarchy-info">
                            <span class="depth-badge">Depth @selectedConcept.HierarchyDepth</span>
                            @if (selectedConcept.IsFoundational)
                            {
                                <span class="badge foundational">Foundational</span>
                            }
                            @if (selectedConcept.IsLeaf)
                            {
                                <span class="badge leaf">Leaf</span>
                            }
                        </div>
                    </div>

                    @if (selectedPrerequisites.Count > 0)
                    {
                        <div class="detail-section">
                            <h4>Prerequisites (@selectedPrerequisites.Count)</h4>
                            <ul class="related-concepts" style="list-style:none;padding:0;">
                                @foreach (var prereq in selectedPrerequisites)
                                {
                                    <li>
                                        <button class="concept-link" type="button" @onclick="@(() => SelectConcept(prereq.Id))">
                                            <span class="bi bi-arrow-left" aria-hidden="true"></span> @prereq.Term
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    @if (selectedDependents.Count > 0)
                    {
                        <div class="detail-section">
                            <h4>Unlocks (@selectedDependents.Count)</h4>
                            <ul class="related-concepts" style="list-style:none;padding:0;">
                                @foreach (var dep in selectedDependents)
                                {
                                    <li>
                                        <button class="concept-link" type="button" @onclick="@(() => SelectConcept(dep.Id))">
                                            @dep.Term <span class="bi bi-arrow-right" aria-hidden="true"></span>
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <div class="detail-actions">
                        <button class="settings-btn" type="button" @onclick="ShowPathTo">
                            <span class="bi bi-arrow-left" aria-hidden="true"></span> Path To This
                        </button>
                        <button class="settings-btn" type="button" @onclick="ShowPathFrom">
                            Path From This <span class="bi bi-arrow-right" aria-hidden="true"></span>
                        </button>
                    </div>
                </div>
            </aside>
        }
    }
</div>
</AuthGuard>

@code {
    private string? activeCourseId;
    private Course? activeCourse;
    private List<CourseResource> resources = [];
    
    private KnowledgeGraph? graph;
    private KnowledgeGraphStats stats = new();
    
    private string viewMode = "hierarchy";
    private string searchQuery = "";
    private List<ConceptNode> searchResults = [];
    
    private string? selectedConceptId;
    private ConceptNode? selectedConcept;
    private List<ConceptNode> selectedPrerequisites = [];
    private List<ConceptNode> selectedDependents = [];


    private bool isLoading = true;
    private bool isBuilding;
    private GraphBuildProgress buildProgress = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Get active course
            activeCourseId = await CourseService.GetActiveCourseIdAsync();
            
            if (!string.IsNullOrEmpty(activeCourseId))
            {
                var courses = await CourseService.GetAllCoursesAsync();
                activeCourse = courses.FirstOrDefault(c => c.Id == activeCourseId);
                
                if (activeCourse != null)
                {
                    // Load resources for this course
                    var allResources = await CourseService.GetAllResourcesAsync();
                    resources = allResources.Where(r => activeCourse.ResourceIds.Contains(r.Id)).ToList();
                    
                    // Load existing graph if available
                    graph = await GraphService.GetGraphForCourseAsync(activeCourseId);
                    
                    if (graph != null)
                    {
                        stats = graph.GetStats();
                    }
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshGraph()
    {
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task BuildGraph()
    {
        if (string.IsNullOrEmpty(activeCourseId) || resources.Count == 0)
            return;

        isBuilding = true;
        buildProgress = new GraphBuildProgress { Message = "Initializing..." };
        StateHasChanged();

        try
        {
            var progress = new Progress<GraphBuildProgress>(p =>
            {
                buildProgress = p;
                InvokeAsync(StateHasChanged);
            });

            graph = await GraphService.CreateGraphFromResourcesAsync(
                activeCourse?.Name ?? "Knowledge Graph",
                activeCourseId,
                resources,
                progress);

            stats = graph.GetStats();
        }
        catch (Exception ex)
        {
            buildProgress = new GraphBuildProgress { Message = $"Error: {ex.Message}" };
        }
        finally
        {
            isBuilding = false;
        }
    }

    private void SelectConcept(string conceptId)
    {
        if (graph == null)
            return;

        selectedConceptId = conceptId;
        
        if (graph.Nodes.TryGetValue(conceptId, out var concept))
        {
            selectedConcept = concept;
            selectedPrerequisites = graph.GetPrerequisites(conceptId).ToList();
            selectedDependents = graph.GetDependents(conceptId).ToList();
        }
    }

    private void DeselectConcept()
    {
        selectedConceptId = null;
        selectedConcept = null;
        selectedPrerequisites.Clear();
        selectedDependents.Clear();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
        {
            await PerformSearch();
        }
    }

    private async Task PerformSearch()
    {
        if (graph == null || string.IsNullOrWhiteSpace(searchQuery))
            return;

        searchResults = await GraphService.FindSimilarConceptsAsync(graph.Id, searchQuery, 10);
        
        var exactMatch = graph.FindByTerm(searchQuery);
        if (exactMatch != null && !searchResults.Any(c => c.Id == exactMatch.Id))
        {
            searchResults.Insert(0, exactMatch);
        }
    }

    private void ClearSearch()
    {
        searchQuery = "";
        searchResults.Clear();
    }

    private void ShowPathTo()
    {
        // Path view is being redesigned - redirect to Learn page
        viewMode = "path";
    }

    private void ShowPathFrom()
    {
        // Path view is being redesigned - redirect to Learn page
        viewMode = "path";
    }

    private static string Truncate(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text) || text.Length <= maxLength)
            return text;
        return text[..maxLength] + "...";
    }
}
