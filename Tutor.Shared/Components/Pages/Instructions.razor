@page "/instructions"
@inject NavigationManager Nav
@inject ISecurePreferences SecurePreferences

<AuthGuard>
<h3 class="page-title">Instructions</h3>
<p>Add instructions that will be sent with every prompt to control ChatGPT's behavior.</p>

<div style="max-width: 720px;">
    @for (int i = 0; i < instructions.Count; i++)
    {
        var index = i;
        <div class="instruction-item">
            <div class="instruction-header">
                <span class="instruction-number">Instruction @(index + 1)</span>
                <button class="delete-btn" @onclick="() => DeleteInstruction(index)" disabled="@isBusy">Delete</button>
            </div>
            <textarea @bind="instructions[index]" 
                      @bind:event="oninput"
                      rows="3" 
                      placeholder="Enter instruction..."
                      class="instruction-textarea"></textarea>
            <button class="save-btn" @onclick="() => SaveInstruction(index)" disabled="@isBusy">Save</button>
        </div>
    }

    <div class="add-section">
        <button class="add-btn" @onclick="AddInstruction" disabled="@isBusy">+ Add Instruction</button>
    </div>

    <p class="status-message">@status</p>
</div>
</AuthGuard>

@code {
    private const string StorageKeyPrefix = "INSTRUCTION_";
    private const string CountKey = "INSTRUCTION_COUNT";

    private List<string> instructions = new();
    private string status = "";
    private bool isBusy;

    protected override async Task OnInitializedAsync()
    {
        await LoadInstructions();
    }

    private async Task LoadInstructions()
    {
        isBusy = true;
        try
        {
            var countStr = await SecurePreferences.GetAsync(CountKey);
            var count = int.TryParse(countStr, out var c) ? c : 0;

            instructions.Clear();
            for (int i = 0; i < count; i++)
            {
                var instruction = await SecurePreferences.GetAsync($"{StorageKeyPrefix}{i}") ?? "";
                instructions.Add(instruction);
            }

            if (instructions.Count == 0)
            {
                status = "No instructions yet. Click 'Add Instruction' to create one.";
            }
            else
            {
                status = $"Loaded {instructions.Count} instruction(s).";
            }
        }
        catch (Exception ex)
        {
            status = "Load failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void AddInstruction()
    {
        instructions.Add("");
        status = "New instruction added. Enter text and click Save.";
    }

    private async Task SaveInstruction(int index)
    {
        if (index < 0 || index >= instructions.Count) return;

        isBusy = true;
        try
        {
            await SecurePreferences.SetAsync($"{StorageKeyPrefix}{index}", instructions[index]);
            await SecurePreferences.SetAsync(CountKey, instructions.Count.ToString());
            status = $"Instruction {index + 1} saved.";
        }
        catch (Exception ex)
        {
            status = "Save failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteInstruction(int index)
    {
        if (index < 0 || index >= instructions.Count) return;

        isBusy = true;
        try
        {
            instructions.RemoveAt(index);

            // Re-save all instructions with new indices
            for (int i = 0; i < instructions.Count; i++)
            {
                await SecurePreferences.SetAsync($"{StorageKeyPrefix}{i}", instructions[i]);
            }
            
            // Remove the last key that's now orphaned
            SecurePreferences.Remove($"{StorageKeyPrefix}{instructions.Count}");
            await SecurePreferences.SetAsync(CountKey, instructions.Count.ToString());
            
            status = "Instruction deleted.";
        }
        catch (Exception ex)
        {
            status = "Delete failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
