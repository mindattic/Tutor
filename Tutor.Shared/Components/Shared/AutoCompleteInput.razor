@using Tutor.Core.Services
@typeparam TItem

<div class="autocomplete-container @Class">
    <span class="bi bi-search"></span>
    <input type="text"
           class="autocomplete-input"
           placeholder="@Placeholder"
           @bind="Value"
           @bind:event="oninput"
           @bind:after="OnInputChanged"
           @onkeydown="HandleKeyDown"
           @onfocus="OnFocus"
           @onblur="OnBlur" />
    @if (!string.IsNullOrEmpty(Value))
    {
        <button class="autocomplete-clear-btn" @onclick="Clear" title="Clear">
            <span class="bi bi-x-lg"></span>
        </button>
    }
    @if (showDropdown && suggestions.Count > 0)
    {
        <div class="autocomplete-dropdown">
            @for (int i = 0; i < suggestions.Count; i++)
            {
                var index = i;
                var item = suggestions[i];
                <button class="autocomplete-item @(selectedIndex == index ? "selected" : "")"
                        @onmousedown="@(() => SelectItem(item))"
                        @onmouseenter="@(() => selectedIndex = index)">
                    <span class="bi @ItemIcon"></span>
                    <span class="suggestion-text">@ItemTextSelector(item)</span>
                </button>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// The current input value (two-way bindable).
    /// </summary>
    [Parameter]
    public string Value { get; set; } = "";

    /// <summary>
    /// Callback when the value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    /// <summary>
    /// Placeholder text for the input.
    /// </summary>
    [Parameter]
    public string Placeholder { get; set; } = "Search...";

    /// <summary>
    /// The source items to search through.
    /// </summary>
    [Parameter]
    public IEnumerable<TItem> Items { get; set; } = [];

    /// <summary>
    /// Function to get the display text from an item.
    /// </summary>
    [Parameter]
    public Func<TItem, string> ItemTextSelector { get; set; } = item => item?.ToString() ?? "";

    /// <summary>
    /// Function to filter/search items. Returns scored results.
    /// If not provided, uses simple contains matching.
    /// </summary>
    [Parameter]
    public Func<IEnumerable<TItem>, string, IEnumerable<TItem>>? SearchFunction { get; set; }

    /// <summary>
    /// Minimum characters before showing suggestions.
    /// </summary>
    [Parameter]
    public int MinQueryLength { get; set; } = 3;

    /// <summary>
    /// Maximum number of suggestions to show.
    /// </summary>
    [Parameter]
    public int MaxSuggestions { get; set; } = 8;

    /// <summary>
    /// Bootstrap icon class for suggestion items.
    /// </summary>
    [Parameter]
    public string ItemIcon { get; set; } = "bi-lightbulb";

    /// <summary>
    /// Additional CSS class for the container.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Callback when an item is selected from the dropdown.
    /// </summary>
    [Parameter]
    public EventCallback<TItem> OnItemSelected { get; set; }

    /// <summary>
    /// Callback when Enter is pressed (for form submission).
    /// </summary>
    [Parameter]
    public EventCallback<string> OnSubmit { get; set; }

    /// <summary>
    /// Callback when the input is cleared.
    /// </summary>
    [Parameter]
    public EventCallback OnCleared { get; set; }

    private List<TItem> suggestions = [];
    private bool showDropdown;
    private int selectedIndex = -1;

    private async Task OnInputChanged()
    {
        await ValueChanged.InvokeAsync(Value);

        if (!string.IsNullOrWhiteSpace(Value) && Value.Trim().Length >= MinQueryLength)
        {
            UpdateSuggestions();
            showDropdown = true;
        }
        else
        {
            HideDropdown();
        }
    }

    private void UpdateSuggestions()
    {
        if (SearchFunction != null)
        {
            suggestions = SearchFunction(Items, Value).Take(MaxSuggestions).ToList();
        }
        else
        {
            // Default: simple case-insensitive contains
            var query = Value.Trim().ToLowerInvariant();
            suggestions = Items
                .Where(item => ItemTextSelector(item).Contains(query, StringComparison.OrdinalIgnoreCase))
                .Take(MaxSuggestions)
                .ToList();
        }

        selectedIndex = suggestions.Count > 0 ? 0 : -1;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (showDropdown && suggestions.Count > 0)
        {
            switch (e.Key)
            {
                case "ArrowDown":
                    selectedIndex = Math.Min(selectedIndex + 1, suggestions.Count - 1);
                    return;

                case "ArrowUp":
                    selectedIndex = Math.Max(selectedIndex - 1, 0);
                    return;

                case "Enter":
                    if (selectedIndex >= 0 && selectedIndex < suggestions.Count)
                    {
                        await SelectItem(suggestions[selectedIndex]);
                        return;
                    }
                    break;

                case "Escape":
                    HideDropdown();
                    return;

                case "Tab":
                    if (selectedIndex >= 0 && selectedIndex < suggestions.Count)
                    {
                        await SelectItem(suggestions[selectedIndex]);
                        return;
                    }
                    break;
            }
        }

        // Default Enter behavior - submit
        if (e.Key == "Enter")
        {
            HideDropdown();
            await OnSubmit.InvokeAsync(Value);
        }
    }

    private async Task SelectItem(TItem item)
    {
        Value = ItemTextSelector(item);
        await ValueChanged.InvokeAsync(Value);
        HideDropdown();
        await OnItemSelected.InvokeAsync(item);
    }

    private void OnFocus()
    {
        if (!string.IsNullOrWhiteSpace(Value) && Value.Trim().Length >= MinQueryLength && suggestions.Count > 0)
        {
            showDropdown = true;
        }
    }

    private async Task OnBlur()
    {
        // Small delay to allow click events on dropdown items to fire first
        await Task.Delay(150);
        HideDropdown();
    }

    private async Task Clear()
    {
        Value = "";
        await ValueChanged.InvokeAsync(Value);
        HideDropdown();
        await OnCleared.InvokeAsync();
    }

    private void HideDropdown()
    {
        showDropdown = false;
        selectedIndex = -1;
    }
}
