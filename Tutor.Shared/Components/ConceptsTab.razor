@using Tutor.Core.Models
@using Tutor.Core.Services
@inject CourseService CourseService
@inject ConceptMapStorageService ConceptMapStorageService
@inject ConceptAutoCompleteService AutoCompleteService

<div class="concepts-tab-container">
    @if (string.IsNullOrEmpty(CourseId))
    {
        <div class="concepts-empty-state" role="status">
            <span class="bi bi-journal-x" aria-hidden="true"></span>
            <h4>No Course Selected</h4>
            <p>Select a course to view its concepts.</p>
        </div>
    }
    else if (isLoading)
    {
        <div class="concepts-loading" role="status" aria-live="polite">
            <div class="spinner" aria-hidden="true"></div>
            <p>Loading concepts...</p>
        </div>
    }
    else if (concepts.Count == 0)
    {
        <div class="concepts-empty-state" role="status">
            <span class="bi bi-journal-text" aria-hidden="true"></span>
            <h4>No Concepts Available</h4>
            <p>Build concept maps for your course resources to see concepts here.</p>
        </div>
    }
    else
    {
        @* Search and filter bar *@
        <div class="concepts-toolbar" role="search" aria-label="Concept search and filters">
            <AutoCompleteInput TItem="Concept"
                               @bind-Value="searchQuery"
                               Placeholder="Search concepts..."
                               Items="concepts"
                               ItemTextSelector="@(c => c.Title)"
                               SearchFunction="@((items, query) => AutoCompleteService.GetSuggestions(items, query).Select(s => items.First(c => c.Id == s.Id)))"
                               OnItemSelected="OnAutoCompleteItemSelected"
                               OnCleared="ClearSearch"
                               Class="concepts-search" />
            <div class="concepts-filter">
                <label for="concepts-filter-mode" class="sr-only">Filter concepts</label>
                <select id="concepts-filter-mode" @bind="filterMode">
                    <option value="all">All Concepts</option>
                    <option value="learned">Learned</option>
                    <option value="not-learned">Not Learned</option>
                </select>
            </div>
            <div class="concepts-stats" aria-live="polite" aria-atomic="true">
                <span class="stat-item">
                    <span class="bi bi-journal-text" aria-hidden="true"></span>
                    <span>@filteredConcepts.Count() of @concepts.Count</span>
                </span>
                @if (LearnedConcepts.Count > 0)
                {
                    <span class="stat-item learned">
                        <span class="bi bi-check-circle-fill" aria-hidden="true"></span>
                        <span>@LearnedConcepts.Count learned</span>
                    </span>
                }
            </div>
        </div>

        @* Concepts grid *@
        <ul class="concepts-grid" style="list-style:none;padding:0;" aria-label="Concepts">
            @foreach (var concept in filteredConcepts)
            {
                var isLearned = LearnedConcepts.Contains(concept.Title);
                var isSelected = concept.Id == SelectedConceptId;

                <li>
                    <article class="concept-card @(isLearned ? "learned" : "") @(isSelected ? "selected" : "")"
                             tabindex="0"
                             role="button"
                             aria-pressed="@isSelected.ToString().ToLowerInvariant()"
                             aria-label="@($"{concept.Title}{(isLearned ? ", learned" : "")}")"
                             @onclick="() => SelectConcept(concept)"
                             @onkeydown="@(e => HandleConceptCardKey(e, concept))">
                        <header class="concept-card-header">
                            <h5 class="concept-title">@concept.Title</h5>
                            <div class="concept-badges">
                                @if (isLearned)
                                {
                                    <span class="badge learned" title="You've learned this concept" aria-label="Learned">
                                        <span class="bi bi-check-circle-fill" aria-hidden="true"></span>
                                    </span>
                                }
                            </div>
                        </header>

                        @if (!string.IsNullOrEmpty(concept.Summary))
                        {
                            <p class="concept-summary">@TruncateSummary(concept.Summary)</p>
                        }

                        @if (concept.Aliases.Count > 0)
                        {
                            <div class="concept-aliases">
                                <span class="label">Also known as:</span>
                                <span class="value">@string.Join(", ", concept.Aliases.Take(3))</span>
                                @if (concept.Aliases.Count > 3)
                                {
                                    <span class="more" aria-label="@($"and {concept.Aliases.Count - 3} more")">+@(concept.Aliases.Count - 3)</span>
                                }
                            </div>
                        }

                        @if (concept.Tags.Count > 0)
                        {
                            <ul class="concept-tags" aria-label="Tags" style="list-style:none;padding:0;">
                                @foreach (var tag in concept.Tags.Take(4))
                                {
                                    <li class="concept-tag">@tag</li>
                                }
                            </ul>
                        }

                        <div class="concept-actions">
                            <button class="action-btn ask"
                                    type="button"
                                    @onclick="() => AskAboutConcept(concept)"
                                    @onclick:stopPropagation="true"
                                    title="Ask about this concept"
                                    aria-label="@($"Ask about {concept.Title}")">
                                <span class="bi bi-chat-dots" aria-hidden="true"></span>
                                <span>Ask</span>
                            </button>
                            <button class="action-btn visualize"
                                    type="button"
                                    @onclick="() => VisualizeConcept(concept)"
                                    @onclick:stopPropagation="true"
                                    title="View in graph"
                                    aria-label="@($"View {concept.Title} in graph")">
                                <span class="bi bi-diagram-3" aria-hidden="true"></span>
                                <span>Visualize</span>
                            </button>
                        </div>
                    </article>
                </li>
            }
        </ul>
    }
</div>

@* Concept Detail Panel (shown when a concept is selected) *@
@if (selectedConcept != null)
{
    <div class="concept-detail-overlay"
         role="dialog"
         aria-modal="true"
         aria-labelledby="concept-detail-title"
         @onclick="ClearSelection">
        <div class="concept-detail-panel" @onclick:stopPropagation="true">
            <header class="detail-header">
                <h4 id="concept-detail-title">@selectedConcept.Title</h4>
                <button class="close-btn" type="button" aria-label="Close concept details" @onclick="ClearSelection">
                    <span class="bi bi-x-lg" aria-hidden="true"></span>
                </button>
            </header>

            <div class="detail-body">
                @if (!string.IsNullOrEmpty(selectedConcept.Summary))
                {
                    <section class="detail-section" aria-labelledby="cd-summary">
                        <h6 id="cd-summary">Summary</h6>
                        <p>@selectedConcept.Summary</p>
                    </section>
                }

                @if (selectedConcept.Aliases.Count > 0)
                {
                    <section class="detail-section" aria-labelledby="cd-aliases">
                        <h6 id="cd-aliases">Also Known As</h6>
                        <ul class="alias-list" style="list-style:none;padding:0;">
                            @foreach (var alias in selectedConcept.Aliases)
                            {
                                <li class="alias-chip">@alias</li>
                            }
                        </ul>
                    </section>
                }

                @if (selectedConcept.Tags.Count > 0)
                {
                    <section class="detail-section" aria-labelledby="cd-tags">
                        <h6 id="cd-tags">Tags</h6>
                        <ul class="tag-list" style="list-style:none;padding:0;">
                            @foreach (var tag in selectedConcept.Tags)
                            {
                                <li class="tag-chip">@tag</li>
                            }
                        </ul>
                    </section>
                }

                @if (relatedConcepts.Count > 0)
                {
                    <section class="detail-section" aria-labelledby="cd-related">
                        <h6 id="cd-related">Related Concepts</h6>
                        <ul class="related-list" style="list-style:none;padding:0;">
                            @foreach (var rel in relatedConcepts)
                            {
                                <li>
                                    <button class="related-btn" type="button" @onclick="() => SelectConceptById(rel.TargetConceptId)">
                                        <span class="rel-type">@FormatRelationType(rel.RelationType)</span>
                                        <span class="rel-target">@GetConceptTitle(rel.TargetConceptId)</span>
                                        <span class="bi bi-arrow-right" aria-hidden="true"></span>
                                    </button>
                                </li>
                            }
                        </ul>
                    </section>
                }
            </div>

            <div class="detail-actions">
                <button class="action-btn primary" type="button" @onclick="() => AskAboutConcept(selectedConcept)">
                    <span class="bi bi-chat-dots" aria-hidden="true"></span>
                    Ask About This
                </button>
                <button class="action-btn secondary" type="button" @onclick="() => VisualizeConcept(selectedConcept)">
                    <span class="bi bi-diagram-3" aria-hidden="true"></span>
                    Visualize
                </button>
            </div>
        </div>
    </div>
}

@code {
[Parameter] public string? CourseId { get; set; }
[Parameter] public HashSet<string> LearnedConcepts { get; set; } = [];
[Parameter] public string? SelectedConceptId { get; set; }
[Parameter] public EventCallback<string> OnAskAboutConcept { get; set; }
[Parameter] public EventCallback<string> OnVisualizeConcept { get; set; }

private bool isLoading = true;
private List<Concept> concepts = [];
private List<ConceptRelationship> relationships = [];
private string searchQuery = "";
private string filterMode = "all";
private Concept? selectedConcept;
private List<ConceptRelationship> relatedConcepts = [];
private string? lastAppliedExternalSelection;

private IEnumerable<Concept> filteredConcepts => concepts
    .Where(c => MatchesSearch(c) && MatchesFilter(c))
    .OrderBy(c => c.Title);

protected override async Task OnInitializedAsync()
{
    await LoadConcepts();
}

protected override async Task OnParametersSetAsync()
{
    // Handle external concept selection - only apply if it's a new external selection
    if (!string.IsNullOrEmpty(SelectedConceptId) && SelectedConceptId != lastAppliedExternalSelection)
    {
        var concept = concepts.FirstOrDefault(c => c.Id == SelectedConceptId);
        if (concept != null)
        {
            SelectConcept(concept);
            lastAppliedExternalSelection = SelectedConceptId;
        }
    }
}

    private async Task LoadConcepts()
    {
        if (string.IsNullOrEmpty(CourseId))
        {
            isLoading = false;
            return;
        }

        isLoading = true;
        StateHasChanged();

        try
        {
            var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(CourseId);
            var allConcepts = new List<Concept>();
            var allRelationships = new List<ConceptRelationship>();

            foreach (var cmId in conceptMapIds)
            {
                var cm = await ConceptMapStorageService.LoadAsync(cmId);
                if (cm != null && cm.Status == ConceptMapStatus.Ready)
                {
                    allConcepts.AddRange(cm.Concepts);
                    allRelationships.AddRange(cm.Relations);
                }
            }

            concepts = allConcepts;
            relationships = allRelationships;
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptsTab] Error loading concepts: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private bool MatchesSearch(Concept concept)
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
            return true;

        var query = searchQuery.Trim().ToLowerInvariant();
        return concept.Title.Contains(query, StringComparison.OrdinalIgnoreCase) ||
               concept.Summary?.Contains(query, StringComparison.OrdinalIgnoreCase) == true ||
               concept.Aliases.Any(a => a.Contains(query, StringComparison.OrdinalIgnoreCase)) ||
               concept.Tags.Any(t => t.Contains(query, StringComparison.OrdinalIgnoreCase));
    }

    private bool MatchesFilter(Concept concept)
    {
        return filterMode switch
        {
            "learned" => LearnedConcepts.Contains(concept.Title),
            "not-learned" => !LearnedConcepts.Contains(concept.Title),
            _ => true
        };
    }

    private void ClearSearch()
    {
        searchQuery = "";
    }

    /// <summary>
    /// Called when user selects an item from autocomplete dropdown.
    /// </summary>
    private void OnAutoCompleteItemSelected(Concept concept)
    {
        searchQuery = concept.Title;
        SelectConcept(concept);
    }

    private void SelectConcept(Concept concept)
    {
        selectedConcept = concept;
        relatedConcepts = relationships
            .Where(r => r.SourceConceptId == concept.Id)
            .ToList();
    }

    private void HandleConceptCardKey(KeyboardEventArgs e, Concept concept)
    {
        if (e.Key == "Enter" || e.Key == " " || e.Key == "Spacebar")
        {
            SelectConcept(concept);
        }
    }

    private void SelectConceptById(string conceptId)
    {
        var concept = concepts.FirstOrDefault(c => c.Id == conceptId);
        if (concept != null)
        {
            SelectConcept(concept);
        }
    }

    private void ClearSelection()
    {
        selectedConcept = null;
        relatedConcepts = [];
        lastAppliedExternalSelection = null;
    }

    private async Task AskAboutConcept(Concept concept)
    {
        ClearSelection();
        if (OnAskAboutConcept.HasDelegate)
        {
            await OnAskAboutConcept.InvokeAsync(concept.Title);
        }
    }

    private async Task VisualizeConcept(Concept concept)
    {
        ClearSelection();
        if (OnVisualizeConcept.HasDelegate)
        {
            await OnVisualizeConcept.InvokeAsync(concept.Id);
        }
    }

    private string TruncateSummary(string summary, int maxLength = 120)
    {
        if (string.IsNullOrEmpty(summary) || summary.Length <= maxLength)
            return summary;
        return summary[..maxLength] + "...";
    }

    private string GetConceptTitle(string conceptId)
    {
        return concepts.FirstOrDefault(c => c.Id == conceptId)?.Title ?? "Unknown";
    }

    private string FormatRelationType(ConceptRelationType type)
    {
        return type switch
        {
            ConceptRelationType.Prerequisite => "requires",
            ConceptRelationType.Related => "related to",
            ConceptRelationType.Contains => "contains",
            ConceptRelationType.InstanceOf => "instance of",
            ConceptRelationType.SimilarTo => "similar to",
            ConceptRelationType.ContrastsWith => "contrasts",
            _ => type.ToString().ToLower()
        };
    }
}
