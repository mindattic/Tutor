@using Microsoft.JSInterop
@using Tutor.Models
@using Tutor.Services
@inject ConceptMapStorageService ConceptMapStorageService
@inject ConceptMapCollectionService ConceptMapCollectionService
@inject CourseService CourseService
@inject OrphanConceptLinkerService OrphanLinkerService
@inject IJSRuntime JS
@implements IDisposable

@if (isLoading)
{
    <div class="kb-graph-container">
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading Concept Maps...</p>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-exclamation-circle"></span>
            </div>
            <h4>Concept Maps Not Found</h4>
            <p>@errorMessage</p>
        </div>
    </div>
}
else if (concepts.Count == 0)
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-diagram-3"></span>
            </div>
            <h4>No Concepts Found</h4>
            <p>The concept maps have no concepts. Try regenerating them with more content.</p>
        </div>
    </div>
}
else
{
<div class="kb-graph-container">
<div class="kb-graph-header">
    <h4>@graphTitle</h4>
    <div class="kb-graph-stats">
        <span class="stat">@concepts.Count concepts</span>
        <span class="stat">@relationships.Count relationships</span>
        @if (conceptMapCount > 1)
        {
            <span class="stat">@conceptMapCount sources</span>
        }
        @if (connectivityInfo != null && !connectivityInfo.IsFullyConnected)
        {
            <span class="stat warning" title="Click to view orphan details">
                <span class="bi bi-exclamation-triangle"></span>
                @connectivityInfo.OrphanedConceptCount orphaned
            </span>
        }
    </div>
</div>

@if (connectivityInfo != null && !connectivityInfo.IsFullyConnected)
{
    <div class="orphan-warning-banner">
        <div class="orphan-info">
            <span class="bi bi-diagram-2"></span>
            <span>
                <strong>@connectivityInfo.OrphanedConceptCount concept(s)</strong> in 
                <strong>@connectivityInfo.OrphanedComponentCount cluster(s)</strong> are disconnected from the main graph.
            </span>
        </div>
        <div class="orphan-actions">
            @if (isLinkingOrphans)
            {
                <span class="linking-status">
                    <span class="spinner-small"></span>
                    Analyzing connections...
                </span>
            }
            else
            {
                <button class="btn-link-orphans" @onclick="LinkOrphansAsync" title="Use AI to find missing connections">
                    <span class="bi bi-link-45deg"></span>
                    Auto-Link Orphans
                </button>
            }
            <button class="btn-show-orphans" @onclick="ToggleOrphanList">
                <span class="bi @(showOrphanList ? "bi-chevron-up" : "bi-chevron-down")"></span>
                @(showOrphanList ? "Hide" : "Show") Details
            </button>
        </div>
    </div>
    
    @if (showOrphanList && connectivityInfo.OrphanedComponents.Count > 0)
    {
        <div class="orphan-details-panel">
            @foreach (var component in connectivityInfo.OrphanedComponents)
            {
                <div class="orphan-component">
                    <div class="component-header">
                        <span class="bi bi-diagram-3"></span>
                        <span>Disconnected cluster (@component.Size concept@(component.Size > 1 ? "s" : ""))</span>
                    </div>
                    <div class="component-concepts">
                        @foreach (var concept in component.Concepts.Take(10))
                        {
                            <button class="orphan-concept-btn" @onclick="@(() => SelectConceptById(concept.Id))">
                                @concept.Title
                            </button>
                        }
                        @if (component.Concepts.Count > 10)
                        {
                            <span class="more-concepts">+@(component.Concepts.Count - 10) more</span>
                        }
                    </div>
                </div>
            }
            @if (!string.IsNullOrEmpty(linkingMessage))
            {
                <div class="linking-message @(linkingSuccess ? "success" : "info")">
                    <span class="bi @(linkingSuccess ? "bi-check-circle" : "bi-info-circle")"></span>
                    @linkingMessage
                </div>
            }
        </div>
    }
}
    
    <div class="kb-graph-content">
        <div class="kb-graph-wrapper">
            <div id="kb-force-graph" class="force-graph-canvas" @ref="graphContainer"></div>
        </div>

        <div class="concept-detail-panel @(selectedConcept == null ? "empty" : "")">
            @if (selectedConcept != null)
            {
                <div class="concept-detail-header">
                    <h5>@selectedConcept.Title</h5>
                    <button class="close-btn small" @onclick="ClearSelection">
                        <span class="bi bi-x-lg"></span>
                    </button>
                </div>
                
                @if (!string.IsNullOrEmpty(selectedConcept.Summary))
                {
                    <div class="concept-summary">@selectedConcept.Summary</div>
                }

                @if (selectedConcept.Aliases.Count > 0)
                {
                    <div class="concept-aliases">
                        <span class="label">Also known as:</span>
                        <span class="value">@string.Join(", ", selectedConcept.Aliases)</span>
                    </div>
                }

                @if (selectedConcept.Tags.Count > 0)
                {
                    <div class="concept-tags">
                        @foreach (var tag in selectedConcept.Tags)
                        {
                            <span class="kb-tag">@tag</span>
                        }
                    </div>
                }

                @if (relatedConcepts.Count > 0)
                {
                    <div class="concept-relationships">
                        <h6>Related Concepts</h6>
                        <div class="relationship-list">
                            @foreach (var rel in relatedConcepts)
                            {
                                <button class="relationship-btn" @onclick="@(() => SelectConceptById(rel.TargetConceptId))">
                                    <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                    <span class="rel-target">@GetConceptTitle(rel.TargetConceptId)</span>
                                    <span class="bi bi-arrow-right"></span>
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (incomingRelationships.Count > 0)
                {
                    <div class="concept-relationships incoming">
                        <h6>Referenced By</h6>
                        <div class="relationship-list">
                            @foreach (var rel in incomingRelationships)
                            {
                                <button class="relationship-btn" @onclick="@(() => SelectConceptById(rel.SourceConceptId))">
                                    <span class="rel-source">@GetConceptTitle(rel.SourceConceptId)</span>
                                    <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                    <span class="bi bi-arrow-left"></span>
                                </button>
                            }
                        </div>
                    </div>
                }

                <div class="concept-actions">
                    <button class="teach-me-btn" @onclick="TeachSelectedConcept">
                        <span class="bi bi-mortarboard"></span>
                        Teach Me
                    </button>
                </div>
            }
            else
            {
                <div class="empty-hint">
                    <span class="bi bi-hand-index"></span>
                    <span>Click on a concept node to view details</span>
                </div>
            }
        </div>
    </div>
</div>
}

@code {
    /// <summary>
    /// Single ConceptMap ID (legacy/single mode)
    /// </summary>
    [Parameter] public string? ConceptMapId { get; set; }

    /// <summary>
    /// Legacy parameter - use ConceptMapId instead
    /// </summary>
    [Parameter] public string? KnowledgeBaseId { get; set; }
    
    /// <summary>
    /// Course ID to load the ConceptMapCollection from
    /// </summary>
    [Parameter] public string? CourseId { get; set; }
    
    /// <summary>
    /// Direct ConceptMapCollection ID to load
    /// </summary>
    [Parameter] public string? ConceptMapCollectionId { get; set; }

    /// <summary>
    /// Legacy parameter - use ConceptMapCollectionId instead
    /// </summary>
    [Parameter] public string? KnowledgeBaseCollectionId { get; set; }
    
    [Parameter] public EventCallback OnClose { get; set; }
    
    /// <summary>
    /// Callback when user clicks "Teach Me" to learn about a concept
    /// </summary>
    [Parameter] public EventCallback<string> OnTeachConcept { get; set; }

    private ConceptMap? conceptMap;
    private LoadedConceptMapCollection? loadedCollection;
    private List<Concept> concepts = [];
    private List<ConceptRelationship> relationships = [];
    private Concept? selectedConcept;
    private List<ConceptRelationship> relatedConcepts = [];
    private List<ConceptRelationship> incomingRelationships = [];
    private ElementReference graphContainer;
    private DotNetObjectReference<ConceptMapCollectionGraph>? dotNetRef;
    private bool isInitialized;
    private bool isLoading = true;
    private string? errorMessage;
    private string graphTitle = "Concept Map Collection";
    private int conceptMapCount = 1;
    
    // Orphan detection state
    private GraphConnectivityInfo? connectivityInfo;
    private bool showOrphanList;
    private bool isLinkingOrphans;
    private string? linkingMessage;
    private bool linkingSuccess;

    protected override async Task OnParametersSetAsync()
    {
        // Resolve legacy parameters
        var effectiveConceptMapId = ConceptMapId ?? KnowledgeBaseId;
        var effectiveCollectionId = ConceptMapCollectionId ?? KnowledgeBaseCollectionId;
        
        // Load when parameter changes - prioritize CourseId, then CollectionId, then single ConceptMapId
        if (!isInitialized)
        {
            if (!string.IsNullOrEmpty(CourseId))
            {
                await LoadFromCourseAsync();
            }
            else if (!string.IsNullOrEmpty(effectiveCollectionId))
            {
                await LoadFromCollectionAsync(effectiveCollectionId);
            }
            else if (!string.IsNullOrEmpty(effectiveConceptMapId))
            {
                await LoadSingleConceptMap(effectiveConceptMapId);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (concepts.Count > 0 && !isInitialized && !isLoading)
        {
            // Small delay to ensure the DOM element is fully rendered
            await Task.Delay(50);
            
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeGraph();
            isInitialized = true;
        }
    }

    /// <summary>
    /// Loads the ConceptMapCollection for a Course and aggregates all concepts/relationships.
    /// </summary>
    private async Task LoadFromCourseAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading from Course: {CourseId}");
            
            var course = await CourseService.GetCourseAsync(CourseId!);
            if (course == null)
            {
                errorMessage = $"Course with ID '{CourseId}' not found.";
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course not found: {CourseId}");
                return;
            }

            graphTitle = $"{course.Name} - Concept Map";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course found: {course.Name}, ResourceIds: {course.ResourceIds.Count}");

            // Get ConceptMap IDs from resources that have them built
            var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(CourseId!);
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] ConceptMap IDs found: {conceptMapIds.Count}");
            
            if (conceptMapIds.Count == 0)
            {
                // Try to get more details about why no ConceptMaps were found
                var resources = await CourseService.GetCourseResourcesAsync(CourseId!);
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course resources: {resources.Count}");
                foreach (var r in resources)
                {
                    System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph]   Resource '{r.Title}': HasConceptMap={r.HasConceptMap}, ConceptMapId={r.ConceptMapId ?? "null"}, Status={r.ConceptMapStatus}");
                }
                
                errorMessage = "No Concept Maps have been built for this course's resources yet.";
                return;
            }

            // Load and aggregate all ConceptMaps
            await LoadAndAggregateConceptMaps(conceptMapIds);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Concept Maps: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads from a ConceptMapCollection directly.
    /// </summary>
    private async Task LoadFromCollectionAsync(string collectionId)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading Collection: {collectionId}");
            
            loadedCollection = await ConceptMapCollectionService.LoadWithConceptMapsAsync(collectionId);
            
            if (loadedCollection == null)
            {
                errorMessage = $"Concept Map Collection '{collectionId}' not found.";
                return;
            }

            graphTitle = loadedCollection.Collection.Name;
            conceptMapCount = loadedCollection.ConceptMaps.Count;
            
            // Aggregate concepts and relationships from the loaded collection
            concepts = loadedCollection.GetAllConcepts().ToList();
            relationships = loadedCollection.GetAllRelations().ToList();
            
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loaded collection with {concepts.Count} concepts, {relationships.Count} relationships from {conceptMapCount} ConceptMaps");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Collection: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads and aggregates multiple ConceptMaps by their IDs.
    /// </summary>
    private async Task LoadAndAggregateConceptMaps(List<string> cmIds)
    {
        var allConcepts = new List<Concept>();
        var allRelationships = new List<ConceptRelationship>();
        var loadedMaps = new List<ConceptMap>();

        foreach (var cmId in cmIds)
        {
            var cm = await ConceptMapStorageService.LoadAsync(cmId);
            if (cm != null && cm.Status == ConceptMapStatus.Ready)
            {
                loadedMaps.Add(cm);
                allConcepts.AddRange(cm.Concepts);
                allRelationships.AddRange(cm.Relations);
            }
        }

        conceptMapCount = loadedMaps.Count;
        concepts = allConcepts;
        relationships = allRelationships;

        System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Aggregated {concepts.Count} concepts, {relationships.Count} relationships from {conceptMapCount} ConceptMaps");
        
        // Calculate connectivity for orphan detection
        CalculateConnectivity();
    }

    /// <summary>
    /// Loads a single ConceptMap (legacy mode).
    /// </summary>
    private async Task LoadSingleConceptMap(string cmId)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading single ConceptMap: {cmId}");
            conceptMap = await ConceptMapStorageService.LoadAsync(cmId);
            
            if (conceptMap != null)
            {
                graphTitle = conceptMap.Name;
                conceptMapCount = 1;
                concepts = conceptMap.Concepts ?? [];
                relationships = conceptMap.Relations ?? [];
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loaded {concepts.Count} concepts, {relationships.Count} relationships");
                
                // Get connectivity info directly from the ConceptMap
                connectivityInfo = conceptMap.GetConnectivityInfo();
            }
            else
            {
                errorMessage = $"Concept Map with ID '{cmId}' not found.";
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] ConceptMap not found: {cmId}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Concept Map: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Calculates graph connectivity to detect orphaned concepts.
    /// Creates a temporary ConceptMap structure for analysis when multiple maps are aggregated.
    /// </summary>
    private void CalculateConnectivity()
    {
        if (concepts.Count == 0)
        {
            connectivityInfo = null;
            return;
        }

        // Create a temporary ConceptMap for connectivity analysis
        var tempMap = new ConceptMap
        {
            Concepts = concepts,
            Relations = relationships
        };
        
        connectivityInfo = tempMap.GetConnectivityInfo();
        
        if (!connectivityInfo.IsFullyConnected)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Detected {connectivityInfo.OrphanedConceptCount} orphaned concepts in {connectivityInfo.OrphanedComponentCount} components");
        }
    }

    /// <summary>
    /// Toggles the orphan details list visibility.
    /// </summary>
    private void ToggleOrphanList()
    {
        showOrphanList = !showOrphanList;
    }

    /// <summary>
    /// Uses AI to find and apply missing connections for orphaned concepts.
    /// </summary>
    private async Task LinkOrphansAsync()
    {
        if (conceptMap == null || isLinkingOrphans)
            return;

        isLinkingOrphans = true;
        linkingMessage = null;
        linkingSuccess = false;
        StateHasChanged();

        try
        {
            var result = await OrphanLinkerService.DetectAndLinkOrphansAsync(conceptMap, minConfidence: 0.5f);
            
            if (result.AppliedLinkCount > 0)
            {
                // Save the updated concept map
                await ConceptMapStorageService.SaveAsync(conceptMap);
                
                // Refresh the display data
                concepts = conceptMap.Concepts ?? [];
                relationships = conceptMap.Relations ?? [];
                connectivityInfo = conceptMap.GetConnectivityInfo();
                
                linkingSuccess = true;
                linkingMessage = $"Added {result.AppliedLinkCount} connection(s). " +
                    (result.IsFullyConnected 
                        ? "All concepts are now connected!" 
                        : $"{result.RemainingOrphanCount} concept(s) still need manual review.");
                
                // Reinitialize the graph to show new connections
                isInitialized = false;
                StateHasChanged();
                await Task.Delay(100);
                await InitializeGraph();
                isInitialized = true;
            }
            else
            {
                linkingMessage = "No suitable connections could be found. Manual review may be needed.";
            }
        }
        catch (Exception ex)
        {
            linkingMessage = $"Error: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Orphan linking error: {ex.Message}");
        }
        finally
        {
            isLinkingOrphans = false;
            StateHasChanged();
        }
    }

    private async Task InitializeGraph()
    {
        if (concepts.Count == 0) return;

        // Prepare data for D3.js force layout
        var nodes = concepts.Select(c => new
        {
            id = c.Id,
            title = c.Title,
            group = c.Tags.FirstOrDefault() ?? "default"
        }).ToArray();

        var links = relationships.Select(r => new
        {
            source = r.SourceConceptId,
            target = r.TargetConceptId,
            type = r.RelationType.ToString()
        }).ToArray();

        try
        {
            await JS.InvokeVoidAsync("initForceGraph", graphContainer, nodes, links, dotNetRef);
        }
        catch (JSException ex)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] JS Error initializing graph: {ex.Message}");
            // Reset flag to allow retry on next render
            isInitialized = false;
        }
    }

    [JSInvokable]
    public void OnNodeClick(string conceptId)
    {
        SelectConceptById(conceptId, smoothPan: false);
        StateHasChanged();
    }

    private async void SelectConceptById(string conceptId, bool smoothPan = true)
    {
        selectedConcept = concepts.FirstOrDefault(c => c.Id == conceptId);
        if (selectedConcept != null)
        {
            relatedConcepts = relationships.Where(r => r.SourceConceptId == conceptId).ToList();
            incomingRelationships = relationships.Where(r => r.TargetConceptId == conceptId).ToList();
            
            if (smoothPan)
            {
                await JS.InvokeVoidAsync("panToNode", conceptId);
            }
            else
            {
                await JS.InvokeVoidAsync("highlightNode", conceptId);
            }
        }
        else
        {
            relatedConcepts = [];
            incomingRelationships = [];
        }
        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedConcept = null;
        relatedConcepts = [];
        incomingRelationships = [];
    }

    /// <summary>
    /// Triggers the OnTeachConcept callback to teach about the selected concept
    /// </summary>
    private async Task TeachSelectedConcept()
    {
        if (selectedConcept == null) return;
        
        // Close the explorer and trigger the teach callback
        await OnTeachConcept.InvokeAsync(selectedConcept.Title);
    }

    private string GetConceptTitle(string conceptId)
    {
        return concepts.FirstOrDefault(c => c.Id == conceptId)?.Title ?? "Unknown";
    }

    private string FormatRelationType(ConceptRelationType type)
    {
        return type switch
        {
            ConceptRelationType.Prerequisite => "requires",
            ConceptRelationType.Related => "related to",
            ConceptRelationType.Contains => "contains",
            ConceptRelationType.InstanceOf => "instance of",
            ConceptRelationType.SimilarTo => "similar to",
            ConceptRelationType.ContrastsWith => "contrasts",
            _ => type.ToString().ToLower()
        };
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }
}
