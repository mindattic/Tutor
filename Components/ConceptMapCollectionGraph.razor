@using Microsoft.JSInterop
@using Tutor.Models
@using Tutor.Services
@inject ConceptMapStorageService ConceptMapStorageService
@inject ConceptMapCollectionService ConceptMapCollectionService
@inject CourseConceptMapService CourseConceptMapService
@inject CourseService CourseService
@inject OrphanConceptLinkerService OrphanLinkerService
@inject IJSRuntime JS
@implements IDisposable

@if (isLoading)
{
    <div class="kb-graph-container">
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading Concept Maps...</p>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-exclamation-circle"></span>
            </div>
            <h4>Concept Maps Not Found</h4>
            <p>@errorMessage</p>
        </div>
    </div>
}
else if (concepts.Count == 0)
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-diagram-3"></span>
            </div>
            <h4>No Concepts Found</h4>
            <p>The concept maps have no concepts. Try regenerating them with more content.</p>
        </div>
    </div>
}
else
{
<div class="kb-graph-container">
<div class="kb-graph-header">
    <h4>@graphTitle</h4>
    <div class="kb-graph-stats">
        <span class="stat">@(isFiltered ? $"{filteredNodeCount}/" : "")@concepts.Count concepts</span>
        <span class="stat">@relationships.Count relationships</span>
        @if (conceptMapCount > 1)
        {
            <span class="stat">@conceptMapCount sources</span>
        }
        @if (connectivityInfo != null && !connectivityInfo.IsFullyConnected)
        {
            <span class="stat warning" title="Click to view orphan details">
                <span class="bi bi-exclamation-triangle"></span>
                @connectivityInfo.OrphanedConceptCount orphaned
            </span>
        }
    </div>
</div>

@* Search and Depth Filter *@
<div class="graph-filter-bar">
    <div class="search-group">
        <span class="bi bi-search"></span>
        <input type="text" 
               class="search-input" 
               placeholder="Search concepts (e.g., Horcrux)..." 
               @bind="searchQuery"
               @bind:event="oninput"
               @onkeydown="HandleSearchKeyDown" />
        @if (!string.IsNullOrEmpty(searchQuery))
        {
            <button class="clear-search-btn" @onclick="ClearSearch" title="Clear search">
                <span class="bi bi-x-lg"></span>
            </button>
        }
    </div>
    <div class="depth-group">
        <label>Depth:</label>
        <select class="depth-select" @bind="filterDepth">
            <option value="1">1 level</option>
            <option value="2">2 levels</option>
            <option value="3">3 levels</option>
            <option value="4">4 levels</option>
            <option value="5">5 levels</option>
            <option value="0">All connected</option>
        </select>
    </div>
    <button class="btn-filter @(isSearching ? "searching" : "")" @onclick="ApplyFilter" disabled="@isSearching">
        @if (isSearching)
        {
            <span class="spinner-small"></span>
        }
        else
        {
            <span class="bi bi-funnel"></span>
        }
        Go
    </button>
    @if (isFiltered)
    {
        <button class="btn-reset-filter" @onclick="ResetFilter" title="Show all nodes">
            <span class="bi bi-arrow-counterclockwise"></span>
            Reset
        </button>
    }
</div>

@if (isFiltered && !string.IsNullOrEmpty(filterResultMessage))
{
    <div class="filter-result-message @(filteredNodeCount == 0 ? "no-results" : "")">
        <span class="bi @(filteredNodeCount == 0 ? "bi-info-circle" : "bi-check-circle")"></span>
        @filterResultMessage
    </div>
}

@if (connectivityInfo != null && !connectivityInfo.IsFullyConnected)
{
    <div class="orphan-warning-banner">
        <div class="orphan-info">
            <span class="bi bi-diagram-2"></span>
            <span>
                <strong>@connectivityInfo.OrphanedConceptCount concept(s)</strong> in 
                <strong>@connectivityInfo.OrphanedComponentCount cluster(s)</strong> are disconnected from the main graph.
            </span>
        </div>
        <div class="orphan-actions">
            @if (isLinkingOrphans)
            {
                <span class="linking-status">
                    <span class="spinner-small"></span>
                    Analyzing connections...
                </span>
            }
            else
            {
                <button class="btn-link-orphans" @onclick="LinkOrphansAsync" title="Use AI to find missing connections">
                    <span class="bi bi-link-45deg"></span>
                    Auto-Link Orphans
                </button>
            }
            <button class="btn-show-orphans" @onclick="ToggleOrphanList">
                <span class="bi @(showOrphanList ? "bi-chevron-up" : "bi-chevron-down")"></span>
                @(showOrphanList ? "Hide" : "Show") Details
            </button>
        </div>
    </div>
    
    @if (showOrphanList && connectivityInfo.OrphanedComponents.Count > 0)
    {
        <div class="orphan-details-panel">
            @foreach (var component in connectivityInfo.OrphanedComponents)
            {
                <div class="orphan-component">
                    <div class="component-header">
                        <span class="bi bi-diagram-3"></span>
                        <span>Disconnected cluster (@component.Size concept@(component.Size > 1 ? "s" : ""))</span>
                    </div>
                    <div class="component-concepts">
                        @foreach (var concept in component.Concepts.Take(10))
                        {
                            <button class="orphan-concept-btn" @onclick="@(async () => await SelectConceptByIdAsync(concept.Id))">
                                @concept.Title
                            </button>
                        }
                        @if (component.Concepts.Count > 10)
                        {
                            <span class="more-concepts">+@(component.Concepts.Count - 10) more</span>
                        }
                    </div>
                </div>
            }
            @if (!string.IsNullOrEmpty(linkingMessage))
            {
                <div class="linking-message @(linkingSuccess ? "success" : "info")">
                    <span class="bi @(linkingSuccess ? "bi-check-circle" : "bi-info-circle")"></span>
                    @linkingMessage
                </div>
            }
        </div>
    }
}
    
    <div class="kb-graph-content">
        <div class="kb-graph-wrapper">
            <div id="kb-force-graph" class="force-graph-canvas" @ref="graphContainer"></div>
            
            @* Context Menu (right-click) *@
            <div id="graph-context-menu" class="graph-context-menu" style="display: none;">
                <div class="context-menu-header">
                    <span class="context-menu-title">Node Options</span>
                </div>
                <div class="context-menu-items">
                    <button class="context-menu-item primary" data-action="expand">
                        <span class="bi bi-share"></span>
                        <span>Show Neighbors</span>
                    </button>
                    <button class="context-menu-item" data-action="focus">
                        <span class="bi bi-bullseye"></span>
                        <span>Center View</span>
                    </button>
                    <button class="context-menu-item" data-action="isolate">
                        <span class="bi bi-diagram-3"></span>
                        <span>Isolate Subgraph</span>
                    </button>
                    <div class="context-menu-divider"></div>
                    <button class="context-menu-item" data-action="pin">
                        <span class="bi bi-pin-angle"></span>
                        <span>Pin/Unpin Position</span>
                        <span class="shortcut">P</span>
                    </button>
                    <button class="context-menu-item" data-action="hide">
                        <span class="bi bi-eye-slash"></span>
                        <span>Hide Node</span>
                    </button>
                    <div class="context-menu-divider"></div>
                    <button class="context-menu-item" data-action="copy">
                        <span class="bi bi-clipboard"></span>
                        <span>Copy Name</span>
                    </button>
                </div>
            </div>
        </div>

        <div class="concept-detail-panel @(selectedConcept == null ? "empty" : "") @panelDockPosition"
             style="@GetPanelStyle()"
             @ref="detailPanelRef">
            @* Dock buttons *@
            @if (selectedConcept != null)
            {
                <div class="panel-dock-buttons">
                    <button class="dock-btn @(panelDockPosition == "dock-top-right" ? "active" : "")" 
                            @onclick="@(() => DockPanel("dock-top-right"))" title="Dock top-right">
                        <span class="bi bi-arrow-up-right"></span>
                    </button>
                    <button class="dock-btn @(panelDockPosition == "dock-bottom-right" ? "active" : "")" 
                            @onclick="@(() => DockPanel("dock-bottom-right"))" title="Dock bottom-right">
                        <span class="bi bi-arrow-down-right"></span>
                    </button>
                    <button class="dock-btn @(panelDockPosition == "dock-bottom-left" ? "active" : "")" 
                            @onclick="@(() => DockPanel("dock-bottom-left"))" title="Dock bottom-left">
                        <span class="bi bi-arrow-down-left"></span>
                    </button>
                    <button class="dock-btn @(panelDockPosition == "dock-top-left" ? "active" : "")" 
                            @onclick="@(() => DockPanel("dock-top-left"))" title="Dock top-left">
                        <span class="bi bi-arrow-up-left"></span>
                    </button>
                    <button class="dock-btn @(panelDockPosition == "" ? "active" : "")" 
                            @onclick="@(() => DockPanel(""))" title="Float (draggable)">
                        <span class="bi bi-arrows-move"></span>
                    </button>
                </div>
            }
            
            @* Drag handle (only visible when floating) *@
            @if (selectedConcept != null && string.IsNullOrEmpty(panelDockPosition))
            {
                <div class="panel-drag-handle" @onmousedown="StartPanelDrag">
                    <span class="bi bi-grip-horizontal"></span>
                </div>
            }
            
            @if (selectedConcept != null)
            {
                <div class="concept-detail-header">
                    <h5>@selectedConcept.Title</h5>
                    <button class="close-btn small" @onclick="ClearSelection">
                        <span class="bi bi-x-lg"></span>
                    </button>
                </div>
                
                <div class="concept-detail-body">
                    @if (!string.IsNullOrEmpty(selectedConcept.Summary))
                    {
                        <div class="concept-summary">@selectedConcept.Summary</div>
                    }

                    @if (selectedConcept.Aliases.Count > 0)
                    {
                        <div class="concept-aliases">
                            <span class="label">Also known as:</span>
                            <span class="value">@string.Join(", ", selectedConcept.Aliases)</span>
                        </div>
                    }

                    @if (selectedConcept.Tags.Count > 0)
                    {
                        <div class="concept-tags">
                            @foreach (var tag in selectedConcept.Tags)
                            {
                                <span class="kb-tag">@tag</span>
                            }
                        </div>
                    }

                    @if (relatedConcepts.Count > 0)
                    {
                        <div class="concept-relationships">
                            <h6>Related Concepts</h6>
                            <div class="relationship-list">
                                @foreach (var rel in relatedConcepts)
                                {
                                    <button class="relationship-btn" @onclick="@(async () => await SelectConceptByIdAsync(rel.TargetConceptId))">
                                        <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                        <span class="rel-target">@GetConceptTitle(rel.TargetConceptId)</span>
                                        <span class="bi bi-arrow-right"></span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (incomingRelationships.Count > 0)
                    {
                        <div class="concept-relationships incoming">
                            <h6>Referenced By</h6>
                            <div class="relationship-list">
                                @foreach (var rel in incomingRelationships)
                                {
                                    <button class="relationship-btn" @onclick="@(async () => await SelectConceptByIdAsync(rel.SourceConceptId))">
                                        <span class="rel-source">@GetConceptTitle(rel.SourceConceptId)</span>
                                        <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                        <span class="bi bi-arrow-left"></span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <div class="concept-actions">
                        @if (EmbeddedMode)
                        {
                            <button class="action-btn chat" @onclick="AskAboutSelectedConcept">
                                <span class="bi bi-chat-dots"></span>
                                Ask
                            </button>
                            <button class="action-btn details" @onclick="ViewSelectedConceptDetails">
                                <span class="bi bi-journal-text"></span>
                                Details
                            </button>
                        }
                        else
                        {
                            <button class="teach-me-btn" @onclick="TeachSelectedConcept">
                                <span class="bi bi-mortarboard"></span>
                                Teach Me
                            </button>
                        }
                    </div>
                </div>
                
                @* Resize handle *@
                <div class="panel-resize-handle" @onmousedown="StartPanelResize">
                    <span class="bi bi-arrows-angle-expand"></span>
                </div>
            }
            else
            {
                <div class="empty-hint">
                    <span class="bi bi-hand-index"></span>
                    <span>Click on a concept node to view details</span>
                </div>
            }
        </div>
    </div>
</div>
}

@code {
/// <summary>
/// Single ConceptMap ID (legacy/single mode)
/// </summary>
[Parameter] public string? ConceptMapId { get; set; }

/// <summary>
/// Legacy parameter - use ConceptMapId instead
/// </summary>
[Parameter] public string? KnowledgeBaseId { get; set; }
    
/// <summary>
/// Course ID to load the ConceptMapCollection from
/// </summary>
[Parameter] public string? CourseId { get; set; }
    
/// <summary>
/// Direct ConceptMapCollection ID to load
/// </summary>
[Parameter] public string? ConceptMapCollectionId { get; set; }

/// <summary>
/// Legacy parameter - use ConceptMapCollectionId instead
/// </summary>
[Parameter] public string? KnowledgeBaseCollectionId { get; set; }
    
/// <summary>
/// When true, the component is embedded in a tab and shows navigation buttons
/// </summary>
[Parameter] public bool EmbeddedMode { get; set; }
    
/// <summary>
/// Concept ID to select and center on when the component loads
/// </summary>
[Parameter] public string? SelectedConceptId { get; set; }
    
[Parameter] public EventCallback OnClose { get; set; }
    
/// <summary>
/// Callback when user clicks "Teach Me" to learn about a concept
/// </summary>
[Parameter] public EventCallback<string> OnTeachConcept { get; set; }
    
/// <summary>
/// Callback when user wants to ask about a concept (embedded mode)
/// </summary>
[Parameter] public EventCallback<string> OnAskAboutConcept { get; set; }
    
/// <summary>
/// Callback when user wants to view concept details (embedded mode)
/// </summary>
[Parameter] public EventCallback<string> OnViewConceptDetails { get; set; }

private ConceptMap? conceptMap;
private LoadedConceptMapCollection? loadedCollection;
private List<Concept> concepts = [];
private List<ConceptRelationship> relationships = [];
private Concept? selectedConcept;
private List<ConceptRelationship> relatedConcepts = [];
private List<ConceptRelationship> incomingRelationships = [];
private ElementReference graphContainer;
private ElementReference detailPanelRef;
private DotNetObjectReference<ConceptMapCollectionGraph>? dotNetRef;
private bool isInitialized;
private bool isLoading = true;
private string? errorMessage;
private string graphTitle = "Concept Map Collection";
private int conceptMapCount = 1;

// Detail panel state (draggable/resizable/dockable)
private string panelDockPosition = "dock-top-right"; // Default docked position
private double panelX = 16;
private double panelY = 16;
private double panelWidth = 320;
private double panelHeight = 400;
private bool isDragging;
private bool isResizing;
private double dragStartX;
private double dragStartY;
private double dragOffsetX;
private double dragOffsetY;
    
// Orphan detection state
private GraphConnectivityInfo? connectivityInfo;
private bool showOrphanList;
    private bool isLinkingOrphans;
    private string? linkingMessage;
    private bool linkingSuccess;
    
    // Search and filter state
    private string searchQuery = "";
    private int filterDepth = 2;
    private bool isFiltered;
    private bool isSearching;
    private int filteredNodeCount;
    private string? filterResultMessage;
    private HashSet<string> visibleNodeIds = [];

    protected override async Task OnParametersSetAsync()
    {
        // Resolve legacy parameters
        var effectiveConceptMapId = ConceptMapId ?? KnowledgeBaseId;
        var effectiveCollectionId = ConceptMapCollectionId ?? KnowledgeBaseCollectionId;
        
        // Load when parameter changes - prioritize CourseId, then CollectionId, then single ConceptMapId
        if (!isInitialized)
        {
            if (!string.IsNullOrEmpty(CourseId))
            {
                await LoadFromCourseAsync();
            }
            else if (!string.IsNullOrEmpty(effectiveCollectionId))
            {
                await LoadFromCollectionAsync(effectiveCollectionId);
            }
            else if (!string.IsNullOrEmpty(effectiveConceptMapId))
            {
                await LoadSingleConceptMap(effectiveConceptMapId);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (concepts.Count > 0 && !isInitialized && !isLoading)
        {
            // Small delay to ensure the DOM element is fully rendered
            await Task.Delay(50);
            
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeGraph();
            isInitialized = true;
            
            // Setup panel drag handler
            await JS.InvokeVoidAsync("setupPanelDragHandler", dotNetRef);
            
            // If a concept was selected externally, pan to it
            if (!string.IsNullOrEmpty(SelectedConceptId))
            {
                await SelectConceptByIdAsync(SelectedConceptId, smoothPan: true);
            }
        }
        // Handle external concept selection after initialization
        else if (isInitialized && !string.IsNullOrEmpty(SelectedConceptId) && selectedConcept?.Id != SelectedConceptId)
        {
            await SelectConceptByIdAsync(SelectedConceptId, smoothPan: true);
        }
    }

    /// <summary>
    /// Loads the ConceptMapCollection for a Course and aggregates all concepts/relationships.
    /// </summary>
    private async Task LoadFromCourseAsync()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading from Course: {CourseId}");
            
            var course = await CourseService.GetCourseAsync(CourseId!);
            if (course == null)
            {
                errorMessage = $"Course with ID '{CourseId}' not found.";
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course not found: {CourseId}");
                return;
            }

            graphTitle = $"{course.Name} - Concept Map";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course found: {course.Name}, ResourceIds: {course.ResourceIds.Count}");

            // Try to load the MERGED map first (this has deduplicated concepts)
            var mergedMap = await CourseConceptMapService.GetOrCreateMergedMapAsync(CourseId!);
            
            if (mergedMap != null && mergedMap.Status == MergedMapStatus.Ready && mergedMap.Concepts.Count > 0)
            {
                // Use the merged/deduplicated map
                concepts = mergedMap.Concepts;
                relationships = mergedMap.Relations;
                conceptMapCount = mergedMap.SourceConceptMapIds.Count;
                
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Using merged map with {concepts.Count} concepts (deduplicated), {relationships.Count} relationships from {conceptMapCount} sources");
                
                // Calculate connectivity
                CalculateConnectivity();
                return;
            }

            // Fallback: load original ConceptMaps if merged map not available
            var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(CourseId!);
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] ConceptMap IDs found: {conceptMapIds.Count}");
            
            if (conceptMapIds.Count == 0)
            {
                // Try to get more details about why no ConceptMaps were found
                var resources = await CourseService.GetCourseResourcesAsync(CourseId!);
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Course resources: {resources.Count}");
                foreach (var r in resources)
                {
                    System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph]   Resource '{r.Title}': HasConceptMap={r.HasConceptMap}, ConceptMapId={r.ConceptMapId ?? "null"}, Status={r.ConceptMapStatus}");
                }
                
                errorMessage = "No Concept Maps have been built for this course's resources yet.";
                return;
            }

            // Load and aggregate all ConceptMaps
            await LoadAndAggregateConceptMaps(conceptMapIds);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Concept Maps: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads from a ConceptMapCollection directly.
    /// </summary>
    private async Task LoadFromCollectionAsync(string collectionId)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading Collection: {collectionId}");
            
            loadedCollection = await ConceptMapCollectionService.LoadWithConceptMapsAsync(collectionId);
            
            if (loadedCollection == null)
            {
                errorMessage = $"Concept Map Collection '{collectionId}' not found.";
                return;
            }

            graphTitle = loadedCollection.Collection.Name;
            conceptMapCount = loadedCollection.ConceptMaps.Count;
            
            // Aggregate concepts and relationships from the loaded collection
            concepts = loadedCollection.GetAllConcepts().ToList();
            relationships = loadedCollection.GetAllRelations().ToList();
            
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loaded collection with {concepts.Count} concepts, {relationships.Count} relationships from {conceptMapCount} ConceptMaps");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Collection: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads and aggregates multiple ConceptMaps by their IDs.
    /// </summary>
    private async Task LoadAndAggregateConceptMaps(List<string> cmIds)
    {
        var allConcepts = new List<Concept>();
        var allRelationships = new List<ConceptRelationship>();
        var loadedMaps = new List<ConceptMap>();

        foreach (var cmId in cmIds)
        {
            var cm = await ConceptMapStorageService.LoadAsync(cmId);
            if (cm != null && cm.Status == ConceptMapStatus.Ready)
            {
                loadedMaps.Add(cm);
                allConcepts.AddRange(cm.Concepts);
                allRelationships.AddRange(cm.Relations);
            }
        }

        conceptMapCount = loadedMaps.Count;
        concepts = allConcepts;
        relationships = allRelationships;

        System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Aggregated {concepts.Count} concepts, {relationships.Count} relationships from {conceptMapCount} ConceptMaps");
        
        // Calculate connectivity for orphan detection
        CalculateConnectivity();
    }

    /// <summary>
    /// Loads a single ConceptMap (legacy mode).
    /// </summary>
    private async Task LoadSingleConceptMap(string cmId)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loading single ConceptMap: {cmId}");
            conceptMap = await ConceptMapStorageService.LoadAsync(cmId);
            
            if (conceptMap != null)
            {
                graphTitle = conceptMap.Name;
                conceptMapCount = 1;
                concepts = conceptMap.Concepts ?? [];
                relationships = conceptMap.Relations ?? [];
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Loaded {concepts.Count} concepts, {relationships.Count} relationships");
                
                // Get connectivity info directly from the ConceptMap
                connectivityInfo = conceptMap.GetConnectivityInfo();
            }
            else
            {
                errorMessage = $"Concept Map with ID '{cmId}' not found.";
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] ConceptMap not found: {cmId}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Concept Map: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Calculates graph connectivity to detect orphaned concepts.
    /// Creates a temporary ConceptMap structure for analysis when multiple maps are aggregated.
    /// </summary>
    private void CalculateConnectivity()
    {
        if (concepts.Count == 0)
        {
            connectivityInfo = null;
            return;
        }

        // Create a temporary ConceptMap for connectivity analysis
        var tempMap = new ConceptMap
        {
            Concepts = concepts,
            Relations = relationships
        };
        
        connectivityInfo = tempMap.GetConnectivityInfo();
        
        if (!connectivityInfo.IsFullyConnected)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Detected {connectivityInfo.OrphanedConceptCount} orphaned concepts in {connectivityInfo.OrphanedComponentCount} components");
        }
    }

    /// <summary>
    /// Toggles the orphan details list visibility.
    /// </summary>
    private void ToggleOrphanList()
    {
        showOrphanList = !showOrphanList;
    }

    /// <summary>
    /// Uses AI to find and apply missing connections for orphaned concepts.
    /// Uses iterative linking to achieve full connectivity.
    /// </summary>
    private async Task LinkOrphansAsync()
    {
        if (isLinkingOrphans)
            return;

        isLinkingOrphans = true;
        linkingMessage = "Starting iterative linking...";
        linkingSuccess = false;
        StateHasChanged();

        try
        {
            var totalApplied = 0;

            // If we have a loadedCollection with multiple ConceptMaps, link each one
            if (loadedCollection != null && loadedCollection.ConceptMaps.Count > 0)
            {
                foreach (var cm in loadedCollection.ConceptMaps)
                {
                    linkingMessage = $"Linking concepts in '{cm.Name}'...";
                    StateHasChanged();

                    var result = await OrphanLinkerService.LinkAllOrphansIterativelyAsync(
                        cm, 
                        maxIterations: 10, 
                        minConfidence: 0.3f);

                    if (result.AppliedLinkCount > 0)
                    {
                        await ConceptMapStorageService.SaveAsync(cm);
                        totalApplied += result.AppliedLinkCount;
                    }
                }

                // Refresh the aggregated view
                concepts = loadedCollection.GetAllConcepts().ToList();
                relationships = loadedCollection.GetAllRelations().ToList();
            }
            // If we have a single conceptMap
            else if (conceptMap != null)
            {
                linkingMessage = "Running iterative linking...";
                StateHasChanged();

                var result = await OrphanLinkerService.LinkAllOrphansIterativelyAsync(
                    conceptMap, 
                    maxIterations: 10, 
                    minConfidence: 0.3f);

                if (result.AppliedLinkCount > 0)
                {
                    await ConceptMapStorageService.SaveAsync(conceptMap);
                    totalApplied = result.AppliedLinkCount;
                }

                concepts = conceptMap.Concepts ?? [];
                relationships = conceptMap.Relations ?? [];
            }
            else
            {
                linkingMessage = "No Concept Map loaded to link.";
                return;
            }

            // Recalculate connectivity
            CalculateConnectivity();

            if (totalApplied > 0)
            {
                linkingSuccess = true;
                linkingMessage = $"Added {totalApplied} connection(s). " +
                    (connectivityInfo?.IsFullyConnected == true
                        ? "🎉 All concepts are now connected!"
                        : $"{connectivityInfo?.OrphanedConceptCount ?? 0} concept(s) still need manual review.");

                // Reinitialize the graph to show new connections
                isInitialized = false;
                StateHasChanged();
                await Task.Delay(100);
                await InitializeGraph();
                isInitialized = true;
            }
            else
            {
                linkingMessage = "No suitable connections could be found. Manual review may be needed.";
            }
        }
        catch (Exception ex)
        {
            linkingMessage = $"Error: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Orphan linking error: {ex.Message}");
        }
        finally
        {
            isLinkingOrphans = false;
            StateHasChanged();
        }
    }

    private async Task InitializeGraph()
    {
        if (concepts.Count == 0) return;

        // Prepare data for D3.js force layout
        var nodes = concepts.Select(c => new
        {
            id = c.Id,
            title = c.Title,
            group = c.Tags.FirstOrDefault() ?? "default"
        }).ToArray();

        var links = relationships.Select(r => new
        {
            source = r.SourceConceptId,
            target = r.TargetConceptId,
            type = r.RelationType.ToString()
        }).ToArray();

        try
        {
            await JS.InvokeVoidAsync("initForceGraph", graphContainer, nodes, links, dotNetRef);
        }
        catch (JSException ex)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] JS Error initializing graph: {ex.Message}");
            // Reset flag to allow retry on next render
            isInitialized = false;
        }
    }

    [JSInvokable]
    public void OnNodeClick(string conceptId)
    {
        selectedConcept = concepts.FirstOrDefault(c => c.Id == conceptId);
        if (selectedConcept != null)
        {
            relatedConcepts = relationships.Where(r => r.SourceConceptId == conceptId).ToList();
            incomingRelationships = relationships.Where(r => r.TargetConceptId == conceptId).ToList();
            
            // Highlight the node (fire-and-forget, don't await)
            _ = JS.InvokeVoidAsync("highlightNode", conceptId);
        }
        else
        {
            relatedConcepts = [];
            incomingRelationships = [];
        }
        StateHasChanged();
    }

    /// <summary>
    /// Handles context menu actions from JavaScript.
    /// Placeholder for future implementation of context menu features.
    /// </summary>
    [JSInvokable]
    public async Task OnContextMenuAction(string action, string conceptId)
    {
        System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Context menu action: {action} on concept: {conceptId}");
        
        switch (action)
        {
            case "expand":
                // Expand to show this node's connections
                await SelectConceptByIdAsync(conceptId);
                break;
                
            case "hide":
                // TODO: Implement hide node functionality
                // This would remove the node from visibleNodeIds and update the filter
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Hide node - not yet implemented");
                break;
                
            case "isolate":
                // TODO: Implement isolate subgraph functionality  
                // This would show only this node and its connected nodes
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Isolate subgraph - not yet implemented");
                break;
                
            default:
                System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Unknown context menu action: {action}");
                break;
        }
    }

    private async Task SelectConceptByIdAsync(string conceptId, bool smoothPan = true)
    {
        selectedConcept = concepts.FirstOrDefault(c => c.Id == conceptId);
        if (selectedConcept == null)
        {
            relatedConcepts = [];
            incomingRelationships = [];
            StateHasChanged();
            return;
        }
        
        relatedConcepts = relationships.Where(r => r.SourceConceptId == conceptId).ToList();
        incomingRelationships = relationships.Where(r => r.TargetConceptId == conceptId).ToList();
        
        // Check if this node is currently visible (either not filtered, or in the visible set)
        var nodeIsVisible = !isFiltered || visibleNodeIds.Contains(conceptId);
        
        if (!nodeIsVisible)
        {
            // Node is hidden - EXPAND the visible set to include this node and its connections
            // This allows following chains of relationships without losing previous context
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Expanding to include hidden node: {selectedConcept.Title}");
            
            // Collect this node plus its connections at the current depth
            var newNodes = CollectNodesWithinDepth([selectedConcept], filterDepth);
            
            // UNION with existing visible nodes (expand, don't replace)
            var previousCount = visibleNodeIds.Count;
            visibleNodeIds.UnionWith(newNodes);
            var addedCount = visibleNodeIds.Count - previousCount;
            filteredNodeCount = visibleNodeIds.Count;
            
            // Update the filter message to show expansion
            var depthLabel = filterDepth == 0 ? "all connected" : $"{filterDepth} level(s)";
            if (addedCount > 0)
            {
                filterResultMessage = $"Expanded to include \"{selectedConcept.Title}\" (+{addedCount} concepts) - showing {filteredNodeCount} total ({depthLabel})";
            }
            else
            {
                filterResultMessage = $"Showing {filteredNodeCount} concepts ({depthLabel})";
            }
            
            // Apply the expanded filter to D3.js, pan to the new concept
            await JS.InvokeVoidAsync("filterGraphByNodes", visibleNodeIds.ToArray(), conceptId);
        }
        else if (smoothPan)
        {
            // Node is already visible - just pan to it
            await JS.InvokeVoidAsync("panToNode", conceptId);
        }
        else
        {
            await JS.InvokeVoidAsync("highlightNode", conceptId);
        }
        
        StateHasChanged();
    }

    private void ClearSelection()
    {
        selectedConcept = null;
        relatedConcepts = [];
        incomingRelationships = [];
    }

    // Panel dragging/resizing/docking methods
    private string GetPanelStyle()
    {
        if (!string.IsNullOrEmpty(panelDockPosition))
        {
            // When docked, use CSS positioning only
            return $"width: {panelWidth}px; height: {panelHeight}px;";
        }
        // When floating, use absolute positioning
        return $"left: {panelX}px; top: {panelY}px; width: {panelWidth}px; height: {panelHeight}px;";
    }

    private void DockPanel(string position)
    {
        panelDockPosition = position;
        StateHasChanged();
    }

    private void StartPanelDrag(MouseEventArgs e)
    {
        if (!string.IsNullOrEmpty(panelDockPosition)) return;
        
        isDragging = true;
        dragStartX = e.ClientX;
        dragStartY = e.ClientY;
        dragOffsetX = panelX;
        dragOffsetY = panelY;
    }

    private void StartPanelResize(MouseEventArgs e)
    {
        isResizing = true;
        dragStartX = e.ClientX;
        dragStartY = e.ClientY;
    }

    [JSInvokable]
    public void OnPanelMouseMove(double clientX, double clientY)
    {
        if (isDragging)
        {
            panelX = dragOffsetX + (clientX - dragStartX);
            panelY = dragOffsetY + (clientY - dragStartY);
            
            // Clamp to viewport
            panelX = Math.Max(0, panelX);
            panelY = Math.Max(0, panelY);
            
            StateHasChanged();
        }
        else if (isResizing)
        {
            var deltaX = clientX - dragStartX;
            var deltaY = clientY - dragStartY;
            
            panelWidth = Math.Max(250, panelWidth + deltaX);
            panelHeight = Math.Max(200, panelHeight + deltaY);
            
            dragStartX = clientX;
            dragStartY = clientY;
            
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnPanelMouseUp()
    {
        isDragging = false;
        isResizing = false;
    }

