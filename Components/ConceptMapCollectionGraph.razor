    private string FormatRelationType(ConceptRelationType type)
    {
        return type switch
        {
            ConceptRelationType.Prerequisite => "requires",
            ConceptRelationType.Related => "related to",
            ConceptRelationType.Contains => "contains",
            ConceptRelationType.InstanceOf => "instance of",
            ConceptRelationType.SimilarTo => "similar to",
            ConceptRelationType.ContrastsWith => "contrasts",
            _ => type.ToString().ToLower()
        };
    }

    #region Search and Filter Methods

    /// <summary>
    /// Handles Enter key in search box to apply filter.
    /// </summary>
    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplyFilter();
        }
    }

    /// <summary>
    /// Applies the search filter to the graph.
    /// Finds matching nodes and shows them plus their connected nodes up to the specified depth.
    /// </summary>
    private async Task ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchQuery))
        {
            await ResetFilter();
            return;
        }

        isSearching = true;
        StateHasChanged();

        try
        {
            // Find all concepts matching the search query (by title or alias)
            var query = searchQuery.Trim().ToLowerInvariant();
            
            // Score matches: exact title match > starts with > contains in title > alias match
            var scoredMatches = concepts
                .Select(c => new
                {
                    Concept = c,
                    Score = GetMatchScore(c, query)
                })
                .Where(x => x.Score > 0)
                .OrderByDescending(x => x.Score)
                .ToList();

            var matchingConcepts = scoredMatches.Select(x => x.Concept).ToList();

            if (matchingConcepts.Count == 0)
            {
                isFiltered = true;
                filteredNodeCount = 0;
                filterResultMessage = $"No concepts found matching \"{searchQuery}\"";
                visibleNodeIds = [];
                
                // Hide all nodes
                await JS.InvokeVoidAsync("filterGraphByNodes", Array.Empty<string>(), null);
                StateHasChanged();
                return;
            }

            // The best match becomes the center "axle" node
            var primaryMatch = matchingConcepts.First();
            
            // Collect all nodes within the specified depth using BFS
            visibleNodeIds = CollectNodesWithinDepth(matchingConcepts, filterDepth);
            filteredNodeCount = visibleNodeIds.Count;
            isFiltered = true;

            var matchCount = matchingConcepts.Count;
            var depthLabel = filterDepth == 0 ? "all connected" : $"{filterDepth} level(s)";
            filterResultMessage = $"Found {matchCount} match(es) for \"{searchQuery}\" - showing {filteredNodeCount} concepts ({depthLabel})";

            // Apply filter to D3.js graph, passing the primary match as the center node
            await JS.InvokeVoidAsync("filterGraphByNodes", visibleNodeIds.ToArray(), primaryMatch.Id);
            
            // Also select the primary match to show its details
            selectedConcept = primaryMatch;
            relatedConcepts = relationships.Where(r => r.SourceConceptId == primaryMatch.Id).ToList();
            incomingRelationships = relationships.Where(r => r.TargetConceptId == primaryMatch.Id).ToList();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Filter error: {ex.Message}");
            filterResultMessage = $"Error applying filter: {ex.Message}";
        }
        finally
        {
            isSearching = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Scores how well a concept matches the search query.
    /// Higher scores indicate better matches.
    /// </summary>
    private static int GetMatchScore(Concept concept, string query)
    {
        var titleLower = concept.Title.ToLowerInvariant();
        
        // Exact title match (highest priority)
        if (titleLower == query)
            return 100;
        
        // Title starts with query
        if (titleLower.StartsWith(query))
            return 80;
        
        // Title contains query as a word
        if (titleLower.Contains($" {query}") || titleLower.Contains($"{query} "))
            return 60;
        
        // Title contains query anywhere
        if (titleLower.Contains(query))
            return 40;
        
        // Alias exact match
        if (concept.Aliases.Any(a => a.Equals(query, StringComparison.OrdinalIgnoreCase)))
            return 30;
        
        // Alias contains query
        if (concept.Aliases.Any(a => a.Contains(query, StringComparison.OrdinalIgnoreCase)))
            return 20;
        
        return 0; // No match
    }

    /// <summary>
    /// Collects all node IDs within the specified depth from the starting concepts.
    /// Uses BFS to traverse the graph bidirectionally.
    /// </summary>
    private HashSet<string> CollectNodesWithinDepth(List<Concept> startConcepts, int maxDepth)
    {
        var result = new HashSet<string>();
        var visited = new HashSet<string>();
        var queue = new Queue<(string Id, int Depth)>();

        // Build adjacency list for bidirectional traversal
        var adjacency = BuildBidirectionalAdjacency();

        // Add all starting concepts
        foreach (var concept in startConcepts)
        {
            queue.Enqueue((concept.Id, 0));
            visited.Add(concept.Id);
        }

        while (queue.Count > 0)
        {
            var (currentId, currentDepth) = queue.Dequeue();
            result.Add(currentId);

            // If depth is unlimited (0) or we haven't reached max depth, continue traversal
            if (maxDepth == 0 || currentDepth < maxDepth)
            {
                if (adjacency.TryGetValue(currentId, out var neighbors))
                {
                    foreach (var neighborId in neighbors)
                    {
                        if (!visited.Contains(neighborId))
                        {
                            visited.Add(neighborId);
                            queue.Enqueue((neighborId, currentDepth + 1));
                        }
                    }
                }
            }
        }

        return result;
    }

    /// <summary>
    /// Builds an adjacency list treating all relationships as bidirectional.
    /// </summary>
    private Dictionary<string, HashSet<string>> BuildBidirectionalAdjacency()
    {
        var adjacency = new Dictionary<string, HashSet<string>>();

        // Initialize with all concepts
        foreach (var concept in concepts)
        {
            adjacency[concept.Id] = [];
        }

        // Add edges for all relationships (bidirectional)
        foreach (var rel in relationships)
        {
            if (adjacency.ContainsKey(rel.SourceConceptId) && adjacency.ContainsKey(rel.TargetConceptId))
            {
                adjacency[rel.SourceConceptId].Add(rel.TargetConceptId);
                adjacency[rel.TargetConceptId].Add(rel.SourceConceptId);
            }
        }

        return adjacency;
    }

    /// <summary>
    /// Resets the filter and shows all nodes.
    /// </summary>
    private async Task ResetFilter()
    {
        searchQuery = "";
        isFiltered = false;
        filteredNodeCount = 0;
        filterResultMessage = null;
        visibleNodeIds = [];

        try
        {
            await JS.InvokeVoidAsync("resetGraphFilter");
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[ConceptMapCollectionGraph] Reset filter error: {ex.Message}");
        }

        StateHasChanged();
    }

    /// <summary>
    /// Clears the search query without applying filter.
    /// </summary>
    private async Task ClearSearch()
    {
        await ResetFilter();
    }

