    private bool IsRegeneratingConceptMap(string resourceId)
    {
        return regeneratingConceptMaps.Contains(resourceId);
    }

    private async Task RegenerateConceptMap(CourseResource resource)
    {
        if (regeneratingConceptMaps.Contains(resource.Id))
            return;

        // Check if the resource has formatted content
        var content = resource.GetEffectiveContent();
        if (string.IsNullOrWhiteSpace(content))
        {
            Log.Warn($"Cannot regenerate ConceptMap for '{resource.Title}': No content available");
            return;
        }

        try
        {
            regeneratingConceptMaps.Add(resource.Id);
            StateHasChanged();

            Log.Info($"Regenerating ConceptMap for resource: {resource.Title}");

            // Clear existing ConceptMap data
            if (!string.IsNullOrEmpty(resource.ConceptMapId))
            {
                await ConceptMapStorageService.DeleteAsync(resource.ConceptMapId);
            }

            // Reset resource state
            resource.ConceptMapId = null;
            resource.ConceptMapStatus = ConceptMapStatus.NotStarted;
            await CourseService.SaveResourceAsync(resource);

            // Invalidate the cached details
            resourceKbDetailsCache.Remove(resource.Id);


            // Queue the resource for processing (only rebuild ConceptMap, don't re-format)
            ProcessingService.QueueResourceForProcessing(
                resource,
                selectedCourseId,
                autoFormat: false,  // Don't re-format, use existing formatted content
                buildGraph: true);  // Build the ConceptMap
            
            RefreshProcessingTasks();
            
            Log.Info($"ConceptMap regeneration queued for: {resource.Title}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to queue ConceptMap regeneration: {ex.Message}", ex);
        }
        finally
        {
            regeneratingConceptMaps.Remove(resource.Id);
            StateHasChanged();
        }
    }

    private async Task ExportConceptMap(CourseResource resource)
    {
        if (string.IsNullOrEmpty(resource.ConceptMapId))
        {
            Log.Warn($"Cannot export ConceptMap for '{resource.Title}': No ConceptMap exists");
            return;
        }

        try
        {
            // Load the ConceptMap and trigger export by re-saving it
            var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId);
            if (conceptMap != null && conceptMap.Status == ConceptMapStatus.Ready)
            {
                await ConceptMapStorageService.SaveAsync(conceptMap);
                
                // Show success message
                statusMessage = $"Concept Map exported to Resources/ConceptMaps/{SanitizeFileName(conceptMap.Name)}_concept-map.md";
                StateHasChanged();
                
                Log.Info($"ConceptMap exported for: {resource.Title}");
            }
            else
            {
                Log.Warn($"Cannot export ConceptMap for '{resource.Title}': ConceptMap not ready");
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to export ConceptMap: {ex.Message}", ex);
        }
    }

    private static string SanitizeFileName(string name)
    {
        var invalid = Path.GetInvalidFileNameChars();
        var sanitized = new string(name.Select(c => invalid.Contains(c) ? '_' : c).ToArray());
        return sanitized.ToLowerInvariant().Replace(' ', '-');
    }

    private async Task PickFile()
    {
        try
        {
            var customFileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
            {
                { DevicePlatform.iOS, new[] { "public.plain-text", "org.openxmlformats.wordprocessingml.document", "com.adobe.pdf" } },
                { DevicePlatform.Android, new[] { "text/plain", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/pdf" } },
                { DevicePlatform.WinUI, new[] { ".txt", ".docx", ".pdf" } },
                { DevicePlatform.MacCatalyst, new[] { "public.plain-text", "org.openxmlformats.wordprocessingml.document", "com.adobe.pdf" } }
            });

            var options = new PickOptions
            {
                PickerTitle = "Select a document",
                FileTypes = customFileTypes
            };

            var result = await FilePicker.PickAsync(options);

            if (result != null)
            {
                uploadedFileName = result.FileName;
                var extension = Path.GetExtension(result.FileName).ToLowerInvariant();

                using var stream = await result.OpenReadAsync();

                switch (extension)
                {
                    case ".txt":
                        uploadedFileType = ResourceType.Txt;
                        using (var reader = new StreamReader(stream))
                        {
                            fullFileContent = await reader.ReadToEndAsync();
                        }
                        break;

                    case ".docx":
                        uploadedFileType = ResourceType.Docx;
                        fullFileContent = await ReadDocxAsync(stream);
                        break;

                    case ".pdf":
                        uploadedFileType = ResourceType.Pdf;
                        fullFileContent = await ReadPdfAsync(stream);
                        break;

                    default:
                        statusMessage = "Unsupported file type.";
                        return;
                }

                // Also set resourceContent for saving
                resourceContent = fullFileContent;

                if (string.IsNullOrEmpty(resourceTitle))
                {
                    resourceTitle = Path.GetFileNameWithoutExtension(result.FileName);
                }

                statusMessage = $"File loaded: {fullFileContent.Length} characters";
            }
        }
        catch (Exception ex)
        {
            statusMessage = "Error reading file: " + ex.Message;
        }
    }

    private string GetContentPreview()
    {
        if (string.IsNullOrEmpty(fullFileContent))
            return "";
        
        return fullFileContent.Length <= 500 
            ? fullFileContent 
            : fullFileContent[..500];
    }

    private async Task<string> ReadDocxAsync(Stream stream)
    {
        try
        {
            using var archive = new System.IO.Compression.ZipArchive(stream, System.IO.Compression.ZipArchiveMode.Read);
            var entry = archive.GetEntry("word/document.xml");

            if (entry == null)
                return "[Could not read DOCX file]";

            using var entryStream = entry.Open();
            using var reader = new StreamReader(entryStream);
            var xml = await reader.ReadToEndAsync();

            var text = System.Text.RegularExpressions.Regex.Replace(xml, "<[^>]+>", " ");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ");
            return text.Trim();
        }
        catch
        {
            return "[Error reading DOCX file]";
        }
    }

    private Task<string> ReadPdfAsync(Stream stream)
    {
        return Task.FromResult("[PDF content extraction requires additional libraries. Please copy-paste the text content instead, or convert to .txt/.docx format.]");
    }

