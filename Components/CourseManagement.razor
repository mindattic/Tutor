@using Microsoft.Maui.Storage
@using Tutor.Models
@using Tutor.Services
@using Tutor.Services.Logging
@inject CourseService CourseService
@inject ResourceProcessingService ProcessingService
@inject KnowledgeBaseService KnowledgeBaseService
@inject KnowledgeBaseStorageService KnowledgeBaseStorageService
@inject IJSRuntime JS
@implements IDisposable

<div class="resources-container">
    @* Processing Queue Status *@
    @if (processingTasks.Count > 0)
    {
        <div class="processing-queue">
            <div class="queue-header">
                <span class="bi bi-hourglass-split"></span>
                <span>Processing @processingTasks.Count resource(s)...</span>
            </div>
            @foreach (var task in processingTasks.Values.OrderBy(t => t.QueuedAt))
            {
                <div class="queue-item @task.Stage.ToString().ToLower()">
                    <div class="queue-item-header">
                        <span class="queue-item-title">@task.ResourceTitle</span>
                        <span class="queue-item-stage">@task.StageDisplayName</span>
                    </div>
                    <div class="progress-bar-container small">
                        <div class="progress-bar" style="width: @(task.Progress)%"></div>
                    </div>
                    <div class="queue-item-status">@task.CurrentOperation</div>
                </div>
            }
        </div>
    }

    @* Course Selector *@
    <div class="curriculum-selector">
        <div class="curriculum-dropdown-container">
            <label>Active Course:</label>
            <div class="curriculum-select-row">
                <select class="curriculum-select" @bind="selectedCourseId" @bind:after="OnCourseChanged">
                    <option value="">None (Standard ChatGPT)</option>
                    @foreach (var course in courses)
                    {
                        <option value="@course.Id">@course.Name (@course.ResourceIds.Count resources)</option>
                    }
                </select>
                <button class="icon-btn" title="New Course" @onclick="ShowNewCourseModal">
                    <span class="icon-add"></span>
                </button>
                @if (!string.IsNullOrEmpty(selectedCourseId))
                {
                    <button class="icon-btn" title="Rename" @onclick="ShowRenameCourseModal">
                        <span class="icon-edit"></span>
                    </button>
                    <button class="icon-btn danger" title="Delete Course" @onclick="ConfirmDeleteCourse">
                        <span class="icon-delete"></span>
                    </button>
                }
            </div>
        </div>
        
        @if (string.IsNullOrEmpty(selectedCourseId))
        {
            <div class="curriculum-info-box">
                <span class="icon-info"></span>
                <span>No course selected. Chat will use standard ChatGPT with full knowledge.</span>
            </div>
        }
        else
        {
            var activeCourse = courses.FirstOrDefault(c => c.Id == selectedCourseId);
            if (activeCourse != null)
            {
                <div class="curriculum-info-box active">
                    <span class="icon-book"></span>
                    <span><strong>@activeCourse.Name</strong> is active. Chat will only use knowledge from the @activeCourse.ResourceIds.Count selected resource(s).</span>
                </div>
                
                @* Knowledge Base Section *@
                <div class="kb-section">
                    <div class="kb-status-row">
                        <div class="kb-status-info">
                            @if (isGeneratingKnowledgeBase)
                            {
                                <span class="kb-status generating">
                                    <span class="bi bi-hourglass-split"></span>
                                    <span>@kbGenerationStatus</span>
                                </span>
                                <div class="progress-bar-container">
                                    <div class="progress-bar" style="width: @(kbGenerationProgress)%"></div>
                                </div>
                            }
                            else if (activeCourse.HasKnowledgeBase)
                            {
                                <span class="kb-status @(kbNeedsRegeneration ? "needs-update" : "ready")">
                                    @if (kbNeedsRegeneration)
                                    {
                                        <span class="bi bi-arrow-clockwise"></span>
                                        <span>Knowledge Base needs update (@knowledgeBaseConceptCount concepts)</span>
                                    }
                                    else
                                    {
                                        <span class="bi bi-check-circle-fill"></span>
                                        <span>Knowledge Base Ready (@knowledgeBaseConceptCount concepts)</span>
                                    }
                                </span>
                            }
                            else
                            {
                                <span class="kb-status not-built">
                                    <span class="bi bi-exclamation-circle"></span>
                                    <span>No Knowledge Base - Generate one to enable concept exploration</span>
                                </span>
                            }
                        </div>
                        <div class="kb-actions">
                            @if (isGeneratingKnowledgeBase)
                            {
                                <button class="settings-btn danger small" @onclick="CancelKnowledgeBaseGeneration" title="Cancel">
                                    <span class="bi bi-x-lg"></span>
                                    Cancel
                                </button>
                            }
                            else
                            {
                                <button class="settings-btn @(kbNeedsRegeneration ? "warning" : "primary") small" 
                                        @onclick="GenerateKnowledgeBase" 
                                        disabled="@(activeCourse.ResourceIds.Count == 0)"
                                        title="@(activeCourse.HasKnowledgeBase ? "Regenerate Knowledge Base" : "Generate Knowledge Base")">
                                    <span class="bi bi-lightbulb"></span>
                                    @(activeCourse.HasKnowledgeBase ? "Regenerate" : "Generate") Knowledge Base
                                </button>
                                @if (activeCourse.HasKnowledgeBase)
                                {
                                    <button class="settings-btn small" @onclick="OpenKnowledgeBaseExplorer" title="Explore Knowledge Base">
                                        <span class="bi bi-diagram-3"></span>
                                        Explore
                                    </button>
                                }
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(kbErrorMessage))
                    {
                        <div class="kb-error">
                            <span class="bi bi-exclamation-triangle"></span>
                            <span>@kbErrorMessage</span>
                        </div>
                    }
                </div>
            }
        }
    </div>

    @* Tabs for Library and Add Resource *@
    <div class="tabs">
        <button class="tab @(activeTab == "Library" ? "active" : "")" @onclick="@(() => activeTab = "Library")">
            Resource Library
            @if (!string.IsNullOrEmpty(selectedCourseId))
            {
                var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
                if (course != null)
                {
                    <span class="tab-badge">@course.ResourceIds.Count in course</span>
                }
            }
        </button>
        <button class="tab @(activeTab == "Add" ? "active" : "")" @onclick="@(() => activeTab = "Add")">Add Resource</button>
    </div>

    <div class="tab-content">
        @if (activeTab == "Library")
        {
            <div class="library-section">
                @if (resources.Count == 0)
                {
                    <div class="empty-state">
                        <p>No resources yet. Add some resources to build your knowledge base.</p>
                        <button class="settings-btn primary" @onclick="@(() => activeTab = "Add")">Add First Resource</button>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(selectedCourseId))
                    {
                        <p class="library-hint">Check resources to add them to the active course. Uncheck to remove.</p>
                    }
                    else
                    {
                        <p class="library-hint">Select a course above to manage which resources are included.</p>
                    }
                    
                    <div class="resource-list">
                        @foreach (var item in resources)
                        {
                            var isInCourse = !string.IsNullOrEmpty(selectedCourseId) && 
                                courses.FirstOrDefault(c => c.Id == selectedCourseId)?.ResourceIds.Contains(item.Id) == true;
                            
                            <div class="resource-item @(isInCourse ? "in-curriculum" : "")">
                                @if (!string.IsNullOrEmpty(selectedCourseId))
                                {
                                    <div class="resource-checkbox">
                                        <input type="checkbox" 
                                               checked="@isInCourse"
                                               @onchange="@(() => ToggleResourceInCourse(item.Id))" />
                                    </div>
                                }
                                <div class="resource-info">
                                    <div class="resource-title">
                                        @item.Title
                                        @if (isInCourse)
                                        {
                                            <span class="in-curriculum-badge">In Course</span>
                                        }
                                    </div>
                                    <div class="resource-meta">
                                        @if (!string.IsNullOrEmpty(item.Author))
                                        {
                                            <span>@item.Author</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Year))
                                        {
                                            <span>(@item.Year)</span>
                                        }
                                        <span class="resource-type">@item.Type</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <div class="resource-description">@item.Description</div>
                                    }
                                </div>
                                <div class="resource-actions">
                                    <button class="icon-btn" title="Edit" @onclick="@(() => EditResource(item))">
                                        <span class="icon-edit"></span>
                                    </button>
                                    <button class="icon-btn danger" title="Delete" @onclick="@(() => ConfirmDeleteResource(item))">
                                        <span class="icon-delete"></span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (activeTab == "Add")
        {
            <div class="add-section">
                <h4>@(editingResource != null ? "Edit Resource" : "Add New Resource")</h4>

                <div class="form-group">
                    <label>Title *</label>
                    <input type="text" class="settings-input" @bind="resourceTitle" placeholder="Resource title" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Author</label>
                        <input type="text" class="settings-input" @bind="resourceAuthor" placeholder="Author name" />
                    </div>
                    <div class="form-group">
                        <label>Year</label>
                        <input type="text" class="settings-input" @bind="resourceYear" placeholder="2024" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea class="settings-input" @bind="resourceDescription" placeholder="Brief description of this resource" rows="2"></textarea>
                </div>

                <div class="form-group">
                    <label>Content Source</label>
                    <div class="toggle-button-group">
                        <button class="toggle-btn @(contentSource == "text" ? "active" : "")" @onclick="@(() => contentSource = "text")">
                            Paste Text
                        </button>
                        <button class="toggle-btn @(contentSource == "file" ? "active" : "")" @onclick="@(() => contentSource = "file")">
                            Upload File
                        </button>
                    </div>
                </div>

                @if (contentSource == "file")
                {
                    <div class="form-group">
                        <label>Upload Document</label>
                        <div class="file-upload-area">
                            <button class="settings-btn" @onclick="PickFile">Choose File</button>
                            @if (!string.IsNullOrEmpty(uploadedFileName))
                            {
                                <span class="file-name">@uploadedFileName</span>
                            }
                            else
                            {
                                <span class="file-hint">Supports .txt, .docx</span>
                            }
                        </div>
                    </div>
                }

                <div class="form-group">
                    <label>Content *</label>
                    <textarea class="settings-input content-textarea" 
                              @bind="resourceContent" 
                              placeholder="Paste your educational content here..."
                              rows="10"></textarea>
                    @if (!string.IsNullOrEmpty(resourceContent))
                    {
                        <div class="content-stats">@resourceContent.Length.ToString("N0") characters</div>
                    }
                </div>

                @if (editingResource == null)
                {
                    <div class="form-group">
                        <div class="checkbox-row">
                            <input type="checkbox" id="autoFormat" @bind="autoFormatContent" />
                            <label for="autoFormat">Auto-format with AI</label>
                        </div>
                        <p class="format-hint">
                            @if (autoFormatContent)
                            {
                                <span><span class="bi bi-check-lg"></span> Content will be automatically structured into clear sections with markdown formatting.</span>
                            }
                            else
                            {
                                <span>Content will be saved as-is without formatting.</span>
                            }
                        </p>
                    </div>

                    @if (!string.IsNullOrEmpty(selectedCourseId))
                    {
                        <div class="form-group">
                            <div class="checkbox-row">
                                <input type="checkbox" id="buildGraph" @bind="buildKnowledgeGraph" />
                                <label for="buildGraph">Build Knowledge Graph</label>
                            </div>
                            <p class="format-hint">
                                @if (buildKnowledgeGraph)
                                {
                                    <span><span class="bi bi-check-lg"></span> Concepts will be extracted and added to the course knowledge graph.</span>
                                }
                                else
                                {
                                    <span>Resource will be saved without updating the knowledge graph.</span>
                                }
                            </p>
                        </div>
                    }
                }

                <div class="form-actions">
                    @if (editingResource != null)
                    {
                        <button class="settings-btn" @onclick="CancelEdit">Cancel</button>
                        <button class="settings-btn primary" @onclick="QueueResource">
                            Update Resource
                        </button>
                    }
                    else
                    {
                        <button class="settings-btn primary" @onclick="QueueResource">
                            <span class="bi bi-plus-lg"></span> Add Resource
                        </button>
                    }
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="status-message @(statusMessage.StartsWith("Error") ? "error" : "success")">
                        @statusMessage
                    </div>
                }
            </div>
        }
    </div>
</div>

@* New Course Modal *@
@if (showNewCourseModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>Create New Course</span>
                <button class="close-btn" @onclick="CloseModals"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Course Name *</label>
                    <input type="text" class="settings-input" @bind="newCourseName" placeholder="e.g., Grade 5 Science" />
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="settings-input" @bind="newCourseDescription" placeholder="Brief description..." rows="2"></textarea>
                </div>
                <div class="form-actions">
                    <button class="settings-btn" @onclick="CloseModals">Cancel</button>
                    <button class="settings-btn primary" @onclick="CreateCourse">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@* Rename Course Modal *@
@if (showRenameCourseModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>Rename Course</span>
                <button class="close-btn" @onclick="CloseModals"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>New Name *</label>
                    <input type="text" class="settings-input" @bind="renameCourseName" placeholder="Enter new name" />
                </div>
                <div class="form-actions">
                    <button class="settings-btn" @onclick="CloseModals">Cancel</button>
                    <button class="settings-btn primary" @onclick="RenameCourse">Rename</button>
                </div>
            </div>
        </div>
    </div>
}

@* Delete Confirmation Modal *@
@if (showDeleteConfirmModal)
{
    <div class="modal-overlay" @onclick="CloseModals">
        <div class="modal-content small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>@deleteConfirmTitle</span>
                <button class="close-btn" @onclick="CloseModals"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body">
                <p>@deleteConfirmMessage</p>
                <div class="form-actions">
                    <button class="settings-btn" @onclick="CloseModals">Cancel</button>
                    <button class="settings-btn danger" @onclick="ExecuteDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@* Knowledge Base Explorer Modal *@
@if (showKnowledgeBaseExplorer && !string.IsNullOrEmpty(explorerKnowledgeBaseId))
{
    <div class="modal-overlay" @onclick="CloseKnowledgeBaseExplorer">
        <div class="modal-content kb-explorer-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><span class="bi bi-diagram-3"></span> Knowledge Base Explorer</span>
                <button class="close-btn" @onclick="CloseKnowledgeBaseExplorer"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body kb-explorer-body">
                <KnowledgeBaseGraph KnowledgeBaseId="@explorerKnowledgeBaseId" />
            </div>
        </div>
    </div>
}

@code {
private string activeTab = "Library";
private List<CourseResource> resources = new();
private List<Course> courses = new();
private string? selectedCourseId;
private Dictionary<string, ResourceProcessingStatus> processingTasks = new();

// Knowledge Base generation state
private bool isGeneratingKnowledgeBase;
private bool kbNeedsRegeneration;
private int kbGenerationProgress;
private string kbGenerationStatus = "";
private string kbErrorMessage = "";
private int knowledgeBaseConceptCount;
private CancellationTokenSource? kbCancellationTokenSource;

// Add/Edit form
private CourseResource? editingResource;
private string resourceTitle = "";
private string resourceAuthor = "";
private string resourceYear = "";
private string resourceDescription = "";
private string resourceContent = "";
    private string contentSource = "text";
    private string uploadedFileName = "";
    private ResourceType uploadedFileType = ResourceType.Text;
    private bool autoFormatContent = true;
    private bool buildKnowledgeGraph = true;

    // Modals
    private bool showNewCourseModal;
    private string newCourseName = "";
    private string newCourseDescription = "";
    
    private bool showRenameCourseModal;
    private string renameCourseName = "";

    // Knowledge Base Explorer modal
    private bool showKnowledgeBaseExplorer;
    private string? explorerKnowledgeBaseId;

    // Delete confirmation modal
    private bool showDeleteConfirmModal;
    private string deleteConfirmTitle = "";
    private string deleteConfirmMessage = "";
    private Func<Task>? pendingDeleteAction;

    private string statusMessage = "";

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to processing events
        ProcessingService.OnStatusChanged += OnProcessingStatusChanged;
        ProcessingService.OnProcessingComplete += OnProcessingComplete;
        ProcessingService.OnProcessingError += OnProcessingError;
        
        // Subscribe to KB build progress
        KnowledgeBaseService.OnProgressChanged += OnKnowledgeBaseProgressChanged;

        await LoadData();
        RefreshProcessingTasks();
    }

    public void Dispose()
    {
        ProcessingService.OnStatusChanged -= OnProcessingStatusChanged;
        ProcessingService.OnProcessingComplete -= OnProcessingComplete;
        ProcessingService.OnProcessingError -= OnProcessingError;
        KnowledgeBaseService.OnProgressChanged -= OnKnowledgeBaseProgressChanged;
        kbCancellationTokenSource?.Cancel();
        kbCancellationTokenSource?.Dispose();
    }

    private void OnProcessingStatusChanged(ResourceProcessingStatus status)
    {
        processingTasks[status.TaskId] = status;
        InvokeAsync(StateHasChanged);
    }

    private async void OnProcessingComplete(string taskId)
    {
        // Refresh data when processing completes
        await LoadData();
        
        // Remove from active tasks after a delay
        await Task.Delay(2000);
        processingTasks.Remove(taskId);
        await InvokeAsync(StateHasChanged);
    }

    private void OnProcessingError(string taskId, string error)
    {
        statusMessage = $"Error processing resource: {error}";
        InvokeAsync(StateHasChanged);
    }

    private void RefreshProcessingTasks()
    {
        processingTasks = ProcessingService.GetAllStatuses()
            .ToDictionary(s => s.TaskId, s => s);
    }

    private async Task LoadData()
    {
        resources = await CourseService.GetAllResourcesAsync();
        courses = await CourseService.GetAllCoursesAsync();
        selectedCourseId = await CourseService.GetActiveCourseIdAsync();
        
        // Load concept count for active course
        await LoadKnowledgeBaseInfo();
    }

    private async Task LoadKnowledgeBaseInfo()
    {
        knowledgeBaseConceptCount = 0;
        if (!string.IsNullOrEmpty(selectedCourseId))
        {
            var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
            if (course?.HasKnowledgeBase == true)
            {
                var kb = await KnowledgeBaseStorageService.LoadAsync(course.KnowledgeBaseId!);
                if (kb != null)
                {
                    knowledgeBaseConceptCount = kb.Concepts.Count;
                }
            }
        }
    }

    private async Task OnCourseChanged()
    {
        await CourseService.SetActiveCourseAsync(selectedCourseId);
        await LoadKnowledgeBaseInfo();
    }

    private async Task ToggleResourceInCourse(string resourceId)
    {
        if (string.IsNullOrEmpty(selectedCourseId))
            return;

        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        if (course == null)
            return;

        bool wasAdded = false;
        if (course.ResourceIds.Contains(resourceId))
        {
            await CourseService.RemoveResourceFromCourseAsync(selectedCourseId, resourceId);
        }
        else
        {
            await CourseService.AddResourceToCourseAsync(selectedCourseId, resourceId);
            wasAdded = true;
        }

        await LoadData();

        // If a resource was added and course has a KB, prompt to regenerate
        if (wasAdded && course.HasKnowledgeBase)
        {
            kbNeedsRegeneration = true;
            statusMessage = "Resource added. Consider regenerating the Knowledge Base to include the new content.";
        }
    }

    private void EditResource(CourseResource resource)
    {
        editingResource = resource;
        resourceTitle = resource.Title;
        resourceAuthor = resource.Author;
        resourceYear = resource.Year;
        resourceDescription = resource.Description;
        resourceContent = resource.Content;
        contentSource = "text";
        uploadedFileName = resource.FileName;
        activeTab = "Add";
    }

    private void CancelEdit()
    {
        editingResource = null;
        ClearForm();
    }

    private void ClearForm()
    {
        resourceTitle = "";
        resourceAuthor = "";
        resourceYear = "";
        resourceDescription = "";
        resourceContent = "";
        uploadedFileName = "";
        uploadedFileType = ResourceType.Text;
        autoFormatContent = true;
        buildKnowledgeGraph = true;
        statusMessage = "";
    }

    private void QueueResource()
    {
        if (string.IsNullOrWhiteSpace(resourceTitle))
        {
            statusMessage = "Title is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(resourceContent))
        {
            statusMessage = "Content is required.";
            return;
        }

        var isNew = editingResource == null;
        var resource = editingResource ?? new CourseResource();
        resource.Title = resourceTitle.Trim();
        resource.Author = resourceAuthor.Trim();
        resource.Year = resourceYear.Trim();
        resource.Description = resourceDescription.Trim();
        resource.Content = resourceContent;
        resource.Type = contentSource == "file" ? uploadedFileType : ResourceType.Text;
        resource.FileName = uploadedFileName;

        if (isNew)
        {
            resource.Id = Guid.NewGuid().ToString();
        }

        // Queue for async processing - returns immediately
        var taskId = ProcessingService.QueueResourceForProcessing(
            resource,
            selectedCourseId,
            autoFormat: autoFormatContent && isNew,
            buildGraph: buildKnowledgeGraph && !string.IsNullOrEmpty(selectedCourseId));

        statusMessage = "Resource queued for processing. You can add more resources.";
        editingResource = null;
        ClearForm();
        
        // Stay on Add tab to allow adding more resources
        RefreshProcessingTasks();
        StateHasChanged();
    }

    private async Task DeleteResource(string id)
    {
        await CourseService.DeleteResourceAsync(id);
        await LoadData();
    }

    private async Task PickFile()
    {
        try
        {
            var customFileTypes = new FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
            {
                { DevicePlatform.iOS, new[] { "public.plain-text", "org.openxmlformats.wordprocessingml.document", "com.adobe.pdf" } },
                { DevicePlatform.Android, new[] { "text/plain", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/pdf" } },
                { DevicePlatform.WinUI, new[] { ".txt", ".docx", ".pdf" } },
                { DevicePlatform.MacCatalyst, new[] { "public.plain-text", "org.openxmlformats.wordprocessingml.document", "com.adobe.pdf" } }
            });

            var options = new PickOptions
            {
                PickerTitle = "Select a document",
                FileTypes = customFileTypes
            };

            var result = await FilePicker.PickAsync(options);

            if (result != null)
            {
                uploadedFileName = result.FileName;
                var extension = Path.GetExtension(result.FileName).ToLowerInvariant();

                using var stream = await result.OpenReadAsync();

                switch (extension)
                {
                    case ".txt":
                        uploadedFileType = ResourceType.Txt;
                        using (var reader = new StreamReader(stream))
                        {
                            resourceContent = await reader.ReadToEndAsync();
                        }
                        break;

                    case ".docx":
                        uploadedFileType = ResourceType.Docx;
                        resourceContent = await ReadDocxAsync(stream);
                        break;

                    case ".pdf":
                        uploadedFileType = ResourceType.Pdf;
                        resourceContent = await ReadPdfAsync(stream);
                        break;

                    default:
                        statusMessage = "Unsupported file type.";
                        return;
                }

                if (string.IsNullOrEmpty(resourceTitle))
                {
                    resourceTitle = Path.GetFileNameWithoutExtension(result.FileName);
                }

                statusMessage = $"File loaded: {resourceContent.Length} characters";
            }
        }
        catch (Exception ex)
        {
            statusMessage = "Error reading file: " + ex.Message;
        }
    }

    private async Task<string> ReadDocxAsync(Stream stream)
    {
        try
        {
            using var archive = new System.IO.Compression.ZipArchive(stream, System.IO.Compression.ZipArchiveMode.Read);
            var entry = archive.GetEntry("word/document.xml");

            if (entry == null)
                return "[Could not read DOCX file]";

            using var entryStream = entry.Open();
            using var reader = new StreamReader(entryStream);
            var xml = await reader.ReadToEndAsync();

            var text = System.Text.RegularExpressions.Regex.Replace(xml, "<[^>]+>", " ");
            text = System.Text.RegularExpressions.Regex.Replace(text, @"\s+", " ");
            return text.Trim();
        }
        catch
        {
            return "[Error reading DOCX file]";
        }
    }

    private Task<string> ReadPdfAsync(Stream stream)
    {
        return Task.FromResult("[PDF content extraction requires additional libraries. Please copy-paste the text content instead, or convert to .txt/.docx format.]");
    }

    // Course management
    private void ShowNewCourseModal()
    {
        newCourseName = "";
        newCourseDescription = "";
        showNewCourseModal = true;
    }

    private void ShowRenameCourseModal()
    {
        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        renameCourseName = course?.Name ?? "";
        showRenameCourseModal = true;
    }

    private void CloseModals()
    {
        showNewCourseModal = false;
        showRenameCourseModal = false;
        showDeleteConfirmModal = false;
        pendingDeleteAction = null;
    }

    private void OpenKnowledgeBaseExplorer()
    {
        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        if (course?.HasKnowledgeBase == true)
        {
            explorerKnowledgeBaseId = course.KnowledgeBaseId;
            showKnowledgeBaseExplorer = true;
        }
    }

    private void CloseKnowledgeBaseExplorer()
    {
        showKnowledgeBaseExplorer = false;
        explorerKnowledgeBaseId = null;
    }

    private void ConfirmDeleteCourse()
    {
        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        if (course == null) return;

        deleteConfirmTitle = "Delete Course";
        deleteConfirmMessage = $"Are you sure you want to delete \"{course.Name}\"? This will remove the course and its Knowledge Base, but resources will remain in the library.";
        pendingDeleteAction = async () =>
        {
            await CourseService.DeleteCourseAsync(selectedCourseId!);
            selectedCourseId = null;
            await LoadData();
        };
        showDeleteConfirmModal = true;
    }

    private void ConfirmDeleteResource(CourseResource resource)
    {
        deleteConfirmTitle = "Delete Resource";
        deleteConfirmMessage = $"Are you sure you want to delete \"{resource.Title}\"? This will remove it from all courses.";
        pendingDeleteAction = async () =>
        {
            await CourseService.DeleteResourceAsync(resource.Id);
            await LoadData();
        };
        showDeleteConfirmModal = true;
    }

    private async Task ExecuteDelete()
    {
        if (pendingDeleteAction != null)
        {
            await pendingDeleteAction();
        }
        CloseModals();
    }

    private async Task CreateCourse()
    {
        if (string.IsNullOrWhiteSpace(newCourseName))
            return;

        var course = await CourseService.CreateCourseAsync(
            newCourseName.Trim(), 
            newCourseDescription.Trim());

        selectedCourseId = course.Id;
        await CourseService.SetActiveCourseAsync(course.Id);
        await LoadData();
        CloseModals();
    }

    private async Task RenameCourse()
    {
        if (string.IsNullOrWhiteSpace(renameCourseName) || string.IsNullOrEmpty(selectedCourseId))
            return;

        await CourseService.RenameCourseAsync(selectedCourseId, renameCourseName.Trim());
        await LoadData();
        CloseModals();
    }

    // Knowledge Base generation
    private void OnKnowledgeBaseProgressChanged(KnowledgeBaseBuildProgress progress)
    {
        kbGenerationProgress = progress.Progress;
        kbGenerationStatus = progress.Message;
        InvokeAsync(StateHasChanged);
    }

    private async Task GenerateKnowledgeBase()
    {
        if (string.IsNullOrEmpty(selectedCourseId))
        {
            Log.Warn("GenerateKnowledgeBase called with no course selected");
            return;
        }

        var course = courses.FirstOrDefault(c => c.Id == selectedCourseId);
        if (course == null || course.ResourceIds.Count == 0)
        {
            kbErrorMessage = "Add at least one resource to the course before generating a Knowledge Base.";
            Log.Warn($"Cannot generate KB for course '{course?.Name ?? selectedCourseId}': No resources");
            return;
        }

        // Get resources for this course
        var courseResources = resources.Where(r => course.ResourceIds.Contains(r.Id)).ToList();
        if (courseResources.Count == 0)
        {
            kbErrorMessage = "No resources found for this course.";
            Log.Warn($"Cannot generate KB for course '{course.Name}': Resources not found in library");
            return;
        }

        Log.Info($"Starting Knowledge Base generation for course '{course.Name}' with {courseResources.Count} resource(s)");
        
        isGeneratingKnowledgeBase = true;
        kbGenerationProgress = 0;
        kbGenerationStatus = "Starting Knowledge Base generation...";
        kbErrorMessage = "";
        kbCancellationTokenSource = new CancellationTokenSource();

        try
        {
            var kb = await KnowledgeBaseService.BuildFromResourcesAsync(
                $"{course.Name} Knowledge Base",
                courseResources,
                kbCancellationTokenSource.Token);


            // Link the Knowledge Base to the course
            course.KnowledgeBaseId = kb.Id;
            course.UpdatedAt = DateTime.UtcNow;
            await CourseService.SaveCourseAsync(course);

            knowledgeBaseConceptCount = kb.Concepts.Count;
            kbGenerationStatus = $"Knowledge Base generated with {kb.Concepts.Count} concepts!";
            kbNeedsRegeneration = false; // Clear the flag after successful generation
            
            Log.Info($"Knowledge Base generation completed for '{course.Name}': {kb.Concepts.Count} concepts, {kb.Relations.Count} relationships");
            
            await LoadData();
        }
        catch (OperationCanceledException)
        {
            kbGenerationStatus = "Knowledge Base generation cancelled.";
            Log.Warn($"Knowledge Base generation cancelled for course '{course.Name}'");
        }
        catch (Exception ex)
        {
            kbErrorMessage = $"Failed to generate Knowledge Base: {ex.Message}";
            Log.Error($"Knowledge Base generation failed for course '{course.Name}': {ex.Message}", ex);
        }
        finally
        {
            isGeneratingKnowledgeBase = false;
            kbCancellationTokenSource?.Dispose();
            kbCancellationTokenSource = null;
            StateHasChanged();
        }
    }

    private void CancelKnowledgeBaseGeneration()
    {
        Log.Info("User cancelled Knowledge Base generation");
        kbCancellationTokenSource?.Cancel();
    }
}
