    {
        if (activeCourse == null)
            return;

        // Load concepts from all resources' ConceptMaps in this course
        var conceptMapIds = await CourseService.GetResourceConceptMapIdsAsync(activeCourse.Id);
        
        if (conceptMapIds.Count == 0)
        {
            Log.Debug("Chat: No ConceptMaps found for course resources");
            return;
        }


        var allConcepts = new List<Concept>();
        
        foreach (var cmId in conceptMapIds)
