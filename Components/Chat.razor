@using System.Text
@using System.Text.RegularExpressions
@using Microsoft.JSInterop
@using Tutor.Services
@using Tutor.Models
@inject OpenAIService Ai
@inject InstructionsService Instructions
@inject SettingsService Settings
@inject CourseService CourseService
@implements IDisposable

@* Mode indicators at the top *@
@if (isQuizMode)
{
    <div class="mode-indicator quiz">
        <span class="mode-icon icon-quiz-white"></span>
        <span class="mode-label">Quiz Mode</span>
        <span class="mode-detail">Question @currentQuestionNumber of @totalQuestions</span>
        <div class="mode-spacer"></div>
        <button class="mode-exit-btn" @onclick="ConfirmRestartQuiz" title="Restart Quiz"><span class="bi bi-arrow-clockwise"></span> Restart</button>
        <button class="mode-exit-btn cancel" @onclick="ConfirmCancelQuiz" title="Cancel Quiz"><span class="bi bi-x-lg"></span> Cancel</button>
    </div>
}
else if (isLessonMode && lessonTopics.Count > 0)
{
    <div class="mode-indicator lesson">
        <span class="mode-icon icon-teach-white"></span>
        <span class="mode-label">Lesson Mode</span>
        <span class="mode-detail">Topic @(currentLessonIndex + 1) of @lessonTopics.Count</span>
        @if (currentLessonIndex < lessonTopics.Count)
        {
            <span class="mode-topic">@lessonTopics[currentLessonIndex]</span>
        }
        <span class="mode-progress">@GetLessonProgressText()</span>
        <div class="mode-spacer"></div>
        <button class="mode-exit-btn toc" @onclick="ShowTableOfContents" title="Table of Contents"><span class="bi bi-list-ul"></span> Table of Contents</button>
        <button class="mode-exit-btn" @onclick="ConfirmRestartLesson" title="Restart Lesson"><span class="bi bi-arrow-clockwise"></span> Restart</button>
    </div>
}

@* Confirmation modal (for restart and cancel) *@
@if (showConfirmModal)
{
    <div class="modal-overlay" @onclick="CloseConfirmModal">
        <div class="modal-content small" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>@confirmModalTitle</span>
                <button class="close-btn" @onclick="CloseConfirmModal"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body">
                <p>@confirmModalMessage</p>
                <div class="modal-actions">
                    <button class="settings-btn" @onclick="CloseConfirmModal">Cancel</button>
                    <button class="settings-btn danger" @onclick="ExecuteConfirmedAction">@confirmModalActionText</button>
                </div>
            </div>
        </div>
    </div>
}

@* Table of Contents modal *@
@if (showTableOfContents && lessonTopics.Count > 0)
{
    <div class="modal-overlay" @onclick="CloseTableOfContents">
        <div class="modal-content toc-modal" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span><span class="bi bi-list-ul"></span> Table of Contents</span>
                <button class="close-btn" @onclick="CloseTableOfContents"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body toc-body">
                <p class="toc-instruction">Click any topic to jump directly to it:</p>
                <div class="toc-list">
                    @for (int i = 0; i < lessonTopics.Count; i++)
                    {
                        var index = i;
                        var topic = lessonTopics[i];
                        var isCurrentTopic = i == currentLessonIndex;
                        var isCompleted = learnedConcepts.Contains(topic);
                        var isVisited = visitedTopicIndices.Contains(i);
                        
                        <button class="toc-item @(isCurrentTopic ? "current" : "") @(isCompleted ? "completed" : "") @(isVisited && !isCompleted ? "visited" : "")"
                                @onclick="() => JumpToTopic(index)">
                            <span class="toc-number">@(i + 1)</span>
                            <span class="toc-topic">@topic</span>
                            @if (isCompleted)
                            {
                                <span class="toc-status"><span class="bi bi-check-lg"></span></span>
                            }
                            else if (isCurrentTopic)
                            {
                                <span class="toc-status"><span class="bi bi-caret-right-fill"></span></span>
                            }
                            else if (isVisited)
                            {
                                <span class="toc-status"><span class="bi bi-circle"></span></span>
                            }
                        </button>
                    }
                </div>
                <div class="toc-legend">
                    <span><span class="legend-icon bi bi-check-lg"></span> Completed</span>
                    <span><span class="legend-icon bi bi-caret-right-fill"></span> Current</span>
                    <span><span class="legend-icon bi bi-circle"></span> Visited</span>
                </div>
            </div>
        </div>
    </div>
}

<div class="chat-shell">
    <div class="chat-log" @ref="chatLogRef">
        @{
            var messageIndex = 0;
            var hiddenCount = GetHiddenMessageCount();
            var startIndex = showAllMessages ? 0 : Math.Max(0, messages.Count - RecentMessageCount);
        }

        @* Show expand button if there are hidden messages *@
        @if (hiddenCount > 0 && !showAllMessages)
        {
            <div class="hidden-messages-notice">
                <button class="expand-messages-btn" @onclick="() => showAllMessages = true">
                    <span class="bi bi-chevron-up"></span>
                    Show @hiddenCount older message@(hiddenCount == 1 ? "" : "s")
                </button>
            </div>
        }
        @if (showAllMessages && messages.Count > RecentMessageCount)
        {
            <div class="hidden-messages-notice">
                <button class="expand-messages-btn" @onclick="() => showAllMessages = false">
                    <span class="bi bi-chevron-down"></span>
                    Hide older messages
                </button>
            </div>
        }

        @foreach (var m in messages)
        {
            var idx = messageIndex;
            var isLastAssistantMessage = m.Role == "assistant" && idx == GetLastAssistantMessageIndex();
            var isVisible = showAllMessages || idx >= startIndex;

            @if (isVisible)
            {
                <div class="msg-wrapper @(m.Role)">
                    <div class="msg-avatar @(m.Role)">
                        @if (m.Role == "user" && !string.IsNullOrEmpty(userCustomAvatar))
                        {
                            <img src="@userCustomAvatar" alt="@userDisplayName" />
                        }
                        else if (m.Role == "assistant" && !string.IsNullOrEmpty(assistantCustomAvatar))
                        {
                            <img src="@assistantCustomAvatar" alt="@assistantDisplayName" />
                        }
                        else
                        {
                            <span class="bi @(m.Role == "user" ? userAvatarIcon : assistantAvatarIcon)"></span>
                        }
                    </div>
                    <div class="msg @(m.Role)">
                        <div class="msg-header">
                            <span class="role">@(m.Role == "user" ? userDisplayName : assistantDisplayName)</span>
                            <button class="view-btn" @onclick="() => ShowModal(m.FullJson)">View</button>
                        </div>
                        <div class="content markdown-content">@((MarkupString)ParseMarkdown(m.VisibleText))</div>

                        @* Show navigation buttons in assistant messages during lesson mode *@
                        @if (m.Role == "assistant" && isLessonMode && !isQuizMode && !isSending && isLastAssistantMessage && !isTermExploration)
                        {
                            <div class="msg-nav-buttons">
                                @if (learnedConcepts.Count > 0)
                                {
                                    <button class="msg-nav-btn quiz-inline" @onclick="StartQuizAtCurrentPoint" title="Quiz me on what I've learned so far">
                                        <span class="icon-quiz-small"></span>
                                        Quiz Me
                                    </button>
                                    <div class="msg-nav-spacer"></div>
                                }
                                <button class="msg-nav-btn previous" @onclick="PreviousLesson" disabled="@(currentLessonIndex <= 0)" title="Go to previous topic">
                                    <span class="icon-previous"></span>
                                    Previous
                                </button>
                                <button class="msg-nav-btn continue" @onclick="ContinueLesson" title="@(hasStartedLearning ? "Continue to next topic" : "Begin the lesson")">
                                    <span class="icon-continue"></span>
                                    @(hasStartedLearning ? "Continue" : "Begin")
                                </button>
                            </div>
                        }

                        @* Show Continue button for term exploration *@
                        @if (m.Role == "assistant" && isTermExploration && isLastAssistantMessage && !isSending)
                        {
                            <div class="msg-nav-buttons">
                                <button class="msg-nav-btn continue" @onclick="ContinueFromExploration" title="Continue with the lesson">
                                    <span class="icon-continue"></span>
                                    Continue
                                </button>
                            </div>
                        }

                        @* Suggestion area for follow-up questions *@
                        <div class="msg-suggestions"></div>
                    </div>
                </div>
            }
            messageIndex++;
        }

        @if (isSending)
        {
            <div class="msg-wrapper assistant">
                <div class="msg-avatar assistant">
                    @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                    {
                        <img src="@assistantCustomAvatar" alt="@assistantDisplayName" />
                    }
                    else
                    {
                        <span class="bi @assistantAvatarIcon"></span>
                    }
                </div>
                <div class="msg assistant">
                    <div class="msg-header">
                        <span class="role">@assistantDisplayName</span>
                    </div>
                    <div class="content thinking">
                        <span class="thinking-dots">
                            <span></span><span></span><span></span>
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="chat-input">
        <textarea @ref="textareaRef"
                  @bind="prompt"
                  @bind:event="oninput"
                  @bind:after="AutoGrow"
                  rows="1"
                  disabled="@isSending"
                  placeholder="@placeholderText"></textarea>

        <div class="chat-actions-row">
            <div class="actions-spacer"></div>
            @if (isSending)
            {
                <button class="action-btn cancel" @onclick="CancelRequest" title="Cancel">
                    <span class="bi bi-stop-fill"></span>
                    Cancel
                </button>
            }
            <button class="action-btn send" @onclick="SendAsync" disabled="@(isSending || string.IsNullOrWhiteSpace(prompt))" title="Send">
                <span class="bi bi-send-fill"></span>
                Send
            </button>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <span>Full Response</span>
                <button class="close-btn" @onclick="CloseModal"><span class="bi bi-x-lg"></span></button>
            </div>
            <div class="modal-body">
                <pre>@modalContent</pre>
            </div>
        </div>
    </div>
}

@code {
private readonly List<ChatMessage> messages = new();
private string prompt = "";
private bool isSending;
private bool showModal;
private string modalContent = "";
private ElementReference textareaRef;
private ElementReference chatLogRef;
private DotNetObjectReference<Chat>? dotNetRef;
private CancellationTokenSource? cts;
private bool enterToSend = true;
private string placeholderText = "Ask a question...";
private string? pendingDisplayText; // Simplified display text for next message
private bool pendingIsExploration; // Whether next message is part of exploration

// Avatar settings
private string userDisplayName = "User";
private string assistantDisplayName = "Assistant";
private string userAvatarIcon = "bi-person-fill";
private string assistantAvatarIcon = "bi-robot";
private string? userCustomAvatar;
private string? assistantCustomAvatar;

// Message visibility
private const int RecentMessageCount = 4; // Show last N messages by default
private bool showAllMessages;

    // Course state
    private Course? activeCourse;

    // Lesson state
    private bool isLessonMode;
    private bool hasStartedLearning; // True after first "Begin" click
    private int currentLessonIndex;
    private List<string> lessonTopics = new();
    private List<string> learnedConcepts = new();
    private HashSet<int> visitedTopicIndices = new(); // Track which topics have been visited


    // Term exploration state
    private bool isTermExploration;
    private int messageIndexBeforeExploration;

    // Confirmation modal state
    private bool showConfirmModal;
    private string confirmModalTitle = "";
    private string confirmModalMessage = "";
    private string confirmModalActionText = "";
    private Func<Task>? confirmedAction;

    // Quiz state
    private bool isQuizMode;
    private int totalQuestions;
    private int currentQuestionNumber;
    private int correctAnswers;
    private GradingScale gradingScale;

    // Table of Contents state
    private bool showTableOfContents;

    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadCourseState();
        await LoadLessonStateAsync();
        
        // Auto-start lesson if course is active and not already in lesson mode
        if (activeCourse != null && !isLessonMode)
        {
            await StartLesson();
        }
    }

    private async Task LoadCourseState()
    {
        activeCourse = await CourseService.GetActiveCourseAsync();
    }

    private async Task LoadLessonStateAsync()
    {
        var state = await Settings.GetLessonStateAsync();
        if (state == null || activeCourse == null || state.CurriculumId != activeCourse.Id)
            return;

        // Restore lesson state
        isLessonMode = true;
        hasStartedLearning = state.HasStartedLearning;
        currentLessonIndex = state.CurrentLessonIndex;
        lessonTopics = state.LessonTopics;
        learnedConcepts = state.LearnedConcepts;
        visitedTopicIndices = [.. state.VisitedTopicIndices];

        // Restore messages
        messages.Clear();
        foreach (var msg in state.Messages)
        {
            messages.Add(new ChatMessage(msg.Role, msg.Text, msg.FullJson));
        }
    }

    private async Task SaveLessonStateAsync()
    {
        if (!isLessonMode || activeCourse == null)
        {
            await Settings.ClearLessonStateAsync();
            return;
        }

        var state = new LessonState
        {
            CurriculumId = activeCourse.Id,
            CurrentLessonIndex = currentLessonIndex,
            HasStartedLearning = hasStartedLearning,
            LessonTopics = lessonTopics,
            LearnedConcepts = learnedConcepts,
            VisitedTopicIndices = [.. visitedTopicIndices],
            Messages = messages.Select(m => new ChatMessageState
            {
                Role = m.Role,
                Text = m.Text,
                FullJson = m.FullJson
            }).ToList()
        };

        await Settings.SaveLessonStateAsync(state);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            enterToSend = await Settings.GetEnterToSendAsync();
            
            // Load avatar settings
            userDisplayName = await Settings.GetUserDisplayNameAsync();
            assistantDisplayName = await Settings.GetAssistantDisplayNameAsync();
            userAvatarIcon = await Settings.GetUserAvatarIconAsync();
            assistantAvatarIcon = await Settings.GetAssistantAvatarIconAsync();
            userCustomAvatar = await Settings.GetUserCustomAvatarAsync();
            assistantCustomAvatar = await Settings.GetAssistantCustomAvatarAsync();
            
            UpdatePlaceholder();
            StateHasChanged();

            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("setupTextareaEnterHandler", textareaRef, dotNetRef, enterToSend);
            await JS.InvokeVoidAsync("setupTabFocus", textareaRef);
            await JS.InvokeVoidAsync("setupTermClickHandler", dotNetRef);
            await FocusTextarea();
        }
    }

    private int GetLastAssistantMessageIndex()
    {
        for (int i = messages.Count - 1; i >= 0; i--)
        {
            if (messages[i].Role == "assistant")
                return i;
        }
        return -1;
    }

    private int GetHiddenMessageCount()
    {
        return Math.Max(0, messages.Count - RecentMessageCount);
    }

    private void UpdatePlaceholder()
    {
        placeholderText = enterToSend
            ? "Ask a question... (Enter to send, Shift+Enter for new line)"
            : "Ask a question... (Click Send button to submit)";
    }

    private async Task FocusTextarea()
    {
        await JS.InvokeVoidAsync("focusElement", textareaRef);
    }

    private void CancelRequest()
    {
        cts?.Cancel();
    }

    // Lesson functionality
    private async Task StartLesson()
    {
        if (activeCourse == null) return;

        var resources = await CourseService.GetCourseResourcesAsync(activeCourse.Id);
        if (resources.Count == 0)
        {
            messages.Add(new ChatMessage("assistant", "This course has no resources yet. Please add some resources first.", "No resources in course."));
            StateHasChanged();
            return;
        }

        // Initialize lesson mode
        isLessonMode = true;
        hasStartedLearning = false;
        currentLessonIndex = 0;
        learnedConcepts.Clear();
        visitedTopicIndices.Clear();
        messages.Clear();

        // Build a prompt that emphasizes using ALL resources together
        var resourceNames = string.Join(", ", resources.Select(r => r.Title));
        var topicsPrompt = $@"Based on ALL the course resources ({resourceNames}), create a unified curriculum.

IMPORTANT: You must synthesize knowledge from ALL {resources.Count} resources to create topics that:
- Cover the breadth of information across ALL resources
- Integrate related concepts from different resources
- Present a logical learning progression

Return ONLY a numbered list of topic names, one per line, like:
1. Topic Name
2. Topic Name
etc.
Keep it to 8-15 main topics to ensure comprehensive coverage.";

        prompt = topicsPrompt;
        await SendAsyncInternal(captureTopics: true);
    }

    private async Task ContinueLesson()
    {
        if (!isLessonMode || activeCourse == null) return;

        // If this is the first time clicking (Begin), teach the first topic
        if (!hasStartedLearning)
        {
            hasStartedLearning = true;
            visitedTopicIndices.Add(currentLessonIndex);
            await TeachCurrentTopic();
            return;
        }

        // Mark current topic as learned
        if (currentLessonIndex < lessonTopics.Count)
        {
            var currentTopic = lessonTopics[currentLessonIndex];
            if (!learnedConcepts.Contains(currentTopic))
            {
                learnedConcepts.Add(currentTopic);
            }
        }

        currentLessonIndex++;

        if (currentLessonIndex >= lessonTopics.Count)
        {
            messages.Add(new ChatMessage("assistant", "?? **Congratulations!** You've completed all the topics in this lesson. You can use the **Previous** button to review any topic, or take a **Quiz** to test your knowledge!", "Lesson completed"));
            StateHasChanged();
            return;
        }

        // Check if we've visited this topic before (spiral learning)
        var enrichWithLearned = visitedTopicIndices.Contains(currentLessonIndex);
        visitedTopicIndices.Add(currentLessonIndex);

        await TeachCurrentTopic(enrichWithLearned);
    }

    private async Task PreviousLesson()
    {
        if (!isLessonMode || currentLessonIndex <= 0) return;

        // Mark current topic as learned before going back
        if (currentLessonIndex < lessonTopics.Count)
        {
            var currentTopic = lessonTopics[currentLessonIndex];
            if (!learnedConcepts.Contains(currentTopic))
            {
                learnedConcepts.Add(currentTopic);
            }
        }

        currentLessonIndex--;

        // Going back always enriches with learned concepts (spiral learning)
        await TeachCurrentTopic(enrichWithLearned: true);
    }

    private async Task TeachCurrentTopic(bool enrichWithLearned = false)
    {
        if (currentLessonIndex >= lessonTopics.Count) return;

        var topic = lessonTopics[currentLessonIndex];

        string teachPrompt;
        if (enrichWithLearned && learnedConcepts.Count > 0)
        {
            var learnedList = string.Join(", ", learnedConcepts);
            teachPrompt = $@"Teach me about ""{topic}"" from the curriculum.

IMPORTANT CONTEXT - SPIRAL LEARNING:
The student has already learned these concepts: {learnedList}

Since the student is REVISITING this topic after learning more advanced concepts, you must:
1. Connect ""{topic}"" to the concepts they already know
2. Show how ""{topic}"" relates to and supports their existing knowledge
3. Provide deeper insights now that they have more context
4. Use examples that reference the other concepts they've learned

This is spiral learning - enrich the explanation with their accumulated knowledge.

Explain clearly and ask if they understand before we continue.";
        }
        else
        {
            teachPrompt = $@"Teach me about ""{topic}"" from the curriculum.
Explain the key concepts clearly, as if you're a tutor.
After explaining, ask if I understand or have questions before we continue.";
        }

        prompt = teachPrompt;
        await SendAsync();
    }

    private async Task BackToLesson()
    {
        if (!isTermExploration) return;

        // Remove messages added during exploration
        while (messages.Count > messageIndexBeforeExploration)
        {
            messages.RemoveAt(messages.Count - 1);
        }

        isTermExploration = false;
        StateHasChanged();

        // Save state after returning to lesson
        if (isLessonMode)
        {
            await SaveLessonStateAsync();
        }
    }

    private async Task ContinueFromExploration()
    {
        // Clear exploration state and continue with the lesson
        isTermExploration = false;
        
        // Continue to next topic if we're in lesson mode
        if (isLessonMode)
        {
            await ContinueLesson();
        }
        else
        {
            StateHasChanged();
        }
    }

    private async Task RestartLesson()
    {
        // Clear all lesson state
        isLessonMode = false;
        hasStartedLearning = false;
        currentLessonIndex = 0;
        lessonTopics.Clear();
        learnedConcepts.Clear();
        visitedTopicIndices.Clear();
        messages.Clear();
        await Settings.ClearLessonStateAsync();
        
        // Restart the lesson from the beginning
        await StartLesson();
    }

    // Table of Contents functionality
    private void ShowTableOfContents()
    {
        showTableOfContents = true;
    }

    private void CloseTableOfContents()
    {
        showTableOfContents = false;
    }

    private async Task JumpToTopic(int topicIndex)
    {
        if (topicIndex < 0 || topicIndex >= lessonTopics.Count) return;

        // Close the TOC modal
        showTableOfContents = false;

        // Mark current topic as learned if we've started learning
        if (hasStartedLearning && currentLessonIndex < lessonTopics.Count)
        {
            var currentTopic = lessonTopics[currentLessonIndex];
            if (!learnedConcepts.Contains(currentTopic))
            {
                learnedConcepts.Add(currentTopic);
            }
        }

        // Jump to the selected topic
        currentLessonIndex = topicIndex;
        hasStartedLearning = true;

        // Check if we've visited this topic before (for spiral learning enrichment)
        var enrichWithLearned = visitedTopicIndices.Contains(topicIndex) && learnedConcepts.Count > 0;
        visitedTopicIndices.Add(topicIndex);

        await TeachCurrentTopic(enrichWithLearned);
    }

    private string GetLessonProgressText()
    {
        if (lessonTopics.Count == 0) return "";
        var completed = learnedConcepts.Count;
        var total = lessonTopics.Count;
        var percentage = (int)((double)completed / total * 100);
        return $"{completed}/{total} completed ({percentage}%)";
    }

    // Quiz at current point in lesson (inline quiz)
    private async Task StartQuizAtCurrentPoint()
    {
        if (activeCourse == null || learnedConcepts.Count == 0)
        {
            // If no concepts learned yet, quiz on the current topic
            if (currentLessonIndex < lessonTopics.Count)
            {
                var currentTopic = lessonTopics[currentLessonIndex];
                learnedConcepts.Add(currentTopic);
            }
        }

        // Get quiz settings
        var questionCount = Math.Min(await Settings.GetQuizQuestionCountAsync(), Math.Max(3, learnedConcepts.Count));
        gradingScale = await Settings.GetGradingScaleAsync();
        currentQuestionNumber = 1;
        totalQuestions = questionCount;
        correctAnswers = 0;
        isQuizMode = true;
        // Keep lesson mode active so we can return to it

        var topicsList = string.Join(", ", learnedConcepts);
        var quizPrompt = $@"Quiz me on what I've learned so far. I have covered these topics: {topicsList}

Please ask me {questionCount} questions ONLY about these specific topics I've learned.

QUIZ RULES:
1. Ask ONE question at a time
2. Wait for my answer before asking the next question
3. After I answer, tell me if I'm correct or incorrect and briefly explain why
4. Keep track of my score
5. After all {questionCount} questions, provide a summary and then I'll continue with my lesson

Please start with Question 1.";

        prompt = quizPrompt;
        await SendAsync();
    }

    // Quiz Me functionality (full course quiz)
    private async Task StartQuizMe()
    {
        if (activeCourse == null) return;

        var resources = await CourseService.GetCourseResourcesAsync(activeCourse.Id);
        if (resources.Count == 0)
        {
            messages.Add(new ChatMessage("assistant", "This course has no resources yet. Please add some resources first.", "No resources in course."));
            StateHasChanged();
            return;
        }

        // Get quiz settings
        totalQuestions = await Settings.GetQuizQuestionCountAsync();
        gradingScale = await Settings.GetGradingScaleAsync();
        currentQuestionNumber = 1;
        correctAnswers = 0;
        isQuizMode = true;
        isLessonMode = false;

        // Clear previous messages for fresh quiz
        messages.Clear();

        var quizPrompt = $@"I want to take a quiz on the curriculum material. Please quiz me with exactly {totalQuestions} questions based ONLY on the resources provided.

QUIZ RULES:
1. Ask ONE question at a time
2. Wait for my answer before asking the next question
3. After I answer, tell me if I'm correct or incorrect and briefly explain why
4. Keep track of my score
5. After all {totalQuestions} questions, provide a final summary with:
   - Total correct: X/{totalQuestions}
   - Percentage: X%
   - Areas I did well in
   - Areas I need to review



Please start with Question 1.";

        prompt = quizPrompt;
        await SendAsync();
    }

    private async Task RestartQuiz()
    {
        // Clear quiz state
        isQuizMode = false;
        currentQuestionNumber = 0;
        totalQuestions = 0;
        correctAnswers = 0;
        messages.Clear();
        
        // Restart quiz from the beginning
        await StartQuizAtCurrentPoint();
    }

    private void CancelQuiz()
    {
        // Clear quiz state and return to lesson mode
        isQuizMode = false;
        currentQuestionNumber = 0;
        totalQuestions = 0;
        correctAnswers = 0;
        messages.Add(new ChatMessage("assistant", "Quiz cancelled. You can continue with your lesson or start a new quiz anytime.", "Quiz cancelled by user."));
        StateHasChanged();
    }

    // Confirmation dialog methods
