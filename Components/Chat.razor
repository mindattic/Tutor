    private string ParseMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text))
            return "";

        // Decode any HTML entities from the AI response (e.g., &amp; -> &, &gt; -> >)
        text = System.Net.WebUtility.HtmlDecode(text);
        
        // Only escape < and > to prevent HTML injection, but preserve & for display
        // We do this selectively to avoid double-encoding
        text = text.Replace("<", "&lt;").Replace(">", "&gt;");

        // Process line by line for block elements
        var lines = text.Split('\n');
        var result = new StringBuilder();
        var inList = false;
        var listType = "";

        foreach (var line in lines)
        {
            var trimmedLine = line.TrimStart();

            // Headers (must be at start of line)
            if (trimmedLine.StartsWith("###### "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h6>{ProcessInlineMarkdown(trimmedLine.Substring(7))}</h6>");
                continue;
            }
            if (trimmedLine.StartsWith("##### "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h5>{ProcessInlineMarkdown(trimmedLine.Substring(6))}</h5>");
                continue;
            }
            if (trimmedLine.StartsWith("#### "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h4>{ProcessInlineMarkdown(trimmedLine.Substring(5))}</h4>");
                continue;
            }
            if (trimmedLine.StartsWith("### "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h3>{ProcessInlineMarkdown(trimmedLine.Substring(4))}</h3>");
                continue;
            }
            if (trimmedLine.StartsWith("## "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h2>{ProcessInlineMarkdown(trimmedLine.Substring(3))}</h2>");
                continue;
            }
            if (trimmedLine.StartsWith("# "))
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine($"<h1>{ProcessInlineMarkdown(trimmedLine.Substring(2))}</h1>");
                continue;
            }

            // Horizontal rule
            if (trimmedLine == "---" || trimmedLine == "***" || trimmedLine == "___")
            {
                CloseList(ref inList, ref listType, result);
                result.AppendLine("<hr />");
                continue;
            }

            // Unordered list items
            if (trimmedLine.StartsWith("- ") || trimmedLine.StartsWith("* "))
            {
                if (!inList || listType != "ul")
                {
                    CloseList(ref inList, ref listType, result);
                    result.AppendLine("<ul>");
                    inList = true;
                    listType = "ul";
                }
                var itemContent = ProcessInlineMarkdown(trimmedLine.Substring(2));
                result.AppendLine($"<li>{itemContent}</li>");
                continue;
            }

            // Ordered list items
            var orderedMatch = Regex.Match(trimmedLine, @"^(\d+)\.\s+(.*)$");
            if (orderedMatch.Success)
            {
                if (!inList || listType != "ol")
                {
                    CloseList(ref inList, ref listType, result);
                    result.AppendLine("<ol>");
                    inList = true;
                    listType = "ol";
                }
                var itemContent = ProcessInlineMarkdown(orderedMatch.Groups[2].Value);
                result.AppendLine($"<li>{itemContent}</li>");
                continue;
            }

            // Empty line - skip (paragraph spacing is handled by CSS)
            if (string.IsNullOrWhiteSpace(line))
            {
                CloseList(ref inList, ref listType, result);
                continue;
            }

            // Check if line is a suggested question (starts with __ or [question?])
            var trimmedLineContent = line.Trim();
            if ((trimmedLineContent.StartsWith("__") && trimmedLineContent.EndsWith("__")) ||
                (trimmedLineContent.StartsWith("[") && trimmedLineContent.EndsWith("?]")))
            {
                CloseList(ref inList, ref listType, result);
                var processed = ProcessInlineMarkdown(line);
                result.AppendLine($"<div class=\"suggested-question-wrapper\">{processed}</div>");
                continue;
            }

            // Regular paragraph
            CloseList(ref inList, ref listType, result);
            var processedParagraph = ProcessInlineMarkdown(line);
            result.AppendLine($"<p>{processedParagraph}</p>");
        }

        CloseList(ref inList, ref listType, result);
        return result.ToString();
    }

    private void CloseList(ref bool inList, ref string listType, StringBuilder result)
    {
        if (inList)
        {
            result.AppendLine(listType == "ul" ? "</ul>" : "</ol>");
            inList = false;
            listType = "";
        }
    }

    private string ProcessInlineMarkdown(string text)
    {
        // Bold with clickable term link: **text**
        // Bold text is NOT styled as a link, just the icon next to it
        text = Regex.Replace(text, @"\*\*(.+?)\*\*", match =>
        {
            var term = match.Groups[1].Value;
            var encodedTerm = System.Net.WebUtility.HtmlEncode(term);
            return $"<strong>{encodedTerm}</strong><a class=\"term-link\" onclick=\"window.askAboutTerm('{EscapeJsString(term)}')\" title=\"Learn more about {encodedTerm}\"><span class=\"icon-link\"></span></a>";
        });
        
        // Suggested question link: __text__ - renders as a blue clickable question
        text = Regex.Replace(text, @"__(.+?)__", match =>
        {
            var question = match.Groups[1].Value;
            var encodedQuestion = System.Net.WebUtility.HtmlEncode(question);
            return $"<a class=\"suggested-question\" onclick=\"window.askAboutTerm('{EscapeJsString(question)}')\" title=\"Click to ask this question\"><span class=\"bi bi-chat-right-quote\"></span> {encodedQuestion}</a>";
        });

        // Italic: *text* or _text_
        text = Regex.Replace(text, @"\*(.+?)\*", "<em>$1</em>");
        text = Regex.Replace(text, @"_(.+?)_", "<em>$1</em>");

        // Inline code: `code`
        text = Regex.Replace(text, @"`(.+?)`", "<code>$1</code>");

        // Links: [text](url) - must be processed BEFORE square bracket questions
        text = Regex.Replace(text, @"\[(.+?)\]\((.+?)\)", "<a href=\"$2\" target=\"_blank\">$1</a>");
        
        // Suggested question link: [text?] - follow-up questions in square brackets ending with ?
        // This must come AFTER markdown link processing to avoid conflicts
        text = Regex.Replace(text, @"\[([^\]\(]+\?)\]", match =>
        {
            var question = match.Groups[1].Value;
            var encodedQuestion = System.Net.WebUtility.HtmlEncode(question);
            return $"<a class=\"suggested-question\" onclick=\"window.askAboutTerm('{EscapeJsString(question)}')\" title=\"Click to ask this question\"><span class=\"bi bi-chat-right-quote\"></span> {encodedQuestion}</a>";
        });

        return text;
    }

    private string EscapeJsString(string text)
    {
        return text.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\"", "\\\"").Replace("\n", "\\n").Replace("\r", "\\r");
    }

    [JSInvokable]
    public async Task AskAboutTerm(string term)
    {
        // Track that we're exploring a term so we can go back
        if (!isTermExploration)
        {
            isTermExploration = true;
            messageIndexBeforeExploration = messages.Count;
        }

        // Build context-aware prompt for term exploration
        // Include instruction to suggest follow-up questions
        string termPrompt;
        if (learnedConcepts.Count > 0)
        {
            var learnedList = string.Join(", ", learnedConcepts);
            termPrompt = $@"What is ""{term}""? Please explain it in simple terms.

The student has already learned: {learnedList}
Connect your explanation to these concepts where relevant.

At the end, suggest THREE natural follow-up questions the student might be thinking. Format each as a clickable link on its own line:
__First specific question?__
__Second specific question?__
__Third specific question?__

The questions should be specific and relevant to what you just explained, not generic.";
        }
        else
        {
            termPrompt = $@"What is ""{term}""? Please explain it in simple terms.

At the end, suggest THREE natural follow-up questions the student might be thinking. Format each as a clickable link on its own line:
__First specific question?__
__Second specific question?__
__Third specific question?__

The questions should be specific and relevant to what you just explained, not generic.";
        }

        // Show simplified display text but send full prompt to AI
        // Clean up the term for display by removing trailing punctuation
        var cleanTerm = term.TrimEnd(':', '-', '–', '—', ',', ';', '.', '!', '?', ' ');
        var displayText = $"{cleanTerm}?";
        prompt = termPrompt;
        pendingDisplayText = displayText;
        pendingIsExploration = true;
        StateHasChanged();
        await SendAsync();
    }

    public void Dispose()
    {
        cts?.Cancel();
        cts?.Dispose();
        dotNetRef?.Dispose();
    }

    /// <summary>
    /// Represents a chat message with optional display text for UI.
    /// </summary>
    /// <param name="Role">The role (user or assistant).</param>
    /// <param name="Text">The actual message text sent to/from the AI.</param>
    /// <param name="FullJson">The full JSON response (for debugging).</param>
    /// <param name="DisplayText">Optional simplified text to show in the UI instead of Text.</param>
    /// <param name="IsExploration">Whether this message is part of a side exploration (e.g., term lookup).</param>
    public record ChatMessage(string Role, string Text, string FullJson, string? DisplayText = null, bool IsExploration = false)
    {
        /// <summary>
        /// Gets the text to display in the chat UI.
        /// Returns DisplayText if set, otherwise returns Text.
        /// </summary>
        public string VisibleText => DisplayText ?? Text;
    }
}
