    private Task SendAsync() => SendAsyncInternal(captureTopics: false);


    private async Task SendAsyncInternal(bool captureTopics)
    {
        var userText = prompt?.Trim();
        if (string.IsNullOrWhiteSpace(userText)) return;
        
        Log.Debug($"Chat: Sending message (captureTopics={captureTopics}, quizMode={isQuizMode}, lessonMode={isLessonMode})");

        prompt = "";
        await ResetTextareaHeight();
        
        // Capture pending state for this message
        var displayText = pendingDisplayText;
        var isExploration = pendingIsExploration;
        pendingDisplayText = null;
        pendingIsExploration = false;
        
        messages.Add(new ChatMessage("user", userText, userText, displayText, isExploration));
        StateHasChanged();

        isSending = true;
        cts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            var instructions = await Instructions.GetCombinedInstructionsAsync();
            
            // Use unified context for curriculum planning (captureTopics), otherwise use RAG
            string courseContext;
            if (captureTopics)
            {
                // For curriculum planning, we need to see ALL resources holistically
                Log.Debug("Chat: Using unified curriculum context for topic planning");
                courseContext = await CourseService.GetUnifiedCurriculumContextAsync(ct: cts.Token);
            }
            else
            {
                // For regular queries, use RAG to get only relevant content
                Log.Trace("Chat: Using RAG context for query");
                courseContext = await CourseService.GetRelevantContentAsync(userText, topK: 5, cts.Token);
            }

            // Build context based on mode
            string fullInstructions;
            if (isQuizMode)
            {
                Log.Debug($"Chat: Quiz mode - Question {currentQuestionNumber}/{totalQuestions}");
                var quizInstructions = $@"You are conducting a quiz. Current question: {currentQuestionNumber} of {totalQuestions}.
After the student answers, evaluate their response and indicate if it's correct or incorrect.
When evaluating, be fair but accurate - partial credit is okay for partially correct answers.
Keep track of the running score.";

                fullInstructions = string.IsNullOrEmpty(courseContext)
                    ? quizInstructions + "\n\n" + instructions
                    : courseContext + "\n\n" + quizInstructions + "\n\n" + instructions;
            }
            else if (isLessonMode && learnedConcepts.Count > 0)
            {
                var learnedContext = $"SPIRAL LEARNING CONTEXT: The student has already learned these concepts: {string.Join(", ", learnedConcepts)}. Always reference and connect to these concepts when explaining new material.";
                fullInstructions = string.IsNullOrEmpty(courseContext)
                    ? learnedContext + "\n\n" + instructions
                    : courseContext + "\n\n" + learnedContext + "\n\n" + instructions;
            }
            else
            {
                fullInstructions = string.IsNullOrEmpty(courseContext)
                    ? instructions
                    : courseContext + "\n\n" + instructions;
            }

            Log.Info($"Chat: Calling AI service ({userText.Length} chars input)");
            var reply = await Ai.GetReplyAsync(messages, fullInstructions, cts.Token);
            messages.Add(new ChatMessage("assistant", reply.Text, reply.FullJson, null, isExploration));
            Log.Info($"Chat: AI reply received ({reply.Text.Length} chars)");

            // Capture topics if this is the initial lesson request
            if (captureTopics && isLessonMode)
            {
                ParseTopicsFromResponse(reply.Text);
                Log.Info($"Chat: Parsed {lessonTopics.Count} topics from curriculum response");
                
                // If we have a pending start topic, jump to it
                if (!string.IsNullOrEmpty(pendingStartTopic) && lessonTopics.Count > 0)
                {
                    var targetIndex = FindTopicIndex(pendingStartTopic);
                    if (targetIndex >= 0)
                    {
                        Log.Debug($"Chat: Jumping to topic index {targetIndex}: {pendingStartTopic}");
                        currentLessonIndex = targetIndex;
                        hasStartedLearning = true;
                        visitedTopicIndices.Add(targetIndex);
                        pendingStartTopic = null;
                        await TeachCurrentTopic();
                        return;
                    }
                    pendingStartTopic = null;
                }
                
                // Auto-show the Table of Contents after topics are generated
                if (lessonTopics.Count > 0)
                {
                    showTableOfContents = true;
                }
            }

            // Update quiz question counter if in quiz mode
            if (isQuizMode && currentQuestionNumber < totalQuestions)
            {
                var responseText = reply.Text.ToLowerInvariant();
                var nextQuestionNum = (currentQuestionNumber + 1).ToString();
                if (responseText.Contains("question") && (responseText.Contains(nextQuestionNum) || responseText.Contains("next")))
                {
                    currentQuestionNumber++;
                }
            }
            else if (isQuizMode && currentQuestionNumber >= totalQuestions)
            {
                var responseText = reply.Text.ToLowerInvariant();
                if (responseText.Contains("final") || responseText.Contains("summary") || responseText.Contains("total"))
                {
                    Log.Info("Chat: Quiz completed");
                    isQuizMode = false;
                }
            }

            // Dynamic concept expansion: Check if the user's question might benefit from expanding the knowledge graph
            // This happens in the background and doesn't block the response
            if (activeCourse != null && !captureTopics && !isQuizMode)
            {
                _ = TryExpandConceptsAsync(userText, cts?.Token ?? CancellationToken.None);
            }
        }
        catch (OperationCanceledException)
        {
            Log.Warn("Chat: Request cancelled by user");
            messages.Add(new ChatMessage("assistant", "Request cancelled.", "Request was cancelled by user."));
        }
        catch (Exception ex)
        {
            Log.Error($"Chat: Error during message send - {ex.Message}", ex);
            messages.Add(new ChatMessage("assistant", $"Error: {ex.Message}", ex.ToString()));
        }
        finally
        {
            cts?.Dispose();
            cts = null;
            isSending = false;
            StateHasChanged();

            // Save lesson state after each interaction
            if (isLessonMode)
            {
                await SaveLessonStateAsync();
            }
        }
    }

    private void ParseTopicsFromResponse(string response)
    {
        lessonTopics.Clear();
        var lines = response.Split('\n');
        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            // Match lines like "1. Topic Name" or "1) Topic Name"
            var match = Regex.Match(trimmed, @"^\d+[\.\)]\s*(.+)$");
            if (match.Success)
            {
                var topic = match.Groups[1].Value.Trim();
                if (!string.IsNullOrEmpty(topic))
                {
                    lessonTopics.Add(topic);
                }
            }
        }
    }

    /// <summary>
    /// Find the index of a topic by name (fuzzy matching)
    /// </summary>
    private int FindTopicIndex(string targetTopic)
    {
        // First try exact match
        var exactIndex = lessonTopics.FindIndex(t => 
            t.Equals(targetTopic, StringComparison.OrdinalIgnoreCase));
        if (exactIndex >= 0) return exactIndex;

        // Try contains match (topic contains target or target contains topic)
        var containsIndex = lessonTopics.FindIndex(t => 
            t.Contains(targetTopic, StringComparison.OrdinalIgnoreCase) ||
            targetTopic.Contains(t, StringComparison.OrdinalIgnoreCase));
        if (containsIndex >= 0) return containsIndex;

        // Try word overlap matching (find best match by common words)
        var targetWords = targetTopic.ToLowerInvariant()
            .Split([' ', ',', ':', '-', '–', '—'], StringSplitOptions.RemoveEmptyEntries)
            .Where(w => w.Length > 2)
            .ToHashSet();

        int bestIndex = -1;
        int bestScore = 0;

        for (int i = 0; i < lessonTopics.Count; i++)
        {
            var topicWords = lessonTopics[i].ToLowerInvariant()
                .Split([' ', ',', ':', '-', '–', '—'], StringSplitOptions.RemoveEmptyEntries)
                .Where(w => w.Length > 2)
                .ToHashSet();

            var overlap = targetWords.Intersect(topicWords).Count();
            if (overlap > bestScore)
            {
                bestScore = overlap;
                bestIndex = i;
            }
        }

        // Only return if we have at least 2 word matches
        return bestScore >= 2 ? bestIndex : -1;
    }

    /// <summary>
    /// Attempts to dynamically expand the concept graph based on the user's query.
    /// This runs in the background and doesn't block the chat response.
    /// If the query mentions concepts related to but not in the graph, new concepts
    /// will be extracted from the course resources and added to the knowledge graph.
    /// </summary>
    private async Task TryExpandConceptsAsync(string userQuery, CancellationToken ct)
    {
        if (activeCourse == null || string.IsNullOrWhiteSpace(userQuery))
            return;

        try
        {
            // First check if expansion might be beneficial (quick heuristic check)
            var shouldExpand = await ConceptExpansionService.ShouldExpandForQueryAsync(
                userQuery,
                activeCourse.Id,
                ct);

            if (!shouldExpand)
            {
                Log.Trace($"Chat: Concept expansion not needed for query");
                return;
            }

            Log.Info($"Chat: Attempting concept expansion for query: '{userQuery}'");

            // Get context concepts (currently learned concepts in lesson mode)
            var contextConceptIds = new List<string>();
            if (isLessonMode && learnedConcepts.Count > 0)
            {
                // Try to find concept IDs that match learned topic names
                var resources = await CourseService.GetCourseResourcesAsync(activeCourse.Id);
                foreach (var resource in resources.Where(r => r.HasConceptMap))
                {
                    var conceptMap = await ConceptMapStorageService.LoadAsync(resource.ConceptMapId!, ct);
                    if (conceptMap?.Concepts != null)
                    {
                        foreach (var concept in conceptMap.Concepts)
                        {
                            if (learnedConcepts.Any(lc => 
                                concept.Title.Contains(lc, StringComparison.OrdinalIgnoreCase) ||
                                lc.Contains(concept.Title, StringComparison.OrdinalIgnoreCase)))
                            {
                                contextConceptIds.Add(concept.Id);
                            }
                        }
                    }
                }
            }

            // Request expansion
            var request = new ConceptExpansionRequest
            {
                Query = userQuery,
                CourseId = activeCourse.Id,
                ContextConceptIds = contextConceptIds,
                MaxNewConcepts = 5,
                MinConfidence = 0.7f
            };

            var result = await ConceptExpansionService.ExpandConceptsAsync(request, ct);

            if (result.Success && result.NewConcepts.Count > 0)
            {
                Log.Info($"Chat: Dynamically added {result.NewConcepts.Count} new concepts: {string.Join(", ", result.NewConcepts.Select(c => c.Title))}");
                
                // Refresh the knowledge base concepts if the modal is open
                if (showKnowledgeBase)
                {
                    await LoadKnowledgeBaseConcepts();
                    await InvokeAsync(StateHasChanged);
                }
            }
            else if (!result.Success && !string.IsNullOrEmpty(result.ErrorMessage))
            {
                Log.Warn($"Chat: Concept expansion failed - {result.ErrorMessage}");
            }
        }
        catch (OperationCanceledException)
        {
            // Cancelled, ignore
        }
        catch (Exception ex)
        {
            // Log but don't show to user - this is a background enhancement
            Log.Warn($"Chat: Background concept expansion failed - {ex.Message}");
        }
    }

