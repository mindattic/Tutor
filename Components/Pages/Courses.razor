@page "/courses"
@using Tutor.Models
@using Tutor.Services
@inject CourseService CourseService
@inject KnowledgeGraphService GraphService
@inject KnowledgeGraphBuildService BuildService
@inject SideNavService SideNavService
@inject AppUiState UiState
@inject NavigationManager Nav
@implements IDisposable

<div class="page-title">Courses</div>

<div class="course-selector-page">
    @* Graph Build Queue *@
    @if (buildStatuses.Count > 0)
    {
        <div class="graph-build-queue">
            <div class="queue-header">
                <span class="bi bi-diagram-3"></span>
                <span>Building Knowledge Graphs (@buildStatuses.Count(s => s.IsActive) active)</span>
            </div>
            @foreach (var build in buildStatuses.OrderBy(s => s.QueuedAt))
            {
                <div class="queue-item @build.Stage.ToString().ToLower()">
                    <div class="queue-item-header">
                        <span class="queue-item-title">@build.CourseName</span>
                        <span class="queue-item-stage">@build.StageDisplayName</span>
                    </div>
                    @if (build.IsActive)
                    {
                        <div class="progress-bar-container small">
                            <div class="progress-bar" style="width: @(build.Progress)%"></div>
                        </div>
                    }
                    <div class="queue-item-status">
                        @build.CurrentOperation
                        @if (build.Stage == GraphBuildStage.Complete)
                        {
                            <span class="build-stats">
                                @build.ConceptsExtracted concepts, @build.RelationshipsFound relationships
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading courses...</p>
        </div>
    }
    else if (courses.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-book"></span>
            </div>
            <h4>No Courses Available</h4>
            <p>Create a course and add resources to get started.</p>
            <a href="settings" class="settings-btn primary">
                <span class="bi bi-gear"></span> Go to Settings ? Courses
            </a>
        </div>
    }
    else if (selectedCourse == null)
    {
        <div class="course-list-view">
            <p class="section-description">Select a course to view its curriculum, or build knowledge graphs.</p>
            
            <div class="course-grid">
                @foreach (var course in courses)
                {
                    var hasGraph = courseGraphStatus.GetValueOrDefault(course.Id, false);
                    var isBuilding = BuildService.IsBuildingCourse(course.Id);
                    
                    <div class="course-card @(hasGraph ? "has-graph" : "") @(isBuilding ? "building" : "")">
                        <div class="course-icon" @onclick="@(() => SelectCourse(course))">
                            <span class="bi bi-book-fill"></span>
                        </div>
                        <div class="course-info" @onclick="@(() => SelectCourse(course))">
                            <div class="course-name">@course.Name</div>
                            @if (!string.IsNullOrEmpty(course.Description))
                            {
                                <div class="course-description">@course.Description</div>
                            }
                            <div class="course-meta">
                                <span class="meta-item">
                                    <span class="bi bi-file-text"></span> @course.ResourceIds.Count resources
                                </span>
                                @if (isBuilding)
                                {
                                    <span class="meta-item graph-building">
                                        <span class="bi bi-hourglass-split"></span> Building...
                                    </span>
                                }
                                else if (hasGraph)
                                {
                                    <span class="meta-item graph-ready">
                                        <span class="bi bi-diagram-3"></span> Graph Ready
                                    </span>
                                }
                                else
                                {
                                    <span class="meta-item graph-missing">
                                        <span class="bi bi-exclamation-circle"></span> No Graph
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="course-actions">
                            @if (!hasGraph && !isBuilding && course.ResourceIds.Count > 0)
                            {
                                <button class="icon-btn primary" title="Build Knowledge Graph" 
                                        @onclick="@(() => QueueGraphBuild(course))" @onclick:stopPropagation="true">
                                    <span class="bi bi-lightning-charge"></span>
                                </button>
                            }
                            else if (hasGraph && !isBuilding)
                            {
                                <button class="icon-btn" title="Rebuild Graph" 
                                        @onclick="@(() => QueueGraphBuild(course, rebuild: true))" @onclick:stopPropagation="true">
                                    <span class="bi bi-arrow-clockwise"></span>
                                </button>
                            }
                            <div class="course-arrow" @onclick="@(() => SelectCourse(course))">
                                <span class="bi bi-chevron-right"></span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="course-detail-view">
            <div class="course-header">
                <button class="back-btn" @onclick="DeselectCourse">
                    <span class="bi bi-arrow-left"></span> Back to Courses
                </button>
                <div class="course-title-row">
                    <h2>@selectedCourse.Name</h2>
                    @if (!string.IsNullOrEmpty(selectedCourse.Description))
                    {
                        <p class="course-desc">@selectedCourse.Description</p>
                    }
                </div>
            </div>

            @if (isLoadingGraph)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>Loading curriculum...</p>
                </div>
            }
            else if (BuildService.IsBuildingCourse(selectedCourse.Id))
            {
                <div class="graph-building-state">
                    <div class="building-header">
                        <span class="building-icon bi bi-diagram-3"></span>
                        <span class="building-title">Building Knowledge Graph</span>
                    </div>
                    @if (SelectedCourseBuildStatus != null)
                    {
                        <div class="progress-bar-container">
                            <div class="progress-bar" style="width: @(SelectedCourseBuildStatus.Progress)%"></div>
                        </div>
                        <div class="building-status">
                            <span class="status-message">@SelectedCourseBuildStatus.CurrentOperation</span>
                        </div>
                        <div class="building-step">@SelectedCourseBuildStatus.StageDisplayName</div>
                    }
                </div>
            }
            else if (graph == null)
            {
                <div class="no-graph-state">
                    <div class="empty-icon">
                        <span class="bi bi-diagram-3"></span>
                    </div>
                    <h4>Knowledge Graph Required</h4>
                    <p>Build a knowledge graph to generate the curriculum for this course.</p>
                    @if (selectedCourse.ResourceIds.Count > 0)
                    {
                        <button class="settings-btn primary" @onclick="@(() => QueueGraphBuild(selectedCourse))">
                            <span class="bi bi-lightning-charge"></span> Build Knowledge Graph
                        </button>
                    }
                    else
                    {
                        <p class="hint">Add resources to this course first.</p>
                        <a href="settings" class="settings-btn">
                            <span class="bi bi-plus-lg"></span> Add Resources
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="curriculum-view">
                    <div class="curriculum-header">
                        <div class="curriculum-stats">
                            <span class="stat">
                                <span class="stat-value">@stats.TotalConcepts</span>
                                <span class="stat-label">concepts</span>
                            </span>
                            <span class="stat">
                                <span class="stat-value">@stats.MaxDepth</span>
                                <span class="stat-label">levels</span>
                            </span>
                        </div>
                        <button class="settings-btn primary" @onclick="StartLearning">
                            <span class="bi bi-play-fill"></span> Start Learning
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
private List<Course> courses = [];
private Dictionary<string, bool> courseGraphStatus = [];
private List<GraphBuildStatus> buildStatuses = [];
private Course? selectedCourse;
private KnowledgeGraph? graph;
private KnowledgeGraphStats stats = new();
    
private bool isLoading = true;
private bool isLoadingGraph;
    
// Computed property for the current course's build status
private GraphBuildStatus? SelectedCourseBuildStatus => 
    selectedCourse != null ? BuildService.GetStatusForCourse(selectedCourse.Id) : null;

protected override async Task OnInitializedAsync()
{
        // Set up side nav for Courses tab
        UiState.SetActiveTab(TopTab.Courses);
        await SideNavService.PopulateCoursesNavAsync();

        // Subscribe to build events
        BuildService.OnStatusChanged += OnBuildStatusChanged;
        BuildService.OnBuildComplete += OnBuildComplete;

        await LoadCoursesAsync();
        RefreshBuildStatuses();
    }

    public void Dispose()
    {
        BuildService.OnStatusChanged -= OnBuildStatusChanged;
        BuildService.OnBuildComplete -= OnBuildComplete;
    }

    private void OnBuildStatusChanged(GraphBuildStatus status)
    {
        RefreshBuildStatuses();
        InvokeAsync(StateHasChanged);
    }

    private async void OnBuildComplete(string taskId)
    {
        // Refresh graph status when a build completes
        await LoadCoursesAsync();
        RefreshBuildStatuses();
        
        // If we're viewing the course that just completed, reload graph
        var completedStatus = BuildService.GetStatus(taskId);
        if (completedStatus != null && selectedCourse?.Id == completedStatus.CourseId)
        {
            await LoadGraphForSelectedCourse();
        }
        
        await InvokeAsync(StateHasChanged);
    }

    private void RefreshBuildStatuses()
    {
        buildStatuses = BuildService.GetRecentStatuses().ToList();
    }

    private async Task LoadCoursesAsync()
    {
        isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            courses = await CourseService.GetAllCoursesAsync();
            
            // Check which courses have knowledge graphs
            foreach (var course in courses)
            {
                var existingGraph = await GraphService.GetGraphForCourseAsync(course.Id);
                courseGraphStatus[course.Id] = existingGraph != null;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectCourse(Course course)
    {
        selectedCourse = course;
        isLoadingGraph = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            // Set as active course
            await CourseService.SetActiveCourseAsync(course.Id);
            await LoadGraphForSelectedCourse();
        }
        finally
        {
            isLoadingGraph = false;
        }
    }

    private async Task LoadGraphForSelectedCourse()
    {
        if (selectedCourse == null) return;

        // Load knowledge graph
        graph = await GraphService.GetGraphForCourseAsync(selectedCourse.Id);
        
        
        if (graph != null)
        {
            stats = graph.GetStats();
        }
        else
        {
            stats = new();
        }
    }

    private void DeselectCourse()
    {
        selectedCourse = null;
        graph = null;
    }

    private void QueueGraphBuild(Course course, bool rebuild = false)
    {
        BuildService.QueueGraphBuild(course.Id, course.Name, rebuild);
        RefreshBuildStatuses();
        StateHasChanged();
    }

    private void StartLearning()
    {
        // Navigate to learn page with active course set (starts from beginning)
        Nav.NavigateTo("/learn?action=lesson");
    }
}
