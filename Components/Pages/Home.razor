@page "/"
@using Tutor.Services
@using Tutor.Models
@inject NavigationManager Nav
@inject AuthenticationService AuthService
@inject CourseService CourseService
@inject ConceptMapCollectionService ConceptMapCollectionService

@if (AuthService.IsAuthenticated)
{
    <div class="home-page">
        <div class="welcome-container">
            <div class="welcome-card">
                <span class="bi bi-mortarboard-fill welcome-icon"></span>
                <h1>Welcome to Tutor</h1>
                <p class="welcome-subtitle">Your AI-Powered Learning Companion</p>
                
                @if (_loadingStats)
                {
                    <div class="stats-loading">
                        <span class="spinner-small"></span>
                        <span>Loading your library...</span>
                    </div>
                }
                else
                {
                    <div class="home-stats">
                        <div class="stat-item">
                            <span class="bi bi-journal-bookmark-fill stat-icon"></span>
                            <div class="stat-content">
                                <span class="stat-value">@_courseCount</span>
                                <span class="stat-label">Courses</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <span class="bi bi-file-earmark-text-fill stat-icon"></span>
                            <div class="stat-content">
                                <span class="stat-value">@_resourceCount</span>
                                <span class="stat-label">Resources</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <span class="bi bi-diagram-3-fill stat-icon"></span>
                            <div class="stat-content">
                                <span class="stat-value">@FormatNumber(_conceptCount)</span>
                                <span class="stat-label">Concepts</span>
                            </div>
                        </div>
                    </div>
                }
                
                <button class="auth-btn primary" @onclick="GoToLearn">
                    <span class="bi bi-book"></span>
                    <span>Start Learning</span>
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="home-page">
        <div class="auth-container">
            <div class="auth-card">
                <div class="auth-header">
                    <span class="bi bi-mortarboard-fill auth-icon"></span>
                    <h1>Welcome to Tutor</h1>
                    <p class="auth-subtitle">Your AI-Powered Learning Companion</p>
                </div>

                <div class="auth-form">
                    <h2>Login</h2>
                    
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="auth-error">
                            <span class="bi bi-exclamation-triangle"></span>
                            @_errorMessage
                        </div>
                    }

                    <div class="form-group">
                        <label for="username">Username</label>
                        <input type="text" id="username" @bind="_username" @bind:event="oninput" 
                               placeholder="Enter your username" disabled="@_processing" />
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" @bind="_password" @bind:event="oninput" 
                               placeholder="Enter your password" disabled="@_processing" 
                               @onkeydown="HandleKeyDown" />
                    </div>

                    <button class="auth-btn primary" @onclick="LoginAsync" disabled="@_processing">
                        @if (_processing)
                        {
                            <span class="spinner-small"></span>
                        }
                        else
                        {
                            <span class="bi bi-box-arrow-in-right"></span>
                        }
                        <span>Login</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
private bool _processing;
private string _username = "";
private string _password = "";
private string? _errorMessage;
    
// Stats
private bool _loadingStats = true;
private int _courseCount;
private int _resourceCount;
private int _conceptCount;

protected override async Task OnInitializedAsync()
{
    if (AuthService.IsAuthenticated)
    {
        await LoadStatsAsync();
    }
}

    private async Task LoadStatsAsync()
    {
        _loadingStats = true;
        try
        {
            var courses = await CourseService.GetAllCoursesAsync();
            var resources = await CourseService.GetAllResourcesAsync();
            
            _courseCount = courses.Count;
            _resourceCount = resources.Count;
            
            // Count concepts from all concept map collections
            _conceptCount = 0;
            foreach (var course in courses)
            {
                // Collection ID is based on course ID
                var collectionId = $"collection_{course.Id}";
                var loadedCollection = await ConceptMapCollectionService.LoadWithConceptMapsAsync(collectionId);
                if (loadedCollection != null)
                {
                    foreach (var cm in loadedCollection.ConceptMaps)
                    {
                        _conceptCount += cm.Concepts.Count;
                    }
                }
            }
        }
        catch
        {
            // Silently fail - show zeros
        }
        finally
        {
            _loadingStats = false;
        }
    }

private static string FormatNumber(int number)
{
    return number.ToString("N0");
}

private void GoToLearn()
{
    Nav.NavigateTo("/learn");
}

private async Task LoginAsync()
    {
        _errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(_username))
        {
            _errorMessage = "Please enter your username.";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Please enter your password.";
            return;
        }

        _processing = true;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(_username.Trim(), _password);
            
            if (result.Success)
            {
                Nav.NavigateTo("/learn");
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Login failed.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        
        _processing = false;
        _password = "";
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = LoginAsync();
        }
    }
}
