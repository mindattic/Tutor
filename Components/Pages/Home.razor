@page "/"
@using Tutor.Services
@inject NavigationManager Nav
@inject AuthenticationService AuthService

<div class="home-page">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <span class="bi bi-mortarboard-fill auth-icon"></span>
                <h1>Welcome to Tutor</h1>
                <p class="auth-subtitle">Your AI-Powered Learning Companion</p>
            </div>

            <div class="auth-form">
                <h2>Login</h2>
                
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="auth-error">
                        <span class="bi bi-exclamation-triangle"></span>
                        @_errorMessage
                    </div>
                }

                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" @bind="_username" @bind:event="oninput" 
                           placeholder="Enter your username" disabled="@_processing" />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" @bind="_password" @bind:event="oninput" 
                           placeholder="Enter your password" disabled="@_processing" 
                           @onkeydown="HandleKeyDown" />
                </div>

                <button class="auth-btn primary" @onclick="LoginAsync" disabled="@_processing">
                    @if (_processing)
                    {
                        <span class="spinner-small"></span>
                    }
                    else
                    {
                        <span class="bi bi-box-arrow-in-right"></span>
                    }
                    <span>Login</span>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _processing;
    private string _username = "";
    private string _password = "";
    private string? _errorMessage;

    private async Task LoginAsync()
    {
        _errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(_username))
        {
            _errorMessage = "Please enter your username.";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Please enter your password.";
            return;
        }

        _processing = true;
        StateHasChanged();

        try
        {
            var result = await AuthService.LoginAsync(_username.Trim(), _password);
            
            if (result.Success)
            {
                Nav.NavigateTo("/learn");
            }
            else
            {
                _errorMessage = result.ErrorMessage ?? "Login failed.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
        }
        
        _processing = false;
        _password = "";
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = LoginAsync();
        }
    }
}
