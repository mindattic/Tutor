        geminiApiKey = "";
    }

    private async Task SaveApiKeyAsync(string keyName, string keyValue, string modelName)
    {
        var trimmed = (keyValue ?? "").Trim();
        if (string.IsNullOrWhiteSpace(trimmed))
        {
            status = $"{modelName} API key is empty.";
            return;
        }

        isBusy = true;
        try
        {
            await SecureStorage.SetAsync(keyName, trimmed);
            status = $"{modelName} API key saved.";
        }
        catch (Exception ex)
        {
            status = "Save failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ClearApiKeyAsync(string keyName, string modelName)
    {
        isBusy = true;
        try
        {
            SecureStorage.Remove(keyName);
            status = $"{modelName} API key cleared.";
        }
        catch (Exception ex)
        {
            status = "Clear failed: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
        await Task.CompletedTask;
    }

    private async Task LoadEnterToSendAsync()
    {
        try
        {
            var value = await SecureStorage.GetAsync(EnterToSendKey);
            enterToSend = string.IsNullOrEmpty(value) || value == "true";
        }
        catch
        {
            enterToSend = true;
        }
    }

    private async Task SaveEnterToSendAsync()
    {
        try
        {
            await SecureStorage.SetAsync(EnterToSendKey, enterToSend.ToString().ToLower());
            status = enterToSend ? "Enter to send enabled." : "Enter to send disabled.";
        }
        catch (Exception ex)
        {
            status = "Save failed: " + ex.Message;
        }
    }

    private static string MaskKey(string key)
    {
        if (key.Length <= 12) return new string('*', key.Length);

        var start = key.Substring(0, 6);
        var end = key.Substring(key.Length - 4, 4);
        return start + "..." + end;
    }
}
