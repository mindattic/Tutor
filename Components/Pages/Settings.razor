    public void Dispose()
    {
        Log.Store.EntryAdded -= OnLogEntryAdded;
        Log.Store.EntriesCleared -= OnLogsCleared;
    }
    
    private async Task LoadLogLevelSettingsAsync()
    {
        logTraceEnabled = await SettingsService.GetLogTraceEnabledAsync();
        logDebugEnabled = await SettingsService.GetLogDebugEnabledAsync();
        logInfoEnabled = await SettingsService.GetLogInfoEnabledAsync();
        logWarningEnabled = await SettingsService.GetLogWarningEnabledAsync();
        logErrorEnabled = await SettingsService.GetLogErrorEnabledAsync();
        logCriticalEnabled = await SettingsService.GetLogCriticalEnabledAsync();
    }
    
    private async Task ToggleLogLevel(LogSeverity severity, bool enabled)
    {
        switch (severity)
        {
            case LogSeverity.Trace:
                logTraceEnabled = enabled;
                await SettingsService.SetLogTraceEnabledAsync(enabled);
                break;
            case LogSeverity.Debug:
                logDebugEnabled = enabled;
                await SettingsService.SetLogDebugEnabledAsync(enabled);
                break;
            case LogSeverity.Information:
                logInfoEnabled = enabled;
                await SettingsService.SetLogInfoEnabledAsync(enabled);
                break;
            case LogSeverity.Warning:
                logWarningEnabled = enabled;
                await SettingsService.SetLogWarningEnabledAsync(enabled);
                break;
            case LogSeverity.Error:
                logErrorEnabled = enabled;
                await SettingsService.SetLogErrorEnabledAsync(enabled);
                break;
            case LogSeverity.Critical:
                logCriticalEnabled = enabled;
                await SettingsService.SetLogCriticalEnabledAsync(enabled);
                break;
        }
        status = $"{severity} logging {(enabled ? "enabled" : "disabled")}.";
    }

    private void OnLogEntryAdded(object? sender, LogEntry entry)
    {
        InvokeAsync(() =>
        {
            LoadLogs();
            StateHasChanged();
        });
    }

    private void OnLogsCleared(object? sender, EventArgs e)
    {
