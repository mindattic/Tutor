    private List<(string Letter, string Range)> GetGradingPreview()
    {
        return gradingScale switch
        {
            GradingScale.Standard => new List<(string, string)>
            {
                ("A", "90-100%"), ("B", "80-89%"), ("C", "70-79%"), ("D", "60-69%"), ("F", "0-59%")
