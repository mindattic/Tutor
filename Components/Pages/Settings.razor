@page "/settings"
@using Microsoft.Maui.Storage
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Tutor.Services
@using Tutor.Services.Logging
@inject NavigationManager Nav
@inject ThemeService ThemeService
@inject SettingsService SettingsService
@inject FileResourceService FileResourceService
@inject SideNavService SideNavService
@inject AppUiState UiState
@inject IJSRuntime JS
@inject LogStorageService LogStorageService
@inject KnowledgeBaseStorageService KnowledgeBaseStorageService
@implements IDisposable


<div class="page-title">Settings</div>

<div style="max-width: 720px;">
    <div class="tabs">
        <button class="tab @(activeTab == "General" ? "active" : "")" @onclick="@(() => activeTab = "General")">General</button>
        <button class="tab @(activeTab == "Appearance" ? "active" : "")" @onclick="@(() => activeTab = "Appearance")">Appearance</button>
        <button class="tab @(activeTab == "Storage" ? "active" : "")" @onclick="@(() => activeTab = "Storage")">Storage</button>
        <button class="tab @(activeTab == "Quiz" ? "active" : "")" @onclick="@(() => activeTab = "Quiz")">Quiz</button>
        <button class="tab @(activeTab == "Credentials" ? "active" : "")" @onclick="@(() => activeTab = "Credentials")">Credentials</button>
        <button class="tab @(activeTab == "Logs" ? "active" : "")" @onclick="@(() => activeTab = "Logs")">Logs</button>
        <button class="tab @(activeTab == "About" ? "active" : "")" @onclick="@(() => activeTab = "About")">About</button>
    </div>

    <div class="tab-content">
        @if (activeTab == "General")
        {
            <div class="settings-section">
                <h4>Theme</h4>
                <select class="theme-select" @bind="selectedTheme" @bind:after="SaveThemeAsync">
                    @foreach (var theme in ThemeService.AvailableThemes)
                    {
                        <option value="@theme">@theme</option>
                    }
                </select>
                <p>Choose a color theme for the application.</p>
            </div>

            <div class="settings-section">
                <h4>Active AI Model</h4>
                <select class="theme-select" @bind="selectedModel" @bind:after="SaveSelectedModelAsync">
                    <option value="ChatGPT">ChatGPT (OpenAI)</option>
                    <option value="Claude">Claude (Anthropic)</option>
                    <option value="Gemini">Gemini (Google)</option>
                </select>
                <p>Select which AI model to use for chat.</p>
            </div>

            <div class="settings-section">
                <h4>Chat Behavior</h4>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="enterToSend" @bind="enterToSend" @bind:after="SaveEnterToSendAsync" style="width: 18px; height: 18px;" />
                    <label for="enterToSend">Press Enter to send message</label>
                </div>
                <p>When enabled, press Enter to send. Use Shift+Enter for new line.</p>
            </div>
        }
        else if (activeTab == "Appearance")
        {
            <div class="settings-section">
                <h4>User Avatar</h4>
                <div class="avatar-settings-row">
                    <div class="avatar-preview user">
                        @if (!string.IsNullOrEmpty(userCustomAvatar))
                        {
                            <img src="@userCustomAvatar" alt="User" />
                        }
                        else
                        {
                            <span class="bi @userAvatarIcon"></span>
                        }
                    </div>
                    <div class="avatar-controls">
                        <div class="avatar-name-row">
                            <label>Display Name:</label>
                            <input type="text" class="settings-input small" @bind="userDisplayName" @bind:after="SaveUserDisplayNameAsync" placeholder="User" />
                        </div>
                        <div class="avatar-icon-row">
                            <label>Icon:</label>
                            <select class="theme-select small" @bind="userAvatarIcon" @bind:after="SaveUserAvatarIconAsync">
                                @foreach (var icon in AvailableAvatarIcons)
                                {
                                    <option value="@icon.Value">@icon.Name</option>
                                }
                            </select>
                        </div>
                        <div class="avatar-actions">
                            <label class="settings-btn upload-btn">
                                <span class="bi bi-upload"></span> Upload Image
                                <InputFile OnChange="OnUserAvatarUpload" accept="image/*" style="display: none;" />
                            </label>
                            @if (!string.IsNullOrEmpty(userCustomAvatar))
                            {
                                <button class="settings-btn danger small" @onclick="ClearUserCustomAvatar">
                                    <span class="bi bi-x"></span> Clear
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Assistant Avatar</h4>
                <div class="avatar-settings-row">
                    <div class="avatar-preview assistant">
                        @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                        {
                            <img src="@assistantCustomAvatar" alt="Assistant" />
                        }
                        else
                        {
                            <span class="bi @assistantAvatarIcon"></span>
                        }
                    </div>
                    <div class="avatar-controls">
                        <div class="avatar-name-row">
                            <label>Display Name:</label>
                            <input type="text" class="settings-input small" @bind="assistantDisplayName" @bind:after="SaveAssistantDisplayNameAsync" placeholder="Assistant" />
                        </div>
                        <div class="avatar-icon-row">
                            <label>Icon:</label>
                            <select class="theme-select small" @bind="assistantAvatarIcon" @bind:after="SaveAssistantAvatarIconAsync">
                                @foreach (var icon in AvailableAvatarIcons)
                                {
                                    <option value="@icon.Value">@icon.Name</option>
                                }
                            </select>
                        </div>
                        <div class="avatar-actions">
                            <label class="settings-btn upload-btn">
                                <span class="bi bi-upload"></span> Upload Image
                                <InputFile OnChange="OnAssistantAvatarUpload" accept="image/*" style="display: none;" />
                            </label>
                            @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                            {
                                <button class="settings-btn danger small" @onclick="ClearAssistantCustomAvatar">
                                    <span class="bi bi-x"></span> Clear
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Border Radius</h4>
                <div class="slider-row">
                    <input type="range" min="0" max="10" step="1" @bind="borderRadius" @bind:after="SaveBorderRadiusAsync" class="settings-slider" />
                    <span class="slider-value">@(borderRadius)px</span>
                </div>
                <p>Adjust the corner roundness for buttons, inputs, and cards (0px = square, 10px = rounded).</p>
            </div>

            <div class="settings-section">
                <h4>Date & Time Format</h4>
                <select class="theme-select" @bind="dateFormat" @bind:after="SaveDateFormatAsync">
                    <option value="yyyy-MM-dd hh:mm:ss tt">2024-01-15 06:30:45 PM (Default)</option>
                    <option value="yyyy-MM-dd HH:mm:ss">2024-01-15 18:30:45 (24-hour)</option>
                    <option value="MM/dd/yyyy hh:mm:ss tt">01/15/2024 06:30:45 PM (US)</option>
                    <option value="dd/MM/yyyy HH:mm:ss">15/01/2024 18:30:45 (EU)</option>
                    <option value="MMM dd, yyyy h:mm tt">Jan 15, 2024 6:30 PM (Short)</option>
                    <option value="MMMM dd, yyyy h:mm:ss tt">January 15, 2024 6:30:45 PM (Long)</option>
                    <option value="yyyy-MM-dd HH:mm:ss.fff">2024-01-15 18:30:45.123 (ISO with ms)</option>
                </select>
                <p>Preview: <code>@GetDateFormatPreview()</code></p>
                <p class="settings-hint">This format is used throughout the app for displaying dates and times.</p>
            </div>

            <div class="settings-section">
                <h4>Preview</h4>
                <div class="chat-preview">
                    <div class="preview-msg user">
                        <div class="preview-avatar user">
                            @if (!string.IsNullOrEmpty(userCustomAvatar))
                            {
                                <img src="@userCustomAvatar" alt="User" />
                            }
                            else
                            {
                                <span class="bi @userAvatarIcon"></span>
                            }
                        </div>
                        <div class="preview-content">
                            <span class="preview-name">@userDisplayName</span>
                            <span class="preview-text">Hello, can you help me?</span>
                        </div>
                    </div>
                    <div class="preview-msg assistant">
                        <div class="preview-avatar assistant">
                            @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                            {
                                <img src="@assistantCustomAvatar" alt="Assistant" />
                            }
                            else
                            {
                                <span class="bi @assistantAvatarIcon"></span>
                            }
                        </div>
                        <div class="preview-content">
                            <span class="preview-name">@assistantDisplayName</span>
                            <span class="preview-text">Of course! I'm here to help.</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "Storage")
        {
            <div class="settings-section">
                <h4>Learning Resources Directory</h4>
                <div class="path-input-row">
                    <input type="text" class="settings-input path-input" value="@learningResourcesPath" readonly />
                    <button class="settings-btn" @onclick="OpenResourcesFolder" title="Open folder">
                        <span class="bi bi-folder2-open"></span>
                    </button>
                </div>
                <p>Learning resources are saved to this folder and can be checked into GitHub.</p>
                
                <div class="folder-stats">
                    <div class="stat-item">
                        <span class="stat-label">Original files:</span>
                        <span class="stat-value">@originalFileCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Formatted files:</span>
                        <span class="stat-value">@formattedFileCount</span>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Storage Options</h4>
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                    <input type="checkbox" id="saveFormatted" @bind="saveFormattedAsMarkdown" @bind:after="SaveStorageOptionsAsync" style="width: 18px; height: 18px;" />
                    <label for="saveFormatted">Save formatted resources as .md files</label>
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="preserveOriginal" @bind="preserveOriginalFiles" @bind:after="SaveStorageOptionsAsync" style="width: 18px; height: 18px;" />
                    <label for="preserveOriginal">Preserve original uploaded files</label>
                </div>
                <p>These options control how resources are saved to the file system.</p>
            </div>

            <div class="settings-section">
                <h4>Knowledge Bases Directory</h4>
                <div class="path-input-row">
                    <input type="text" class="settings-input path-input" value="@knowledgeBasesPath" readonly />
                    <button class="settings-btn" @onclick="OpenKnowledgeBasesFolder" title="Open folder">
                        <span class="bi bi-folder2-open"></span>
                    </button>
                </div>
                <p>Knowledge bases contain extracted concepts and relationships for courses.</p>
                
                <div class="folder-stats">
                    <div class="stat-item">
                        <span class="stat-label">Knowledge bases:</span>
                        <span class="stat-value">@knowledgeBaseCount</span>
                    </div>
                </div>

                @if (knowledgeBases.Count > 0)
                {
                    <div class="kb-list" style="margin-top: 15px;">
                        <table class="kb-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Concepts</th>
                                    <th>Relations</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kb in knowledgeBases)
                                {
                                    <tr>
                                        <td>@kb.Name</td>
                                        <td>@kb.ConceptCount</td>
                                        <td>@kb.RelationCount</td>
                                        <td>
                                            <span class="kb-status @kb.Status.ToString().ToLower()">@kb.Status</span>
                                        </td>
                                        <td>
                                            <button class="btn-icon-small danger" @onclick="() => DeleteKnowledgeBaseAsync(kb.Id)" title="Delete">
                                                <span class="bi bi-trash"></span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="settings-section">
                <h4>Folder Structure</h4>
                <div class="folder-tree">
                    <div class="folder-item">📁 Resources/</div>
                    <div class="folder-item indent">📁 Original/ - Original uploaded files</div>
                    <div class="folder-item indent">📁 Formatted/ - AI-formatted markdown files</div>
                    <div class="folder-item indent">📁 Courses/ - Course definitions</div>
                    <div class="folder-item">📁 KnowledgeBases/ - AI-generated concept graphs</div>
                </div>
            </div>
        }
        else if (activeTab == "Quiz")
        {
            <div class="settings-section">
                <h4>Number of Quiz Questions</h4>
                <select class="theme-select" @bind="quizQuestionCount" @bind:after="SaveQuizQuestionCountAsync">
                    <option value="3">3 questions</option>
                    <option value="5">5 questions</option>
                    <option value="10">10 questions</option>
                    <option value="15">15 questions</option>
                    <option value="20">20 questions</option>
                </select>
                <p>Select how many questions to include in each quiz.</p>
            </div>

            <div class="settings-section">
                <h4>Grading Scale</h4>
                <select class="theme-select" @bind="gradingScale" @bind:after="SaveGradingScaleAsync">
                    <option value="Standard">Standard (A=90%, B=80%, C=70%, D=60%)</option>
                    <option value="PlusMinus">Plus/Minus (A+, A, A-, B+, etc.)</option>
                    <option value="Lenient">Lenient (A=85%, B=75%, C=65%, D=55%)</option>
                    <option value="Strict">Strict (A=95%, B=85%, C=75%, D=65%)</option>
                </select>
                <p>Choose the grading scale for quiz results.</p>
            </div>

            <div class="settings-section">
                <h4>Grading Scale Preview</h4>
                <div class="grading-preview">
                    @foreach (var grade in GetGradingPreview())
                    {
                        <div class="grade-item">
                            <span class="grade-letter">@grade.Letter</span>
                            <span class="grade-range">@grade.Range</span>
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "Credentials")
        {
            <div class="settings-section">
                <h4>OpenAI (ChatGPT)</h4>
                <div class="credential-row">
                    <div class="credential-input-group">
                        <label>API Key</label>
                        <input type="password"
                               class="settings-input"
                               @bind="chatGptApiKey"
                               placeholder="sk-..." />
                    </div>
                    <div class="credential-actions">
                        <button class="settings-btn small" @onclick="SaveChatGptKeyAsync" disabled="@isBusy">Save</button>
                        <button class="settings-btn small" @onclick="ClearChatGptKeyAsync" disabled="@isBusy">Clear</button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(chatGptKeyPreview))
                {
                    <p class="key-preview">Stored: <code>@chatGptKeyPreview</code></p>
                }
                <div class="credential-model-row">
                    <label>Model:</label>
                    <select class="theme-select small" @bind="chatGptModel" @bind:after="SaveChatGptModelAsync">
                        <option value="gpt-4.1-mini">GPT-4.1 Mini</option>
                        <option value="gpt-4.1">GPT-4.1</option>
                        <option value="gpt-4o">GPT-4o</option>
                        <option value="gpt-4o-mini">GPT-4o Mini</option>
                    </select>
                </div>
                <p class="credential-link">Get your key from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a></p>
            </div>

            <div class="settings-section">
                <h4>Anthropic (Claude) <span class="coming-soon-badge">Coming Soon</span></h4>
                <div class="credential-row">
                    <div class="credential-input-group">
                        <label>API Key</label>
                        <input type="password"
                               class="settings-input"
                               @bind="claudeApiKey"
                               placeholder="sk-ant-..." />
                    </div>
                    <div class="credential-actions">
                        <button class="settings-btn small" @onclick="SaveClaudeKeyAsync" disabled="@isBusy">Save</button>
                        <button class="settings-btn small" @onclick="ClearClaudeKeyAsync" disabled="@isBusy">Clear</button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(claudeKeyPreview))
                {
                    <p class="key-preview">Stored: <code>@claudeKeyPreview</code></p>
                }
                <p class="credential-link">Get your key from <a href="https://console.anthropic.com/" target="_blank">Anthropic Console</a></p>
            </div>

            <div class="settings-section">
                <h4>Google AI (Gemini) <span class="coming-soon-badge">Coming Soon</span></h4>
                <div class="credential-row">
                    <div class="credential-input-group">
                        <label>API Key</label>
                        <input type="password"
                               class="settings-input"
                               @bind="geminiApiKey"
                               placeholder="AIza..." />
                    </div>
                    <div class="credential-actions">
                        <button class="settings-btn small" @onclick="SaveGeminiKeyAsync" disabled="@isBusy">Save</button>
                        <button class="settings-btn small" @onclick="ClearGeminiKeyAsync" disabled="@isBusy">Clear</button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(geminiKeyPreview))
                {
                    <p class="key-preview">Stored: <code>@geminiKeyPreview</code></p>
                }
                <p class="credential-link">Get your key from <a href="https://aistudio.google.com/apikey" target="_blank">Google AI Studio</a></p>
            </div>

            @if (!string.IsNullOrWhiteSpace(status))
            {
                <div class="status-message @(status.Contains("Error") || status.Contains("failed") ? "error" : "success")">
                    @status
                </div>
            }
        }
        else if (activeTab == "Logs")
        {
            <div class="settings-section">
                <h4>Log Level Settings</h4>
                <p class="settings-hint">Enable or disable logging for each severity level. Disabled levels won't be captured.</p>
                <div class="log-level-toggles">
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logTraceEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Trace, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge trace">Trace</span>
                        <span class="level-desc">Detailed diagnostic information</span>
                    </label>
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logDebugEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Debug, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge debug">Debug</span>
                        <span class="level-desc">Debug information for development</span>
                    </label>
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logInfoEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Information, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge info">Info</span>
                        <span class="level-desc">General operational messages</span>
                    </label>
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logWarningEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Warning, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge warning">Warning</span>
                        <span class="level-desc">Potential issues or unexpected behavior</span>
                    </label>
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logErrorEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Error, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge error">Error</span>
                        <span class="level-desc">Operation failures</span>
                    </label>
                    <label class="log-level-toggle">
                        <input type="checkbox" checked="@logCriticalEnabled" @onchange="@(e => ToggleLogLevel(LogSeverity.Critical, (bool)(e.Value ?? false)))" />
                        <span class="severity-badge critical">Critical</span>
                        <span class="level-desc">Critical errors (always recommended)</span>
                    </label>
                </div>
            </div>

            <div class="settings-section">
                <h4>Log Viewer</h4>
                <div class="log-controls">
                    <div class="log-filters">
                        <label class="filter-label">Display Filter:</label>
                        @foreach (var severity in Enum.GetValues<LogSeverity>())
                        {
                            <label class="filter-checkbox">
                                <input type="checkbox" 
                                       checked="@logFilters.Contains(severity)"
                                       @onchange="@(e => ToggleLogFilter(severity, (bool)(e.Value ?? false)))" />
                                <span class="severity-badge @severity.ToString().ToLower()">@severity</span>
                            </label>
                        }
                    </div>
                    <div class="log-actions">
                        <button class="settings-btn small" @onclick="RefreshLogs">
                            <span class="bi bi-arrow-clockwise"></span> Refresh
                        </button>
                        <button class="settings-btn danger small" @onclick="ClearLogs">
                            <span class="bi bi-trash"></span> Clear All
                        </button>
                    </div>
                </div>
                <p class="log-count">Showing @filteredLogs.Count of @totalLogCount entries</p>
            </div>

            <div class="log-viewer">
                @if (filteredLogs.Count == 0)
                {
                    <div class="log-empty">
                        <span class="bi bi-journal-text"></span>
                        <p>No log entries to display.</p>
                    </div>
                }
                else
                {
                    @foreach (var entry in filteredLogs)
                    {
                        <div class="log-entry @entry.SeverityCssClass">
                            <div class="log-entry-header">
                                <span class="log-severity">
                                    <span class="bi @entry.SeverityIcon"></span>
                                    @entry.Severity
                                </span>
                                <span class="log-timestamp">@entry.TimestampDisplay</span>
                            </div>
                            <div class="log-message">@entry.Message</div>
                            @if (!string.IsNullOrEmpty(entry.SourceDisplay))
                            {
                                <div class="log-source">@entry.SourceDisplay</div>
                            }
                            @if (entry.Exception != null)
                            {
                                <div class="log-exception">
                                    <strong>@entry.Exception.GetType().Name:</strong> @entry.Exception.Message
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }
        else if (activeTab == "About")
        {
            <div class="settings-section">
                <h4>Tutor</h4>
                <p>Version 1.0.0</p>
                <p>A multi-model AI chat application built with .NET MAUI Blazor.</p>
            </div>

            <div class="settings-section">
                <h4>Supported Models</h4>
                <p>• ChatGPT (OpenAI) - Active</p>
                <p>• Claude (Anthropic) - Coming Soon</p>
                <p>• Gemini (Google) - Coming Soon</p>
            </div>

            <div class="settings-section">
                <h4>Links</h4>
                <p><a href="https://github.com/mindattic/Tutor" target="_blank">GitHub Repository</a></p>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(status))
    {
        <p style="color: var(--text-secondary); margin-top: 16px;">@status</p>
    }
</div>


@code
{
    private const string SelectedModelKey = "SELECTED_MODEL";
    private const string ChatGptApiKeyName = "OPENAI_API_KEY";
    private const string ClaudeApiKeyName = "CLAUDE_API_KEY";
    private const string GeminiApiKeyName = "GEMINI_API_KEY";
    private const string EnterToSendKey = "ENTER_TO_SEND";
    private const string ChatGptModelKey = "CHATGPT_MODEL";

    private string activeTab = "General";
    private string selectedTheme = "Light";
    private string selectedModel = "ChatGPT";
    private string chatGptModel = "gpt-4.1-mini";
    private string chatGptApiKey = "";
    private string claudeApiKey = "";
    private string geminiApiKey = "";
    private string chatGptKeyPreview = "";
    private string claudeKeyPreview = "";
    private string geminiKeyPreview = "";
    private string status = "";
    private bool isBusy;
    private bool enterToSend = true;
    
    // Quiz settings
    private int quizQuestionCount = 3;
    private GradingScale gradingScale = GradingScale.Standard;

    // Log settings - display filters
    private HashSet<LogSeverity> logFilters = [LogSeverity.Information, LogSeverity.Warning, LogSeverity.Error, LogSeverity.Critical];
    private List<LogEntry> filteredLogs = [];
    private int totalLogCount = 0;
    
    // Log settings - capture toggles
    private bool logTraceEnabled = false;
    private bool logDebugEnabled = true;
    private bool logInfoEnabled = true;
    private bool logWarningEnabled = true;
    private bool logErrorEnabled = true;
    private bool logCriticalEnabled = true;


    // Storage settings
    private string learningResourcesPath = "";
    private bool saveFormattedAsMarkdown = true;
    private bool preserveOriginalFiles = true;
    private int originalFileCount = 0;
    private int formattedFileCount = 0;

    // Knowledge Base storage settings
    private string knowledgeBasesPath = "";
    private int knowledgeBaseCount = 0;
    private List<KnowledgeBaseSummary> knowledgeBases = [];


