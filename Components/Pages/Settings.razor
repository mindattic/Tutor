            GradingScale.PlusMinus => new List<(string, string)>
            {
                ("A+", "97-100%"), ("A", "93-96%"), ("A-", "90-92%"),
                ("B+", "87-89%"), ("B", "83-86%"), ("B-", "80-82%"),
                ("C+", "77-79%"), ("C", "73-76%"), ("C-", "70-72%"),
                ("D+", "67-69%"), ("D", "63-66%"), ("D-", "60-62%"),
                ("F", "0-59%")
            },
            GradingScale.Lenient => new List<(string, string)>
            {
                ("A", "85-100%"), ("B", "75-84%"), ("C", "65-74%"), ("D", "55-64%"), ("F", "0-54%")
            },
            GradingScale.Strict => new List<(string, string)>
            {
                ("A", "95-100%"), ("B", "85-94%"), ("C", "75-84%"), ("D", "65-74%"), ("F", "0-64%")
            },
            _ => new List<(string, string)>()
