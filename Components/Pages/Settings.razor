    private async Task<string> LoadKeyPreviewAsync(string keyName)
    {
        try
        {
            var key = await SecureStorage.GetAsync(keyName);
            return string.IsNullOrWhiteSpace(key) ? "" : MaskKey(key);
        }
        catch
        {
            return "";
        }
    }

