@page "/settings"
@using Microsoft.Maui.Storage
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Forms
@using Tutor.Services
@inject NavigationManager Nav
@inject ThemeService ThemeService
@inject SettingsService SettingsService
@inject FileResourceService FileResourceService
@inject IJSRuntime JS


<div class="page-title">Settings</div>

<div style="max-width: 720px;">
    <div class="tabs">
        <button class="tab @(activeTab == "General" ? "active" : "")" @onclick="@(() => activeTab = "General")">General</button>
        <button class="tab @(activeTab == "Appearance" ? "active" : "")" @onclick="@(() => activeTab = "Appearance")">Appearance</button>
        <button class="tab @(activeTab == "Storage" ? "active" : "")" @onclick="@(() => activeTab = "Storage")">Storage</button>
        <button class="tab @(activeTab == "Quiz" ? "active" : "")" @onclick="@(() => activeTab = "Quiz")">Quiz</button>
        <button class="tab @(activeTab == "ChatGPT" ? "active" : "")" @onclick="@(() => activeTab = "ChatGPT")">ChatGPT</button>
        <button class="tab @(activeTab == "Claude" ? "active" : "")" @onclick="@(() => activeTab = "Claude")">Claude</button>
        <button class="tab @(activeTab == "Gemini" ? "active" : "")" @onclick="@(() => activeTab = "Gemini")">Gemini</button>
        <button class="tab @(activeTab == "About" ? "active" : "")" @onclick="@(() => activeTab = "About")">About</button>
    </div>

    <div class="tab-content">
        @if (activeTab == "General")
        {
            <div class="settings-section">
                <h4>Theme</h4>
                <select class="theme-select" @bind="selectedTheme" @bind:after="SaveThemeAsync">
                    @foreach (var theme in ThemeService.AvailableThemes)
                    {
                        <option value="@theme">@theme</option>
                    }
                </select>
                <p>Choose a color theme for the application.</p>
            </div>

            <div class="settings-section">
                <h4>Active AI Model</h4>
                <select class="theme-select" @bind="selectedModel" @bind:after="SaveSelectedModelAsync">
                    <option value="ChatGPT">ChatGPT (OpenAI)</option>
                    <option value="Claude">Claude (Anthropic)</option>
                    <option value="Gemini">Gemini (Google)</option>
                </select>
                <p>Select which AI model to use for chat.</p>
            </div>

            <div class="settings-section">
                <h4>Chat Behavior</h4>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="enterToSend" @bind="enterToSend" @bind:after="SaveEnterToSendAsync" style="width: 18px; height: 18px;" />
                    <label for="enterToSend">Press Enter to send message</label>
                </div>
                <p>When enabled, press Enter to send. Use Shift+Enter for new line.</p>
            </div>
        }
        else if (activeTab == "Appearance")
        {
            <div class="settings-section">
                <h4>User Avatar</h4>
                <div class="avatar-settings-row">
                    <div class="avatar-preview user">
                        @if (!string.IsNullOrEmpty(userCustomAvatar))
                        {
                            <img src="@userCustomAvatar" alt="User" />
                        }
                        else
                        {
                            <span class="bi @userAvatarIcon"></span>
                        }
                    </div>
                    <div class="avatar-controls">
                        <div class="avatar-name-row">
                            <label>Display Name:</label>
                            <input type="text" class="settings-input small" @bind="userDisplayName" @bind:after="SaveUserDisplayNameAsync" placeholder="User" />
                        </div>
                        <div class="avatar-icon-row">
                            <label>Icon:</label>
                            <select class="theme-select small" @bind="userAvatarIcon" @bind:after="SaveUserAvatarIconAsync">
                                @foreach (var icon in AvailableAvatarIcons)
                                {
                                    <option value="@icon.Value">@icon.Name</option>
                                }
                            </select>
                        </div>
                        <div class="avatar-actions">
                            <label class="settings-btn upload-btn">
                                <span class="bi bi-upload"></span> Upload Image
                                <InputFile OnChange="OnUserAvatarUpload" accept="image/*" style="display: none;" />
                            </label>
                            @if (!string.IsNullOrEmpty(userCustomAvatar))
                            {
                                <button class="settings-btn danger small" @onclick="ClearUserCustomAvatar">
                                    <span class="bi bi-x"></span> Clear
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Assistant Avatar</h4>
                <div class="avatar-settings-row">
                    <div class="avatar-preview assistant">
                        @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                        {
                            <img src="@assistantCustomAvatar" alt="Assistant" />
                        }
                        else
                        {
                            <span class="bi @assistantAvatarIcon"></span>
                        }
                    </div>
                    <div class="avatar-controls">
                        <div class="avatar-name-row">
                            <label>Display Name:</label>
                            <input type="text" class="settings-input small" @bind="assistantDisplayName" @bind:after="SaveAssistantDisplayNameAsync" placeholder="Assistant" />
                        </div>
                        <div class="avatar-icon-row">
                            <label>Icon:</label>
                            <select class="theme-select small" @bind="assistantAvatarIcon" @bind:after="SaveAssistantAvatarIconAsync">
                                @foreach (var icon in AvailableAvatarIcons)
                                {
                                    <option value="@icon.Value">@icon.Name</option>
                                }
                            </select>
                        </div>
                        <div class="avatar-actions">
                            <label class="settings-btn upload-btn">
                                <span class="bi bi-upload"></span> Upload Image
                                <InputFile OnChange="OnAssistantAvatarUpload" accept="image/*" style="display: none;" />
                            </label>
                            @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                            {
                                <button class="settings-btn danger small" @onclick="ClearAssistantCustomAvatar">
                                    <span class="bi bi-x"></span> Clear
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Preview</h4>
                <div class="chat-preview">
                    <div class="preview-msg user">
                        <div class="preview-avatar user">
                            @if (!string.IsNullOrEmpty(userCustomAvatar))
                            {
                                <img src="@userCustomAvatar" alt="User" />
                            }
                            else
                            {
                                <span class="bi @userAvatarIcon"></span>
                            }
                        </div>
                        <div class="preview-content">
                            <span class="preview-name">@userDisplayName</span>
                            <span class="preview-text">Hello, can you help me?</span>
                        </div>
                    </div>
                    <div class="preview-msg assistant">
                        <div class="preview-avatar assistant">
                            @if (!string.IsNullOrEmpty(assistantCustomAvatar))
                            {
                                <img src="@assistantCustomAvatar" alt="Assistant" />
                            }
                            else
                            {
                                <span class="bi @assistantAvatarIcon"></span>
                            }
                        </div>
                        <div class="preview-content">
                            <span class="preview-name">@assistantDisplayName</span>
                            <span class="preview-text">Of course! I'm here to help.</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (activeTab == "Storage")
        {
            <div class="settings-section">
                <h4>Learning Resources Directory</h4>
                <div class="path-input-row">
                    <input type="text" class="settings-input path-input" value="@learningResourcesPath" readonly />
                    <button class="settings-btn" @onclick="OpenResourcesFolder" title="Open folder">
                        <span class="bi bi-folder2-open"></span>
                    </button>
                </div>
                <p>Learning resources are saved to this folder and can be checked into GitHub.</p>
                
                <div class="folder-stats">
                    <div class="stat-item">
                        <span class="stat-label">Original files:</span>
                        <span class="stat-value">@originalFileCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Formatted files:</span>
                        <span class="stat-value">@formattedFileCount</span>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Storage Options</h4>
                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                    <input type="checkbox" id="saveFormatted" @bind="saveFormattedAsMarkdown" @bind:after="SaveStorageOptionsAsync" style="width: 18px; height: 18px;" />
                    <label for="saveFormatted">Save formatted resources as .md files</label>
                </div>
                <div style="display: flex; align-items: center; gap: 10px;">
                    <input type="checkbox" id="preserveOriginal" @bind="preserveOriginalFiles" @bind:after="SaveStorageOptionsAsync" style="width: 18px; height: 18px;" />
                    <label for="preserveOriginal">Preserve original uploaded files</label>
                </div>
                <p>These options control how resources are saved to the file system.</p>
            </div>

            <div class="settings-section">
                <h4>Folder Structure</h4>
                <div class="folder-tree">
                    <div class="folder-item">📁 Resources/</div>
                    <div class="folder-item indent">📁 Original/ - Original uploaded files</div>
                    <div class="folder-item indent">📁 Formatted/ - AI-formatted markdown files</div>
                    <div class="folder-item indent">📁 Courses/ - Course definitions</div>
                </div>
            </div>
        }
        else if (activeTab == "Quiz")
        {
            <div class="settings-section">
                <h4>Number of Quiz Questions</h4>
                <select class="theme-select" @bind="quizQuestionCount" @bind:after="SaveQuizQuestionCountAsync">
                    <option value="3">3 questions</option>
                    <option value="5">5 questions</option>
                    <option value="10">10 questions</option>
                    <option value="15">15 questions</option>
                    <option value="20">20 questions</option>
                </select>
                <p>Select how many questions to include in each quiz.</p>
            </div>

            <div class="settings-section">
                <h4>Grading Scale</h4>
                <select class="theme-select" @bind="gradingScale" @bind:after="SaveGradingScaleAsync">
                    <option value="Standard">Standard (A=90%, B=80%, C=70%, D=60%)</option>
                    <option value="PlusMinus">Plus/Minus (A+, A, A-, B+, etc.)</option>
                    <option value="Lenient">Lenient (A=85%, B=75%, C=65%, D=55%)</option>
                    <option value="Strict">Strict (A=95%, B=85%, C=75%, D=65%)</option>
                </select>
                <p>Choose the grading scale for quiz results.</p>
            </div>

            <div class="settings-section">
                <h4>Grading Scale Preview</h4>
                <div class="grading-preview">
                    @foreach (var grade in GetGradingPreview())
                    {
                        <div class="grade-item">
                            <span class="grade-letter">@grade.Letter</span>
                            <span class="grade-range">@grade.Range</span>
                        </div>
                    }
                </div>
            </div>
        }
        else if (activeTab == "ChatGPT")
        {
            <div class="settings-section">
                <h4>OpenAI API Key</h4>
                <input type="password"
                       class="settings-input"
                       @bind="chatGptApiKey"
                       placeholder="sk-..." />
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <button class="settings-btn" @onclick="SaveChatGptKeyAsync" disabled="@isBusy">Save</button>
                    <button class="settings-btn" @onclick="ClearChatGptKeyAsync" disabled="@isBusy">Clear</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(chatGptKeyPreview))
                {
                    <p>Stored key: <code>@chatGptKeyPreview</code></p>
                }
                <p>Get your API key from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a></p>
            </div>

            <div class="settings-section">
                <h4>Model</h4>
                <select class="theme-select" @bind="chatGptModel" @bind:after="SaveChatGptModelAsync">
                    <option value="gpt-4.1-mini">GPT-4.1 Mini</option>
                    <option value="gpt-4.1">GPT-4.1</option>
                    <option value="gpt-4o">GPT-4o</option>
                    <option value="gpt-4o-mini">GPT-4o Mini</option>
                </select>
                <p>Select which ChatGPT model to use.</p>
            </div>
        }
        else if (activeTab == "Claude")
        {
            <div class="settings-section">
                <h4>Anthropic API Key</h4>
                <input type="password"
                       class="settings-input"
                       @bind="claudeApiKey"
                       placeholder="sk-ant-..." />
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <button class="settings-btn" @onclick="SaveClaudeKeyAsync" disabled="@isBusy">Save</button>
                    <button class="settings-btn" @onclick="ClearClaudeKeyAsync" disabled="@isBusy">Clear</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(claudeKeyPreview))
                {
                    <p>Stored key: <code>@claudeKeyPreview</code></p>
                }
                <p>⚠️ Claude integration coming soon</p>
                <p>Get your API key from <a href="https://console.anthropic.com/" target="_blank">Anthropic Console</a></p>
            </div>
        }
        else if (activeTab == "Gemini")
        {
            <div class="settings-section">
                <h4>Google AI API Key</h4>
                <input type="password"
                       class="settings-input"
                       @bind="geminiApiKey"
                       placeholder="AIza..." />
                <div style="margin-top: 10px; display: flex; gap: 10px;">
                    <button class="settings-btn" @onclick="SaveGeminiKeyAsync" disabled="@isBusy">Save</button>
                    <button class="settings-btn" @onclick="ClearGeminiKeyAsync" disabled="@isBusy">Clear</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(geminiKeyPreview))
                {
                    <p>Stored key: <code>@geminiKeyPreview</code></p>
                }
                <p>⚠️ Gemini integration coming soon</p>
                <p>Get your API key from <a href="https://aistudio.google.com/apikey" target="_blank">Google AI Studio</a></p>
            </div>
        }
        else if (activeTab == "About")
        {
            <div class="settings-section">
                <h4>Tutor</h4>
                <p>Version 1.0.0</p>
                <p>A multi-model AI chat application built with .NET MAUI Blazor.</p>
            </div>

            <div class="settings-section">
                <h4>Supported Models</h4>
                <p>• ChatGPT (OpenAI) - Active</p>
                <p>• Claude (Anthropic) - Coming Soon</p>
                <p>• Gemini (Google) - Coming Soon</p>
            </div>

            <div class="settings-section">
                <h4>Links</h4>
                <p><a href="https://github.com/mindattic/Tutor" target="_blank">GitHub Repository</a></p>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(status))
    {
        <p style="color: var(--text-secondary); margin-top: 16px;">@status</p>
    }
</div>

@code
{
    private const string SelectedModelKey = "SELECTED_MODEL";
    private const string ChatGptApiKeyName = "OPENAI_API_KEY";
    private const string ClaudeApiKeyName = "CLAUDE_API_KEY";
    private const string GeminiApiKeyName = "GEMINI_API_KEY";
    private const string EnterToSendKey = "ENTER_TO_SEND";
    private const string ChatGptModelKey = "CHATGPT_MODEL";

    private string activeTab = "General";
    private string selectedTheme = "Light";
    private string selectedModel = "ChatGPT";
    private string chatGptModel = "gpt-4.1-mini";
    private string chatGptApiKey = "";
    private string claudeApiKey = "";
    private string geminiApiKey = "";
    private string chatGptKeyPreview = "";
    private string claudeKeyPreview = "";
    private string geminiKeyPreview = "";
    private string status = "";
    private bool isBusy;
    private bool enterToSend = true;
    
    // Quiz settings
    private int quizQuestionCount = 3;
    private GradingScale gradingScale = GradingScale.Standard;

    // Storage settings
    private string learningResourcesPath = "";
    private bool saveFormattedAsMarkdown = true;
    private bool preserveOriginalFiles = true;
    private int originalFileCount = 0;
    private int formattedFileCount = 0;

    // Avatar settings
    private string userDisplayName = "User";
    private string assistantDisplayName = "Assistant";
    private string userAvatarIcon = "bi-person-fill";
    private string assistantAvatarIcon = "bi-robot";
    private string? userCustomAvatar;
    private string? assistantCustomAvatar;

    // Available avatar icons
    private static readonly List<(string Name, string Value)> AvailableAvatarIcons =
    [
        ("Person", "bi-person-fill"),
        ("Person Circle", "bi-person-circle"),
        ("Person Badge", "bi-person-badge-fill"),
        ("Emoji Smile", "bi-emoji-smile-fill"),
        ("Emoji Sunglasses", "bi-emoji-sunglasses-fill"),
        ("Emoji Heart Eyes", "bi-emoji-heart-eyes-fill"),
        ("Star", "bi-star-fill"),
        ("Heart", "bi-heart-fill"),
        ("Lightning", "bi-lightning-fill"),
        ("Fire", "bi-fire"),
        ("Rocket", "bi-rocket-takeoff-fill"),
        ("Trophy", "bi-trophy-fill"),
        ("Robot", "bi-robot"),
        ("CPU", "bi-cpu-fill"),
        ("Lightbulb", "bi-lightbulb-fill"),
        ("Book", "bi-book-fill"),
        ("Mortarboard", "bi-mortarboard-fill"),
        ("Chat", "bi-chat-dots-fill"),
        ("Magic", "bi-magic"),
        ("Gem", "bi-gem"),
        ("Shield", "bi-shield-fill"),
        ("Globe", "bi-globe"),
        ("Moon", "bi-moon-fill"),
        ("Sun", "bi-sun-fill"),
        ("Cloud", "bi-cloud-fill"),
        ("Music Note", "bi-music-note-beamed"),
        ("Controller", "bi-controller"),
        ("Puzzle", "bi-puzzle-fill"),
        ("Flower", "bi-flower1"),
        ("Tree", "bi-tree-fill"),
    ];


    protected override async Task OnInitializedAsync()
    {
        selectedTheme = await ThemeService.GetThemeAsync();
        await LoadSelectedModelAsync();
        await LoadAllApiKeysAsync();
        await LoadEnterToSendAsync();
        await LoadChatGptModelAsync();
        await LoadQuizSettingsAsync();
        await LoadAvatarSettingsAsync();
        LoadStorageSettings();
    }

    private async Task LoadAvatarSettingsAsync()
    {
        userDisplayName = await SettingsService.GetUserDisplayNameAsync();
        assistantDisplayName = await SettingsService.GetAssistantDisplayNameAsync();
        userAvatarIcon = await SettingsService.GetUserAvatarIconAsync();
        assistantAvatarIcon = await SettingsService.GetAssistantAvatarIconAsync();
        userCustomAvatar = await SettingsService.GetUserCustomAvatarAsync();
        assistantCustomAvatar = await SettingsService.GetAssistantCustomAvatarAsync();
    }

    private async Task SaveUserDisplayNameAsync()
    {
        await SettingsService.SetUserDisplayNameAsync(userDisplayName);
        status = "User display name saved.";
    }

    private async Task SaveAssistantDisplayNameAsync()
    {
        await SettingsService.SetAssistantDisplayNameAsync(assistantDisplayName);
        status = "Assistant display name saved.";
    }

    private async Task SaveUserAvatarIconAsync()
    {
        await SettingsService.SetUserAvatarIconAsync(userAvatarIcon);
        status = "User avatar icon saved.";
    }

    private async Task SaveAssistantAvatarIconAsync()
    {
        await SettingsService.SetAssistantAvatarIconAsync(assistantAvatarIcon);
        status = "Assistant avatar icon saved.";
    }

    private async Task OnUserAvatarUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file.Size > 512 * 1024) // 512KB limit
            {
                status = "Image too large. Please use an image under 512KB.";
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var dataUrl = $"data:{file.ContentType};base64,{base64}";
            
            userCustomAvatar = dataUrl;
            await SettingsService.SetUserCustomAvatarAsync(dataUrl);
            status = "User avatar uploaded.";
        }
        catch (Exception ex)
        {
            status = $"Failed to upload: {ex.Message}";
        }
    }

    private async Task OnAssistantAvatarUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file.Size > 512 * 1024)
            {
                status = "Image too large. Please use an image under 512KB.";
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 512 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var base64 = Convert.ToBase64String(ms.ToArray());
            var dataUrl = $"data:{file.ContentType};base64,{base64}";
            
            assistantCustomAvatar = dataUrl;
            await SettingsService.SetAssistantCustomAvatarAsync(dataUrl);
            status = "Assistant avatar uploaded.";
        }
        catch (Exception ex)
        {
            status = $"Failed to upload: {ex.Message}";
        }
    }

    private async Task ClearUserCustomAvatar()
    {
        userCustomAvatar = null;
        await SettingsService.SetUserCustomAvatarAsync(null);
        status = "User custom avatar cleared.";
    }

    private async Task ClearAssistantCustomAvatar()
    {
        assistantCustomAvatar = null;
        await SettingsService.SetAssistantCustomAvatarAsync(null);
        status = "Assistant custom avatar cleared.";
    }

    private void LoadStorageSettings()
    {
        StorageSettings.Load();
        learningResourcesPath = StorageSettings.GetResolvedDirectory();
        saveFormattedAsMarkdown = StorageSettings.SaveFormattedAsMarkdown;
        preserveOriginalFiles = StorageSettings.PreserveOriginalFiles;
        
        // Count files
        originalFileCount = FileResourceService.GetOriginalFiles().Count;
        formattedFileCount = FileResourceService.GetFormattedFiles().Count;
    }

    private void SaveStorageOptionsAsync()
    {
        StorageSettings.SaveFormattedAsMarkdown = saveFormattedAsMarkdown;
        StorageSettings.PreserveOriginalFiles = preserveOriginalFiles;
        StorageSettings.Save();
        status = "Storage options saved.";
    }

    private void OpenResourcesFolder()
    {
        FileResourceService.OpenResourcesDirectory();
    }

    private async Task LoadQuizSettingsAsync()
    {
        quizQuestionCount = await SettingsService.GetQuizQuestionCountAsync();
        gradingScale = await SettingsService.GetGradingScaleAsync();
    }

    private async Task SaveQuizQuestionCountAsync()
    {
        await SettingsService.SetQuizQuestionCountAsync(quizQuestionCount);
        status = $"Quiz will have {quizQuestionCount} questions.";
    }

    private async Task SaveGradingScaleAsync()
    {
        await SettingsService.SetGradingScaleAsync(gradingScale);
        status = $"Grading scale set to {gradingScale}.";
    }

    private List<(string Letter, string Range)> GetGradingPreview()
    {
        return gradingScale switch
        {
            GradingScale.Standard => new List<(string, string)>
            {
                ("A", "90-100%"), ("B", "80-89%"), ("C", "70-79%"), ("D", "60-69%"), ("F", "0-59%")
            },
            GradingScale.PlusMinus => new List<(string, string)>
            {
                ("A+", "97-100%"), ("A", "93-96%"), ("A-", "90-92%"),
                ("B+", "87-89%"), ("B", "83-86%"), ("B-", "80-82%"),
                ("C+", "77-79%"), ("C", "73-76%"), ("C-", "70-72%"),
                ("D+", "67-69%"), ("D", "63-66%"), ("D-", "60-62%"),
                ("F", "0-59%")
            },
            GradingScale.Lenient => new List<(string, string)>
            {
                ("A", "85-100%"), ("B", "75-84%"), ("C", "65-74%"), ("D", "55-64%"), ("F", "0-54%")
            },
            GradingScale.Strict => new List<(string, string)>
            {
                ("A", "95-100%"), ("B", "85-94%"), ("C", "75-84%"), ("D", "65-74%"), ("F", "0-64%")
            },
            _ => new List<(string, string)>()
        };
    }

    private async Task SaveThemeAsync()
    {
        await ThemeService.SetThemeAsync(selectedTheme);
        await JS.InvokeVoidAsync("setTheme", selectedTheme);
        status = $"Theme changed to {selectedTheme}.";
    }

    private async Task LoadSelectedModelAsync()
    {
        try
        {
            var model = await SecureStorage.GetAsync(SelectedModelKey);
            if (!string.IsNullOrEmpty(model))
            {
                selectedModel = model;
            }
        }
        catch { }
    }

    private async Task SaveSelectedModelAsync()
    {
        try
        {
            await SecureStorage.SetAsync(SelectedModelKey, selectedModel);
            status = $"{selectedModel} selected as active model.";
        }
        catch (Exception ex)
        {
            status = "Failed to save selection: " + ex.Message;
        }
    }

    private async Task LoadChatGptModelAsync()
    {
        try
        {
            var model = await SecureStorage.GetAsync(ChatGptModelKey);
            if (!string.IsNullOrEmpty(model))
            {
                chatGptModel = model;
            }
        }
        catch { }
    }

    private async Task SaveChatGptModelAsync()
    {
        try
        {
            await SecureStorage.SetAsync(ChatGptModelKey, chatGptModel);
            status = $"ChatGPT model set to {chatGptModel}.";
        }
        catch (Exception ex)
        {
            status = "Failed to save model: " + ex.Message;
        }
    }

    private async Task LoadAllApiKeysAsync()
    {
        chatGptKeyPreview = await LoadKeyPreviewAsync(ChatGptApiKeyName);
        claudeKeyPreview = await LoadKeyPreviewAsync(ClaudeApiKeyName);
        geminiKeyPreview = await LoadKeyPreviewAsync(GeminiApiKeyName);
    }

    private async Task<string> LoadKeyPreviewAsync(string keyName)
    {
        try
        {
            var key = await SecureStorage.GetAsync(keyName);
            return string.IsNullOrWhiteSpace(key) ? "" : MaskKey(key);
        }
        catch
        {
            return "";
        }
    }

    private async Task SaveChatGptKeyAsync()
    {
        await SaveApiKeyAsync(ChatGptApiKeyName, chatGptApiKey, "ChatGPT");
        chatGptKeyPreview = await LoadKeyPreviewAsync(ChatGptApiKeyName);
        chatGptApiKey = "";
    }

    private async Task ClearChatGptKeyAsync()
    {
        await ClearApiKeyAsync(ChatGptApiKeyName, "ChatGPT");
        chatGptKeyPreview = "";
        chatGptApiKey = "";
    }

    private async Task SaveClaudeKeyAsync()
    {
        await SaveApiKeyAsync(ClaudeApiKeyName, claudeApiKey, "Claude");
        claudeKeyPreview = await LoadKeyPreviewAsync(ClaudeApiKeyName);
        claudeApiKey = "";
    }

    private async Task ClearClaudeKeyAsync()
    {
        await ClearApiKeyAsync(ClaudeApiKeyName, "Claude");
        claudeKeyPreview = "";
        claudeApiKey = "";
    }

    private async Task SaveGeminiKeyAsync()
    {
        await SaveApiKeyAsync(GeminiApiKeyName, geminiApiKey, "Gemini");
        geminiKeyPreview = await LoadKeyPreviewAsync(GeminiApiKeyName);
        geminiApiKey = "";
    }

    private async Task ClearGeminiKeyAsync()
