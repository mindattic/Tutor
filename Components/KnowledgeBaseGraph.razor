@using Microsoft.JSInterop
@using Tutor.Models
@using Tutor.Services
@inject KnowledgeBaseStorageService KbStorageService
@inject IJSRuntime JS
@implements IDisposable

@if (isLoading)
{
    <div class="kb-graph-container">
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Loading Knowledge Base...</p>
        </div>
    </div>
}
else if (knowledgeBase == null)
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-exclamation-circle"></span>
            </div>
            <h4>Knowledge Base Not Found</h4>
            <p>The knowledge base could not be loaded. It may need to be regenerated.</p>
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p class="error-text">@errorMessage</p>
            }
        </div>
    </div>
}
else if (concepts.Count == 0)
{
    <div class="kb-graph-container">
        <div class="empty-state">
            <div class="empty-icon">
                <span class="bi bi-diagram-3"></span>
            </div>
            <h4>No Concepts Found</h4>
            <p>This knowledge base has no concepts. Try regenerating it with more content.</p>
        </div>
    </div>
}
else
{
<div class="kb-graph-container">
    <div class="kb-graph-header">
        <h4>@(knowledgeBase?.Name ?? "Knowledge Base")</h4>
        <div class="kb-graph-stats">
            <span class="stat">@concepts.Count concepts</span>
            <span class="stat">@relationships.Count relationships</span>
        </div>
    </div>
    
    <div class="kb-graph-wrapper">
        <div id="kb-force-graph" class="force-graph-canvas" @ref="graphContainer"></div>
    </div>

    @if (selectedConcept != null)
    {
        <div class="concept-detail-panel">
            <div class="concept-detail-header">
                <h5>@selectedConcept.Title</h5>
                <button class="close-btn small" @onclick="ClearSelection">
                    <span class="bi bi-x-lg"></span>
                </button>
            </div>
            
            @if (!string.IsNullOrEmpty(selectedConcept.Summary))
            {
                <div class="concept-summary">@selectedConcept.Summary</div>
            }

            @if (selectedConcept.Aliases.Count > 0)
            {
                <div class="concept-aliases">
                    <span class="label">Also known as:</span>
                    <span class="value">@string.Join(", ", selectedConcept.Aliases)</span>
                </div>
            }

            @if (selectedConcept.Tags.Count > 0)
            {
                <div class="concept-tags">
                    @foreach (var tag in selectedConcept.Tags)
                    {
                        <span class="kb-tag">@tag</span>
                    }
                </div>
            }

            @if (relatedConcepts.Count > 0)
            {
                <div class="concept-relationships">
                    <h6>Related Concepts</h6>
                    <div class="relationship-list">
                        @foreach (var rel in relatedConcepts)
                        {
                            <button class="relationship-btn" @onclick="@(() => SelectConceptById(rel.TargetConceptId))">
                                <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                <span class="rel-target">@GetConceptTitle(rel.TargetConceptId)</span>
                                <span class="bi bi-arrow-right"></span>
                            </button>
                        }
                    </div>
                </div>
            }

            @if (incomingRelationships.Count > 0)
            {
                <div class="concept-relationships incoming">
                    <h6>Referenced By</h6>
                    <div class="relationship-list">
                        @foreach (var rel in incomingRelationships)
                        {
                            <button class="relationship-btn" @onclick="@(() => SelectConceptById(rel.SourceConceptId))">
                                <span class="rel-source">@GetConceptTitle(rel.SourceConceptId)</span>
                                <span class="rel-type @rel.RelationType.ToString().ToLower()">@FormatRelationType(rel.RelationType)</span>
                                <span class="bi bi-arrow-left"></span>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="concept-detail-panel empty">
            <div class="empty-hint">
                <span class="bi bi-hand-index"></span>
                <span>Click on a concept node to view details</span>
            </div>
        </div>
    }
</div>
}

@code {
    [Parameter] public string? KnowledgeBaseId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private KnowledgeBase? knowledgeBase;
    private List<Concept> concepts = [];
    private List<ConceptRelationship> relationships = [];
    private Concept? selectedConcept;
    private List<ConceptRelationship> relatedConcepts = [];
    private List<ConceptRelationship> incomingRelationships = [];
    private ElementReference graphContainer;
    private DotNetObjectReference<KnowledgeBaseGraph>? dotNetRef;
    private bool isInitialized;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        // Load when parameter changes
        if (!string.IsNullOrEmpty(KnowledgeBaseId) && !isInitialized)
        {
            await LoadKnowledgeBase();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && concepts.Count > 0 && !isInitialized)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeGraph();
            isInitialized = true;
        }
        else if (!firstRender && concepts.Count > 0 && !isInitialized)
        {
            // Graph data loaded after first render, initialize now
            dotNetRef = DotNetObjectReference.Create(this);
            await InitializeGraph();
            isInitialized = true;
        }
    }

    private async Task LoadKnowledgeBase()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            if (string.IsNullOrEmpty(KnowledgeBaseId))
            {
                errorMessage = "No Knowledge Base ID provided.";
                return;
            }

            System.Diagnostics.Debug.WriteLine($"[KnowledgeBaseGraph] Loading KB: {KnowledgeBaseId}");
            knowledgeBase = await KbStorageService.LoadAsync(KnowledgeBaseId);
            
            if (knowledgeBase != null)
            {
                concepts = knowledgeBase.Concepts ?? [];
                relationships = knowledgeBase.Relations ?? [];
                System.Diagnostics.Debug.WriteLine($"[KnowledgeBaseGraph] Loaded {concepts.Count} concepts, {relationships.Count} relationships");
            }
            else
            {
                errorMessage = $"Knowledge Base with ID '{KnowledgeBaseId}' not found.";
                System.Diagnostics.Debug.WriteLine($"[KnowledgeBaseGraph] KB not found: {KnowledgeBaseId}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading Knowledge Base: {ex.Message}";
            System.Diagnostics.Debug.WriteLine($"[KnowledgeBaseGraph] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitializeGraph()
    {
        if (concepts.Count == 0) return;

        // Prepare data for D3.js
        var nodes = concepts.Select(c => new
        {
            id = c.Id,
            title = c.Title,
            group = c.Tags.FirstOrDefault() ?? "default"
        }).ToArray();

        var links = relationships.Select(r => new
        {
            source = r.SourceConceptId,
            target = r.TargetConceptId,
            type = r.RelationType.ToString()
        }).ToArray();

        await JS.InvokeVoidAsync("initForceGraph", graphContainer, nodes, links, dotNetRef);
    }

    [JSInvokable]
    public void OnNodeClick(string conceptId)
    {
        SelectConceptById(conceptId);
        StateHasChanged();
    }

    private void SelectConceptById(string conceptId)
    {
        selectedConcept = concepts.FirstOrDefault(c => c.Id == conceptId);
        if (selectedConcept != null)
        {
            relatedConcepts = relationships.Where(r => r.SourceConceptId == conceptId).ToList();
            incomingRelationships = relationships.Where(r => r.TargetConceptId == conceptId).ToList();
        }
        else
        {
            relatedConcepts = [];
            incomingRelationships = [];
        }
    }

    private void ClearSelection()
    {
        selectedConcept = null;
        relatedConcepts = [];
        incomingRelationships = [];
    }

    private string GetConceptTitle(string conceptId)
    {
        return concepts.FirstOrDefault(c => c.Id == conceptId)?.Title ?? "Unknown";
    }

    private string FormatRelationType(ConceptRelationType type)
    {
        return type switch
        {
            ConceptRelationType.Prerequisite => "requires",
            ConceptRelationType.Related => "related to",
            ConceptRelationType.Contains => "contains",
            ConceptRelationType.InstanceOf => "instance of",
            ConceptRelationType.SimilarTo => "similar to",
            ConceptRelationType.ContrastsWith => "contrasts",
            _ => type.ToString().ToLower()
        };
    }

    public void Dispose()
    {
        dotNetRef?.Dispose();
    }
}
